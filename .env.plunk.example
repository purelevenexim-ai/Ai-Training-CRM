# ====================================
# Plunk Self-Hosted Configuration
# ====================================

# Database
DB_PASSWORD=your-secure-db-password-here

# JWT Secret (generate: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Domain Configuration
# Change these to your actual domains
API_DOMAIN=api.pureleven.local
DASHBOARD_DOMAIN=app.pureleven.local
LANDING_DOMAIN=www.pureleven.local
WIKI_DOMAIN=docs.pureleven.local
SMTP_DOMAIN=smtp.pureleven.local

# HTTPS (set to true in production)
USE_HTTPS=false

# ====================================
# AWS SES Configuration (Email Sending)
# ====================================
# Required for Plunk to send emails
# Get credentials from AWS SES console

AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your-aws-access-key
AWS_SES_SECRET_ACCESS_KEY=your-aws-secret-key
SES_CONFIGURATION_SET=plunk-tracking

# ====================================
# Minio Storage (optional - auto-configured)
# ====================================
MINIO_ROOT_USER=plunk
MINIO_ROOT_PASSWORD=plunkminiopass
