{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-merch-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign blog_intro = ''
  assign blog_marketing_heading = 'Read the guide, then move straight into Pureleven products without losing momentum.'
  assign blog_marketing_kicker = 'From Kerala soil to your kitchen.'
  assign primary_product_handle = 'kerala-black-pepper-200gm'
  assign secondary_product_handle = 'kerala-cardamom-8mm-fruit-100gm'
  assign tertiary_product_handle = 'cardamom-100g-black-pepper-200g-clove-100g-3-in-1-spice-combo-pack'
  assign collection_cta_url = '/collections/combo'
  assign collection_cta_label = 'Shop combo packs'

  case blog.handle
    when 'cooking-spices'
      assign blog_intro = 'Answer-first guides on Kerala spices, storage, sourcing, flavor differences, and practical kitchen use.'
    when 'honey'
      assign blog_intro = 'Practical honey guides on purity, sourcing, comparisons, and everyday use.'
      assign blog_marketing_heading = 'Honey readers now get a direct path into the live Pureleven kitchen catalog instead of a dead-end blog loop.'
      assign primary_product_handle = 'cardamom-100g-black-pepper-200g-clove-100g-3-in-1-spice-combo-pack'
      assign secondary_product_handle = 'aromatic-true-cinnamon-ceylon-100g'
      assign tertiary_product_handle = 'kerala-black-pepper-200gm'
      assign collection_cta_label = 'Shop kitchen best sellers'
    when 'herbs'
      assign blog_intro = 'Practical herb guides on flavor, benefits, storage, and everyday kitchen use.'
      assign blog_marketing_heading = 'Turn herb-led browsing into aromatic kitchen discovery with products that fit seasoning, infusions, and repeat kitchen use.'
      assign primary_product_handle = 'aromatic-true-cinnamon-ceylon-100g'
      assign secondary_product_handle = 'kerala-black-pepper-200gm'
      assign tertiary_product_handle = 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack'
      assign collection_cta_url = '/collections/cinnamon'
      assign collection_cta_label = 'Shop aromatic picks'
    else
      assign blog_intro = 'Ingredient guides and product education from Organic Pure Leven.'
      assign collection_cta_url = routes.all_products_collection_url
      assign collection_cta_label = 'See all products'
  endcase

  assign blog_home_url = shop.secure_url | append: '/'
  assign blog_current_url = shop.secure_url | append: blog.url
  assign featured_blog_product = all_products[primary_product_handle]
  assign secondary_blog_product = all_products[secondary_product_handle]
  assign tertiary_blog_product = all_products[tertiary_product_handle]

  if featured_blog_product == blank
    assign featured_blog_product = all_products['kerala-black-pepper-200gm']
  endif
  if secondary_blog_product == blank
    assign secondary_blog_product = all_products['kerala-cardamom-8mm-fruit-100gm']
  endif
  if tertiary_blog_product == blank
    assign tertiary_blog_product = all_products['cardamom-100g-black-pepper-200g-clove-100g-3-in-1-spice-combo-pack']
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .main-blog__breadcrumbs {
    margin: 0 0 1.2rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .main-blog__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .main-blog__intro {
    max-width: 58rem;
    margin: 1rem 0 2rem;
    font-size: 1.6rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.82);
  }

  .main-blog .title--primary {
    margin: 0;
    max-width: 10ch;
    font-size: clamp(4rem, 7vw, 7.2rem);
    line-height: 0.94;
    letter-spacing: -0.04em;
  }

  .main-blog__empty {
    max-width: 56rem;
    margin-top: 1.6rem;
    padding: 1.8rem 2rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
    border-radius: 1.6rem;
    background: rgba(var(--color-foreground), 0.03);
  }

  .main-blog__conversion-shell {
    display: grid;
    gap: 1.8rem;
    margin: 0 0 3rem;
    padding: clamp(2rem, 4vw, 2.8rem);
    border-radius: 2.8rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    background:
      radial-gradient(circle at top left, rgba(var(--color-foreground), 0.05), transparent 38%),
      linear-gradient(180deg, rgba(var(--color-background), 0.98), rgba(var(--color-foreground), 0.02));
    box-shadow: 0 1.8rem 3.4rem rgba(var(--color-foreground), 0.06);
  }

  .main-blog__kicker {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.7);
  }

  .main-blog__marketing-copy {
    display: grid;
    gap: 1.2rem;
  }

  .main-blog__marketing-copy h2 {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(3.2rem, 4.6vw, 5.6rem);
    line-height: 0.98;
  }

  .main-blog__cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .main-blog__cta-row .button {
    min-width: 16rem;
  }

  .main-blog__trust-strip {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
  }

  .main-blog__trust-item {
    padding: 1rem 1.2rem;
    border-radius: 999px;
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    background: rgba(var(--color-background), 0.84);
  }

  .main-blog__merch-grid {
    display: grid;
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .main-blog__conversion-shell {
      grid-template-columns: minmax(0, 1fr) minmax(24rem, 30rem);
      align-items: start;
    }
  }

  @media screen and (min-width: 990px) {
    .main-blog__conversion-shell {
      grid-template-columns: minmax(0, 1fr) minmax(28rem, 34rem);
    }
  }
{%- endstyle -%}

{%- paginate blog.articles by 6 -%}
  <div class="main-blog page-width section-{{ section.id }}-padding">
    <nav class="main-blog__breadcrumbs caption-with-letter-spacing" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true"> / </span>
      <span>{{ blog.title | escape }}</span>
    </nav>

    <h1 class="title--primary{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ blog.title | escape }}
    </h1>

    <p class="main-blog__intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ blog_intro }}
    </p>

    <div class="main-blog__conversion-shell{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="main-blog__marketing-copy">
        <p class="main-blog__kicker">{{ blog_marketing_kicker }}</p>
        <h2>{{ blog_marketing_heading }}</h2>
        <div class="main-blog__cta-row">
          <a href="{{ collection_cta_url }}" class="button">{{ collection_cta_label }}</a>
          <a href="{{ routes.all_products_collection_url }}" class="button button--secondary">See all products</a>
          <a href="{{ routes.root_url }}" class="button button--secondary">Visit homepage</a>
        </div>
        <div class="main-blog__trust-strip" aria-label="Pureleven trust points">
          <div class="main-blog__trust-item">Farm-direct sourcing from Kerala</div>
          <div class="main-blog__trust-item">Small-batch packing for stronger aroma</div>
          <div class="main-blog__trust-item">Premium gifting and repeat-buy packs</div>
        </div>
      </div>

      <div class="main-blog__merch-grid">
        {%- if featured_blog_product != blank -%}
          {% render 'article-merch-card', card_product: featured_blog_product, eyebrow: 'Editor\'s pick', supporting_text: 'A strong first Pureleven buy for readers moving from guide to checkout.', action_label: 'View product', layout: 'horizontal' %}
        {%- endif -%}
        {%- if secondary_blog_product != blank -%}
          {% render 'article-merch-card', card_product: secondary_blog_product, eyebrow: 'Everyday buy', action_label: 'View product', layout: 'horizontal' %}
        {%- endif -%}
        {%- if tertiary_blog_product != blank -%}
          {% render 'article-merch-card', card_product: tertiary_blog_product, eyebrow: 'Bundle value', action_label: 'View product', layout: 'horizontal' %}
        {%- endif -%}
      </div>
    </div>

    {%- if blog.articles_count == 0 -%}
      <div class="main-blog__empty rte">
        <p>This blog does not have published articles yet. Browse the main spice journal for currently published guides.</p>
        <p><a href="/blogs/cooking-spices">Explore Cooking &amp; Spices</a></p>
      </div>
    {%- endif -%}

    <div class="blog-articles {% if section.settings.layout == 'collage' %}blog-articles--collage{% endif %}">
      {%- for article in blog.articles -%}
        <div
          class="blog-articles__article article{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          {%- render 'article-card',
            article: article,
            media_height: section.settings.image_height,
            media_aspect_ratio: article.image.aspect_ratio,
            show_image: section.settings.show_image,
            show_date: section.settings.show_date,
            show_author: section.settings.show_author,
            show_excerpt: true
          -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": {{ blog.title | strip | json }},
      "description": {{ blog_intro | strip | json }},
      "url": {{ blog_current_url | json }}
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ blog_home_url | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | strip | json }},
          "item": {{ blog_current_url | json }}
        }
      ]
    }
  </script>
{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.main-blog.settings.layout.options__1.label"
        },
        {
          "value": "collage",
          "label": "t:sections.main-blog.settings.layout.options__2.label"
        }
      ],
      "default": "collage",
      "label": "t:sections.main-blog.settings.layout.label"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.main-blog.settings.show_image.label"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-blog.settings.image_height.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.main-blog.settings.image_height.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.main-blog.settings.image_height.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.main-blog.settings.image_height.options__4.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.main-blog.settings.image_height.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.main-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.main-blog.settings.show_author.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
