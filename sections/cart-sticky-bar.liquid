<!-- Cart sticky bar: total + BUY NOW -->
<!-- JS moves #sr-cart-fixed-bar to <body> to ensure position:fixed is never inside a CSS transform context -->
<div id="sr-sticky-src" aria-hidden="true" hidden>
  <div id="sr-cart-fixed-bar">
    <div id="sr-fixed-total">
      <span id="sr-fixed-label">Estimated total</span>
      <span id="sr-fixed-price">{{ cart.total_price | money_with_currency }}</span>
    </div>
    <div id="sr-fixed-cta">
      <div class="shiprocket-headless" data-type="cart"></div>
    </div>
  </div>
</div>
<style>
  #sr-cart-fixed-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 14px;
    background: #fff;
    padding: 10px 16px;
    padding-bottom: max(10px, env(safe-area-inset-bottom));
    border-top: 1px solid rgba(0,0,0,.07);
    box-shadow: 0 -6px 24px rgba(0,0,0,.08);
  }
  #sr-fixed-total {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  #sr-fixed-label {
    display: block;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: #9a9a9a;
    line-height: 1;
  }
  #sr-fixed-price {
    display: block;
    font-size: 18px;
    font-weight: 800;
    color: #111;
    line-height: 1.15;
    letter-spacing: -.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #sr-fixed-cta {
    flex-shrink: 0;
    width: 152px;
  }
  #main-cart-items {
    padding-bottom: 90px;
  }
  #main-cart-footer {
    padding-bottom: 96px;
  }

  /* --- Defensive scroll fixes for cart page ---
     The Anu login popup adds .anu-login-lock to html+body at 25% scroll depth,
     causing overflow:hidden which traps mobile scroll. The popup is now disabled
     on cart, but these overrides guard against any other source locking scroll.
     .stop__scroll__body (Shiprocket modal) is intentionally preserved. */
  html.anu-login-lock,
  body.anu-login-lock:not(.stop__scroll__body) {
    overflow: auto !important;
    overflow-y: auto !important;
    overscroll-behavior: auto !important;
  }
</style>
<script>
(function () {
  function mountFixedBar() {
    var src = document.getElementById('sr-sticky-src');
    if (!src) return;
    var bar = document.getElementById('sr-cart-fixed-bar');
    if (!bar || bar.parentNode !== src) return;
    document.body.appendChild(bar);
  }
  if (document.readyState !== 'loading') {
    mountFixedBar();
  } else {
    document.addEventListener('DOMContentLoaded', mountFixedBar);
  }
}());
</script>

{% schema %}
{
  "name": "Cart Sticky Bar",
  "settings": []
}
{% endschema %}
