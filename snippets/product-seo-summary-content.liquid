{%- if summary != blank -%}
  <div class="product__seo-summary-surface">
    <p class="product__seo-summary-eyebrow">Answer-first guide</p>
    <p class="product__seo-summary-text">{{ summary }}</p>
    <ul class="product__seo-summary-highlights list-unstyled" role="list">
      {%- if highlight_1 != blank -%}<li>{{ highlight_1 }}</li>{%- endif -%}
      {%- if highlight_2 != blank -%}<li>{{ highlight_2 }}</li>{%- endif -%}
      {%- if highlight_3 != blank -%}<li>{{ highlight_3 }}</li>{%- endif -%}
      {%- if highlight_4 != blank -%}<li>{{ highlight_4 }}</li>{%- endif -%}
    </ul>
    <div class="product__seo-summary-actions">
      <a class="product__seo-summary-action product__seo-summary-action--primary" href="{{ primary_cta_url }}">{{ primary_cta_label }}</a>
      <a class="product__seo-summary-action product__seo-summary-action--secondary" href="{{ secondary_cta_url }}">{{ secondary_cta_label }}</a>
    </div>
    {%- if note != blank -%}
      <p class="product__seo-summary-note">{{ note }}</p>
    {%- endif -%}
  </div>
{%- endif -%}