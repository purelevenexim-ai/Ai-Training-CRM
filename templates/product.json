    "custom_liquid_mfDEHn": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div id=\"pl-quality-guarantee\" class=\"pl-quality-section\">\n\n<style>\n  /* \u2500\u2500 Pureleven Quality Section \u2014 Premium Desktop Experience \u2500\u2500 */\n  .pl-quality-section {\n    background: linear-gradient(135deg, var(--pl-cream, #F8F5EE) 0%, #fafaf8 100%);\n    padding: 96px 0;\n  }\n  \n  .pl-quality-container {\n    max-width: 1280px;\n    margin: 0 auto;\n    padding: 0 48px;\n  }\n  \n  .pl-quality-inner {\n    display: grid;\n    grid-template-columns: 1fr 1.1fr;\n    gap: 72px;\n    align-items: center;\n  }\n  \n  .pl-quality-left {\n    padding-right: 24px;\n  }\n  \n  .pl-quality-right {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 100%;\n  }\n  \n  /* Image wrapper for responsive aspect ratio */\n  .pl-quality-img-wrapper {\n    width: 100%;\n    max-width: 560px;\n    aspect-ratio: 1;\n    overflow: hidden;\n    border-radius: 28px;\n    box-shadow: 0 20px 60px rgba(27,58,48,0.15);\n    transition: box-shadow 0.3s ease;\n  }\n  \n  .pl-quality-img-wrapper:hover {\n    box-shadow: 0 24px 72px rgba(27,58,48,0.2);\n  }\n  \n  .pl-quality-right img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform 0.3s ease;\n  }\n  \n  .pl-quality-img-wrapper:hover img {\n    transform: scale(1.02);\n  }\n  \n  /* kicker label */\n  .pl-quality-kicker {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    background: var(--pl-green-pale, #E8F5F3);\n    color: var(--pl-green, #1B5E56);\n    border-radius: 100px;\n    padding: 6px 18px;\n    font-family: var(--font-body-family, Inter, sans-serif);\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    margin-bottom: 28px;\n  }\n  \n  .pl-quality-kicker svg {\n    width: 14px;\n    height: 14px;\n  }\n  \n  /* Title */\n  .pl-quality-title {\n    font-family: var(--font-heading-family, \"Bodoni Moda\", serif);\n    font-size: 4.2rem;\n    font-weight: 600;\n    color: var(--pl-green-deep, #1B3A30);\n    line-height: 1.12;\n    letter-spacing: -0.03em;\n    margin: 0 0 24px;\n  }\n  \n  /* Subheading */\n  .pl-quality-sub {\n    font-family: var(--font-body-family, Inter, sans-serif);\n    font-size: 16px;\n    line-height: 1.8;\n    color: var(--pl-text-mid, #5A6B67);\n    margin: 0 0 48px;\n    max-width: 540px;\n  }\n  \n  /* 2x2 icon grid */\n  .pl-quality-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 32px 28px;\n    margin-bottom: 48px;\n  }\n  \n  .pl-quality-item {\n    display: flex;\n    align-items: flex-start;\n    gap: 16px;\n  }\n  \n  .pl-quality-icon {\n    flex-shrink: 0;\n    width: 52px;\n    height: 52px;\n    background: var(--pl-green-pale, #E8F5F3);\n    border-radius: 14px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--pl-green, #1B5E56);\n  }\n  \n  .pl-quality-icon svg {\n    width: 26px;\n    height: 26px;\n  }\n  \n  .pl-quality-item-text {\n    font-family: var(--font-body-family, Inter, sans-serif);\n    font-size: 15px;\n    line-height: 1.65;\n    color: var(--pl-text, #1B3A30);\n    font-weight: 500;\n    padding-top: 4px;\n  }\n  \n  /* CTA button */\n  .pl-quality-btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    background: var(--pl-amber, #D4821A);\n    color: #fff;\n    border-radius: var(--pl-radius-btn, 100px);\n    padding: 18px 44px;\n    font-family: var(--font-body-family, Inter, sans-serif);\n    font-size: 15px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    text-decoration: none;\n    transition: background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;\n    box-shadow: 0 6px 20px rgba(212,130,26,0.32);\n    border: none;\n    cursor: pointer;\n  }\n  \n  .pl-quality-btn:hover {\n    background: var(--pl-amber-hover, #BF7015);\n    transform: translateY(-3px);\n    box-shadow: 0 10px 32px rgba(212,130,26,0.4);\n    color: #fff;\n    text-decoration: none;\n  }\n  \n  /* \u2500\u2500 Tablet: 1024px and below \u2500\u2500 */\n  @media screen and (max-width: 1024px) {\n    .pl-quality-section {\n      padding: 80px 0;\n    }\n    .pl-quality-container {\n      padding: 0 40px;\n    }\n    .pl-quality-inner {\n      grid-template-columns: 1fr;\n      gap: 56px;\n    }\n    .pl-quality-left {\n      padding-right: 0;\n    }\n    .pl-quality-title {\n      font-size: 3.6rem;\n    }\n    .pl-quality-img-wrapper {\n      max-width: 100%;\n      aspect-ratio: 1;\n    }\n  }\n  \n  /* \u2500\u2500 Mobile: 768px and below \u2500\u2500 */\n  @media screen and (max-width: 768px) {\n    .pl-quality-section {\n      padding: 56px 0;\n    }\n    .pl-quality-container {\n      padding: 0 24px;\n    }\n    .pl-quality-inner {\n      gap: 40px;\n    }\n    .pl-quality-grid {\n      grid-template-columns: 1fr;\n      gap: 24px;\n    }\n    .pl-quality-title {\n      font-size: 2.8rem;\n    }\n    .pl-quality-sub {\n      font-size: 15px;\n      margin-bottom: 32px;\n    }\n    .pl-quality-img-wrapper {\n      max-width: 100%;\n      aspect-ratio: 1;\n    }\n  }\n  \n  /* \u2500\u2500 Small Mobile: 600px and below \u2500\u2500 */\n  @media screen and (max-width: 600px) {\n    .pl-quality-section {\n      padding: 48px 0;\n    }\n    .pl-quality-container {\n      padding: 0 18px;\n    }\n    .pl-quality-btn {\n      width: 100%;\n      justify-content: center;\n    }\n    .pl-quality-title {\n      font-size: 2.4rem;\n    }\n    .pl-quality-img-wrapper {\n      max-width: 100%;\n      aspect-ratio: 1;\n    }\n  }\n</style>\n\n<div class=\"pl-quality-container\">\n  <div class=\"pl-quality-inner\">\n    <div class=\"pl-quality-left\">\n      <div class=\"pl-quality-kicker\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2a10 10 0 0 1 10 10c0 7-10 12-10 12S2 19 2 12A10 10 0 0 1 12 2z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>\n        Idukki Highlands\n      </div>\n      <h2 class=\"pl-quality-title\">Deep Rooted in Idukki.</h2>\n      <p class=\"pl-quality-sub\">Our spices never sit in warehouses. They are handpicked from high-altitude estates and brought straight to your kitchen, preserving every note of aroma.</p>\n\n      <div class=\"pl-quality-grid\">\n        <div class=\"pl-quality-item\">\n          <div class=\"pl-quality-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>\n          </div>\n          <div class=\"pl-quality-item-text\">100% natural &amp; fresh \u2014 just how spices should be</div>\n        </div>\n        <div class=\"pl-quality-item\">\n          <div class=\"pl-quality-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z\"/><line x1=\"4\" y1=\"22\" x2=\"4\" y2=\"15\"/></svg>\n          </div>\n          <div class=\"pl-quality-item-text\">Proudly made in India \ud83c\uddee\ud83c\uddf3</div>\n        </div>\n        <div class=\"pl-quality-item\">\n          <div class=\"pl-quality-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/><polyline points=\"9 22 9 12 15 12 15 22\"/></svg>\n          </div>\n          <div class=\"pl-quality-item-text\">Direct from our farms \u2014 zero middlemen</div>\n        </div>\n        <div class=\"pl-quality-item\">\n          <div class=\"pl-quality-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n          </div>\n          <div class=\"pl-quality-item-text\">Chemical-free \u00b7 Polish-free \u00b7 Handpicked</div>\n        </div>\n      </div>\n\n      <a href=\"/collections/all\" class=\"pl-quality-btn\">\n        Explore All Spices\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>\n      </a>\n    </div>\n\n    <div class=\"pl-quality-right\">\n      <div class=\"pl-quality-img-wrapper\">\n        <img src=\"https://pureleven.com/cdn/shop/files/ca3.jpg\" alt=\"Fresh spices from Idukki farms\" loading=\"lazy\">\n      </div>\n    </div>\n  </div>\n</div>\n\n</div>",
