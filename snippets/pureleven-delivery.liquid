<style>
  .pureleven-delivery {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
    box-sizing: border-box;
  }

  .pureleven-delivery__shell {
    position: relative;
    display: grid;
    gap: 1.2rem;
    padding: clamp(1.6rem, 2vw, 2rem);
    border-radius: 2rem;
    border: 0.1rem solid rgba(27, 94, 86, 0.14);
    background: linear-gradient(135deg, #f8f3e9 0%, #eef7f3 56%, #f9fbf8 100%);
    box-shadow: 0 0.9rem 2.4rem rgba(27, 94, 86, 0.07);
    overflow: hidden;
  }

  .pureleven-delivery__shell::after {
    content: '';
    position: absolute;
    inset: auto -7rem -8rem auto;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(77, 155, 147, 0.14), rgba(77, 155, 147, 0));
    pointer-events: none;
  }

  .pureleven-delivery__top {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    gap: 0.9rem 1rem;
  }

  .pureleven-delivery__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 1.3rem;
    background: linear-gradient(135deg, #1b5e56, #4d9b93);
    color: #fff;
    box-shadow: 0 0.8rem 2rem rgba(27, 94, 86, 0.2);
    flex-shrink: 0;
  }

  .pureleven-delivery__icon svg {
    width: 2.2rem;
    height: 2.2rem;
  }

  .pureleven-delivery__copy {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    grid-column: 2;
  }

  .pureleven-delivery__eyebrow {
    margin: 0;
    font-family: var(--font-body-family, 'Inter', sans-serif);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(27, 58, 48, 0.64);
  }

  .pureleven-delivery__title {
    margin: 0;
    max-width: none;
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: clamp(1.85rem, 5.2vw, 2.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #1b3a30;
  }

  .pureleven-delivery__text {
    margin: 0;
    max-width: 72rem;
    font-family: var(--font-body-family, 'Inter', sans-serif);
    font-size: 1.26rem;
    line-height: 1.55;
    color: rgba(27, 58, 48, 0.8);
  }

  .pureleven-delivery__text strong {
    color: #1b3a30;
    font-weight: 700;
  }

  .pureleven-delivery__badge {
    display: none;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.6rem;
    padding: 0.7rem 1.15rem;
    border-radius: 999px;
    background: #1b5e56;
    color: #fff;
    font-family: var(--font-body-family, 'Inter', sans-serif);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 0.6rem 1.6rem rgba(27, 94, 86, 0.14);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pureleven-delivery__facts {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pureleven-delivery__fact {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    padding: 0.58rem 0.82rem;
    border-radius: 999px;
    border: 0.1rem solid rgba(27, 94, 86, 0.08);
    background: rgba(255, 255, 255, 0.74);
    backdrop-filter: blur(0.6rem);
  }

  .pureleven-delivery__fact svg {
    width: 1.55rem;
    height: 1.55rem;
    flex-shrink: 0;
    color: #1b5e56;
  }

  .pureleven-delivery__fact--rating svg {
    color: #d4881a;
    fill: #d4881a;
  }

  .pureleven-delivery__fact-text {
    font-family: var(--font-body-family, 'Inter', sans-serif);
    font-size: 1.14rem;
    line-height: 1.3;
    color: rgba(27, 58, 48, 0.78);
    white-space: nowrap;
  }

  .pureleven-delivery__fact-text strong {
    color: #1b3a30;
    font-weight: 700;
  }

  @media screen and (min-width: 900px) {
    .pureleven-delivery__shell {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      column-gap: 1.8rem;
      row-gap: 0.8rem;
    }

    .pureleven-delivery__top {
      display: flex;
      align-items: center;
      gap: 1.2rem;
    }

    .pureleven-delivery__copy {
      grid-column: auto;
      flex: 1;
    }

    .pureleven-delivery__title {
      font-size: 2.8rem;
    }

    .pureleven-delivery__text {
      font-size: 1.42rem;
    }

    .pureleven-delivery__badge {
      display: inline-flex;
    }

    .pureleven-delivery__facts {
      grid-column: 1 / -1;
      gap: 0.7rem;
    }

    .pureleven-delivery__fact {
      padding: 0.7rem 0.95rem;
    }

    .pureleven-delivery__fact-text {
      font-size: 1.24rem;
    }
  }

  @media screen and (max-width: 749px) {
    .pureleven-delivery {
      padding: 0 12px;
    }

    .pureleven-delivery__shell {
      padding: 1.4rem;
      gap: 1rem;
      border-radius: 1.8rem;
    }

    .pureleven-delivery__top {
      gap: 0.75rem 0.85rem;
    }

    .pureleven-delivery__icon {
      width: 4rem;
      height: 4rem;
      border-radius: 1.1rem;
    }

    .pureleven-delivery__icon svg {
      width: 1.8rem;
      height: 1.8rem;
    }

    .pureleven-delivery__title {
      font-size: 1.95rem;
    }

    .pureleven-delivery__text {
      font-size: 1.2rem;
    }

    .pureleven-delivery__facts {
      gap: 0.5rem;
    }

    .pureleven-delivery__fact {
      width: fit-content;
      max-width: 100%;
    }
  }

  @media screen and (max-width: 560px) {
    .pureleven-delivery__top {
      grid-template-columns: 3.6rem minmax(0, 1fr);
    }

    .pureleven-delivery__icon {
      width: 3.6rem;
      height: 3.6rem;
      border-radius: 1rem;
    }

    .pureleven-delivery__icon svg {
      width: 1.65rem;
      height: 1.65rem;
    }

    .pureleven-delivery__fact-text {
      white-space: normal;
    }
  }
</style>

<section class="pureleven-delivery" role="region" aria-label="Delivery and trust promise">
  <div class="pureleven-delivery__shell">
    <div class="pureleven-delivery__top">
      <div class="pureleven-delivery__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="3" width="15" height="13"></rect>
          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
          <circle cx="5.5" cy="18.5" r="2.5"></circle>
          <circle cx="18.5" cy="18.5" r="2.5"></circle>
        </svg>
      </div>

      <div class="pureleven-delivery__copy">
        <p class="pureleven-delivery__eyebrow">Quiet trust</p>
        <h2 class="pureleven-delivery__title">Small-batch packed from Kerala</h2>
        <p class="pureleven-delivery__text">
          Farm-origin ingredients with strong natural aroma, packed in smaller batches and shipped fresh across India.
        </p>
      </div>

      <div class="pureleven-delivery__badge">Free shipping ₹649+</div>
    </div>

    <ul class="pureleven-delivery__facts" role="list">
      <li class="pureleven-delivery__fact">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span class="pureleven-delivery__fact-text"><strong>Farm-origin</strong> ingredients</span>
      </li>
      <li class="pureleven-delivery__fact pureleven-delivery__fact--rating">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span class="pureleven-delivery__fact-text"><strong>Small-batch</strong> packed</span>
      </li>
      <li class="pureleven-delivery__fact">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="pureleven-delivery__fact-text"><strong>Strong</strong> natural aroma</span>
      </li>
      <li class="pureleven-delivery__fact">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        <span class="pureleven-delivery__fact-text"><strong>Shipped fresh</strong> across India</span>
      </li>
    </ul>
  </div>
</section>
