{%- comment -%}
  snippets/basil-cart-drawer.liquid
  Basil Commerce OS — Phase 1
  Smart cart slide-in drawer with reward tiers, upsells, and native checkout CTA.
  Opened/closed by basil-cart.js via data-basil-cart-open / data-basil-cart-close triggers.
{%- endcomment -%}

{%- liquid
  assign free_delivery_threshold_rupees = settings.basil_cart_free_delivery_threshold | default: 649 | plus: 0
  assign mid_threshold_rupees           = settings.basil_cart_mid_threshold           | default: 999 | plus: 0
  assign free_gift_threshold_rupees     = settings.basil_cart_gift_threshold          | default: 1449 | plus: 0
  assign mid_discount                   = settings.basil_cart_mid_discount            | default: 100 | plus: 0
  assign gift_discount                  = settings.basil_cart_gift_discount           | default: 200 | plus: 0
  assign free_delivery_threshold        = free_delivery_threshold_rupees | times: 100
  assign mid_threshold                  = mid_threshold_rupees | times: 100
  assign free_gift_threshold            = free_gift_threshold_rupees | times: 100
  assign cart_total                     = cart.total_price
  assign free_delivery_unlocked         = false
  assign mid_unlocked                   = false
  assign free_gift_unlocked             = false
  assign free_delivery_remaining        = free_delivery_threshold | minus: cart_total
  assign mid_remaining                  = mid_threshold | minus: cart_total
  assign free_gift_remaining            = free_gift_threshold | minus: cart_total
  if free_delivery_remaining < 0
    assign free_delivery_remaining = 0
  endif
  if mid_remaining < 0
    assign mid_remaining = 0
  endif
  if free_gift_remaining < 0
    assign free_gift_remaining = 0
  endif
  if cart_total >= free_delivery_threshold
    assign free_delivery_unlocked = true
  endif
  if cart_total >= mid_threshold
    assign mid_unlocked = true
  endif
  if cart_total >= free_gift_threshold
    assign free_gift_unlocked = true
  endif

  comment
    Reward progress bar — percentage toward next unlocked tier
  endcomment
  assign progress_percent = 0
  if free_gift_unlocked
    assign progress_percent = 100
  elsif mid_unlocked
    assign progress_percent = mid_threshold | minus: free_delivery_threshold | plus: 0
    assign progress_range   = free_gift_threshold | minus: mid_threshold | plus: 0
    assign progress_earned  = cart_total | minus: mid_threshold
    if progress_range > 0
      assign progress_percent = progress_earned | times: 100 | divided_by: progress_range | plus: 50
    endif
  elsif free_delivery_unlocked
    assign progress_percent = 50
  else
    if free_delivery_threshold > 0
      assign progress_percent = cart_total | times: 50 | divided_by: free_delivery_threshold
    endif
  endif
  if progress_percent > 100
    assign progress_percent = 100
  endif
-%}

{%- comment -%}── Overlay ──{%- endcomment -%}
<div id="basil-cart-overlay" aria-hidden="true" tabindex="-1"></div>

{%- comment -%}── Drawer panel ──{%- endcomment -%}
<div
  id="basil-cart-drawer"
  class="basil-cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  aria-hidden="true"
>
  {%- comment -%}── Header ──{%- endcomment -%}
  <div class="basil-drawer__header">
    <h2 class="basil-drawer__title">
      Your Cart
      {%- if cart.item_count > 0 -%}
        <span class="basil-drawer__count">({{ cart.item_count }})</span>
      {%- endif -%}
    </h2>
    <button
      class="basil-drawer__close"
      data-basil-cart-close
      aria-label="Close cart"
      type="button"
    >
      {% render 'icon-close' %}
    </button>
  </div>

  {%- if cart.item_count > 0 -%}

    {%- comment -%}── Reward Progress ──{%- endcomment -%}
    <div class="basil-drawer__rewards" aria-live="polite" aria-label="Reward progress">
      <div class="basil-reward-bar">
        <div
          class="basil-reward-bar__fill"
          style="width: {{ progress_percent }}%;"
          role="progressbar"
          aria-valuenow="{{ progress_percent }}"
          aria-valuemin="0"
          aria-valuemax="100"
        ></div>
      </div>

      <div class="basil-reward-bar__tiers">
        <span class="basil-reward-tier{% if free_delivery_unlocked %} is-unlocked{% endif %}">
          {%- if free_delivery_unlocked -%}
            ✅ Free delivery unlocked
          {%- else -%}
            🚚 {{ free_delivery_remaining | money_without_trailing_zeros }} for free delivery
          {%- endif -%}
        </span>
        {%- if mid_unlocked or cart_total >= free_delivery_threshold -%}
          <span class="basil-reward-tier{% if mid_unlocked %} is-unlocked{% endif %}">
            {%- if mid_unlocked -%}
              ✅ ₹{{ mid_discount }} OFF applied
            {%- else -%}
              ✨ {{ mid_remaining | money_without_trailing_zeros }} for ₹{{ mid_discount }} OFF
            {%- endif -%}
          </span>
        {%- endif -%}
        {%- if free_gift_unlocked or mid_unlocked -%}
          <span class="basil-reward-tier{% if free_gift_unlocked %} is-unlocked{% endif %}">
            {%- if free_gift_unlocked -%}
              🎁 ₹{{ gift_discount }} OFF applied
            {%- else -%}
              🎁 {{ free_gift_remaining | money_without_trailing_zeros }} for ₹{{ gift_discount }} OFF
            {%- endif -%}
          </span>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}── Cart items ──{%- endcomment -%}
    <div class="basil-drawer__items" role="list">
      {%- for item in cart.items -%}
        <div class="basil-drawer-item" role="listitem" data-key="{{ item.key }}">
          <a href="{{ item.url }}" class="basil-drawer-item__img-link" tabindex="-1">
            {%- if item.image -%}
              <img
                src="{{ item.image | image_url: width: 120 }}"
                alt="{{ item.image.alt | escape }}"
                width="60"
                height="60"
                loading="lazy"
                class="basil-drawer-item__img"
              >
            {%- else -%}
              <div class="basil-drawer-item__img-placeholder"></div>
            {%- endif -%}
          </a>
          <div class="basil-drawer-item__details">
            <a href="{{ item.url }}" class="basil-drawer-item__name">{{ item.product_title }}</a>
            {%- unless item.variant_title == 'Default Title' -%}
              <p class="basil-drawer-item__variant">{{ item.variant_title }}</p>
            {%- endunless -%}
            <p class="basil-drawer-item__price">
              {%- if item.original_price != item.final_price -%}
                <s>{{ item.original_price | money_without_trailing_zeros }}</s>
              {%- endif -%}
              {{ item.final_price | money_without_trailing_zeros }}
            </p>
          </div>
          <div class="basil-drawer-item__qty">
            <button
              class="basil-qty-btn"
              aria-label="Decrease quantity"
              data-basil-qty-change="{{ item.key }}"
              data-delta="-1"
              type="button"
            >−</button>
            <span class="basil-qty-display">{{ item.quantity }}</span>
            <button
              class="basil-qty-btn"
              aria-label="Increase quantity"
              data-basil-qty-change="{{ item.key }}"
              data-delta="1"
              type="button"
            >+</button>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%}── Footer ──{%- endcomment -%}
    <div class="basil-drawer__footer">
      <div class="basil-drawer__totals">
        <span class="basil-drawer__totals-label">Subtotal</span>
        <span class="basil-drawer__totals-value">{{ cart.total_price | money_without_trailing_zeros }}</span>
      </div>
      {%- if settings.basil_checkout_prep_enabled -%}
        {%- comment -%}Phase 2: route through address intelligence page{%- endcomment -%}
        <a
          href="/pages/checkout-prep"
          class="basil-checkout-btn button button--full-width button--primary"
          data-basil-cta="proceed-checkout"
        >
          <span class="basil-checkout-btn__icon">🔒</span>
          <span class="basil-checkout-btn__label">Proceed to Checkout</span>
        </a>
      {%- else -%}
        <button
          name="checkout"
          form="cart"
          class="basil-checkout-btn button button--full-width button--primary"
          data-basil-cta="proceed-checkout"
          type="submit"
        >
          <span class="basil-checkout-btn__icon">🔒</span>
          <span class="basil-checkout-btn__label">Proceed to Checkout</span>
        </button>
      {%- endif -%}
      <p class="basil-drawer__tax-note">
        {{- 'sections.cart.taxes_and_shipping_policy_html' | t: link: shop.privacy_policy.url -}}
      </p>
      <div class="basil-drawer__trust">
        <span>🔒 Secure</span>
        <span>⚡ Fast Delivery</span>
        <span>↩ Easy Returns</span>
      </div>
    </div>

  {%- else -%}
    <div class="basil-drawer__empty">
      <p>Your cart is empty.</p>
      <a href="/collections/all" class="button button--primary">Continue Shopping</a>
    </div>
  {%- endif -%}
</div>
