{% comment %} pl-phone-unlock.liquid — Pure Leven Cart {% endcomment %}

{% if settings.phone_coupon_enabled %}
<div class="pl-ph-card"
     data-code="{{ settings.phone_coupon_code | default: 'KERALA15' }}"
     data-discount="{{ settings.phone_coupon_discount | default: '15% off' }}"
     data-validity="{{ settings.phone_coupon_validity | default: '24 hours' }}">

  <div class="pl-ph-header">
    <p class="pl-ph-header-title">
      🔓 Unlock your exclusive {{ settings.phone_coupon_discount | default: '15% off' }} discount
    </p>
    <p class="pl-ph-header-sub">Enter your number — coupon appears instantly</p>
  </div>

  <div class="pl-ph-body">
    <div class="pl-ph-input-row">
      <div class="pl-ph-prefix" aria-hidden="true">+91</div>
      <input id="pl-ph-inp"
             class="pl-ph-inp"
             type="tel"
             inputmode="numeric"
             pattern="[0-9]*"
             autocomplete="tel-national"
             placeholder="10-digit mobile number"
             maxlength="10"
             aria-label="Mobile number">
      <button id="pl-ph-btn"
              class="pl-ph-btn"
              type="button"
              onclick="plRevealCoupon()">
        Reveal &rarr;
      </button>
    </div>

    <!-- Revealed coupon card -->
    <div class="pl-ph-revealed" id="pl-ph-revealed">
      <div class="pl-ph-code-row">
        <span class="pl-ph-code-txt" id="pl-ph-code-display">{{ settings.phone_coupon_code | default: 'KERALA15' }}</span>
        <button class="pl-ph-copy-btn"
                type="button"
                onclick="plCopyCode('{{ settings.phone_coupon_code | default: 'KERALA15' }}', 'pl-ph-code-display')"
                aria-label="Copy coupon code">
          Copy
        </button>
      </div>
      <p class="pl-ph-note">
        ✓ {{ settings.phone_coupon_discount | default: '15% off' }} your entire order
        · Valid for {{ settings.phone_coupon_validity | default: '24 hours' }}
      </p>
    </div>
  </div>

</div>
{% endif %}
