{%- assign faq_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.settings.question != blank and block.settings.answer != blank -%}
    {%- assign faq_count = faq_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- capture fallback_faq_items -%}
  {% render 'product-seo-faq-content', product_handle: product.handle, mode: 'items', open_first_item: section.settings.open_first_item %}
{%- endcapture -%}
{%- capture fallback_faq_schema -%}
  {% render 'product-seo-faq-content', product_handle: product.handle, mode: 'schema' %}
{%- endcapture -%}
{%- assign faq_metaobject = product.metafields.custom.product_faq_entry.value -%}
{%- assign faq_metafield = product.metafields.custom.product_faq.value -%}
{%- assign faq_eyebrow = section.settings.eyebrow -%}
{%- assign faq_heading = section.settings.heading -%}
{%- assign faq_intro = section.settings.intro -%}
{%- assign faq_item_1_question = '' -%}
{%- assign faq_item_1_answer = '' -%}
{%- assign faq_item_2_question = '' -%}
{%- assign faq_item_2_answer = '' -%}
{%- assign faq_item_3_question = '' -%}
{%- assign faq_item_3_answer = '' -%}
{%- assign faq_item_4_question = '' -%}
{%- assign faq_item_4_answer = '' -%}
{%- if faq_metaobject != blank -%}
  {%- assign faq_metaobject_heading = faq_metaobject.heading.value | default: faq_metaobject.heading -%}
  {%- if faq_metaobject_heading != blank -%}
    {%- assign faq_heading = faq_metaobject_heading -%}
    {%- assign faq_eyebrow = faq_metaobject.eyebrow.value | default: faq_metaobject.eyebrow | default: faq_eyebrow -%}
    {%- assign faq_intro_value = faq_metaobject.intro.value | default: faq_metaobject.intro -%}
    {%- if faq_intro_value != blank -%}
      {%- capture faq_intro -%}<p>{{ faq_intro_value }}</p>{%- endcapture -%}
    {%- endif -%}
    {%- assign faq_item_1_question = faq_metaobject.item_1_question.value | default: faq_metaobject.item_1_question -%}
    {%- assign faq_item_1_answer = faq_metaobject.item_1_answer.value | default: faq_metaobject.item_1_answer -%}
    {%- assign faq_item_2_question = faq_metaobject.item_2_question.value | default: faq_metaobject.item_2_question -%}
    {%- assign faq_item_2_answer = faq_metaobject.item_2_answer.value | default: faq_metaobject.item_2_answer -%}
    {%- assign faq_item_3_question = faq_metaobject.item_3_question.value | default: faq_metaobject.item_3_question -%}
    {%- assign faq_item_3_answer = faq_metaobject.item_3_answer.value | default: faq_metaobject.item_3_answer -%}
    {%- assign faq_item_4_question = faq_metaobject.item_4_question.value | default: faq_metaobject.item_4_question -%}
    {%- assign faq_item_4_answer = faq_metaobject.item_4_answer.value | default: faq_metaobject.item_4_answer -%}
  {%- endif -%}
{%- endif -%}
{%- capture metaobject_faq_items -%}
  {%- if faq_item_1_question != blank and faq_item_1_answer != blank -%}
    <details class="product-faq__item" {% if section.settings.open_first_item %}open{% endif %}>
      <summary class="product-faq__question">
        <span class="product-faq__question-text">{{ faq_item_1_question }}</span>
        <span class="product-faq__icon">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="product-faq__answer rte"><p>{{ faq_item_1_answer }}</p></div>
    </details>
  {%- endif -%}
  {%- if faq_item_2_question != blank and faq_item_2_answer != blank -%}
    <details class="product-faq__item">
      <summary class="product-faq__question">
        <span class="product-faq__question-text">{{ faq_item_2_question }}</span>
        <span class="product-faq__icon">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="product-faq__answer rte"><p>{{ faq_item_2_answer }}</p></div>
    </details>
  {%- endif -%}
  {%- if faq_item_3_question != blank and faq_item_3_answer != blank -%}
    <details class="product-faq__item">
      <summary class="product-faq__question">
        <span class="product-faq__question-text">{{ faq_item_3_question }}</span>
        <span class="product-faq__icon">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="product-faq__answer rte"><p>{{ faq_item_3_answer }}</p></div>
    </details>
  {%- endif -%}
  {%- if faq_item_4_question != blank and faq_item_4_answer != blank -%}
    <details class="product-faq__item">
      <summary class="product-faq__question">
        <span class="product-faq__question-text">{{ faq_item_4_question }}</span>
        <span class="product-faq__icon">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="product-faq__answer rte"><p>{{ faq_item_4_answer }}</p></div>
    </details>
  {%- endif -%}
{%- endcapture -%}
{%- capture metaobject_faq_schema -%}
  {%- assign rendered_metaobject_faq = 0 -%}
  {%- if faq_item_1_question != blank and faq_item_1_answer != blank -%}
    {
      "@type": "Question",
      "name": {{ faq_item_1_question | strip | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_item_1_answer | strip | json }}
      }
    }
    {%- assign rendered_metaobject_faq = rendered_metaobject_faq | plus: 1 -%}
  {%- endif -%}
  {%- if faq_item_2_question != blank and faq_item_2_answer != blank -%}
    {%- if rendered_metaobject_faq > 0 -%},{%- endif -%}
    {
      "@type": "Question",
      "name": {{ faq_item_2_question | strip | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_item_2_answer | strip | json }}
      }
    }
    {%- assign rendered_metaobject_faq = rendered_metaobject_faq | plus: 1 -%}
  {%- endif -%}
  {%- if faq_item_3_question != blank and faq_item_3_answer != blank -%}
    {%- if rendered_metaobject_faq > 0 -%},{%- endif -%}
    {
      "@type": "Question",
      "name": {{ faq_item_3_question | strip | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_item_3_answer | strip | json }}
      }
    }
    {%- assign rendered_metaobject_faq = rendered_metaobject_faq | plus: 1 -%}
  {%- endif -%}
  {%- if faq_item_4_question != blank and faq_item_4_answer != blank -%}
    {%- if rendered_metaobject_faq > 0 -%},{%- endif -%}
    {
      "@type": "Question",
      "name": {{ faq_item_4_question | strip | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_item_4_answer | strip | json }}
      }
    }
  {%- endif -%}
{%- endcapture -%}
{%- capture metafield_faq_items -%}
  {%- if faq_metafield != blank and faq_metafield.items != blank -%}
    {%- for item in faq_metafield.items -%}
      {%- if item.question != blank and item.answer != blank -%}
        <details class="product-faq__item" {% if section.settings.open_first_item and forloop.first %}open{% endif %}>
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ item.question }}</span>
            <span class="product-faq__icon">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </summary>
          <div class="product-faq__answer rte"><p>{{ item.answer }}</p></div>
        </details>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}
{%- capture metafield_faq_schema -%}
  {%- if faq_metafield != blank and faq_metafield.items != blank -%}
    {%- assign rendered_metafield_faq = 0 -%}
    {%- for item in faq_metafield.items -%}
      {%- if item.question != blank and item.answer != blank -%}
        {%- if rendered_metafield_faq > 0 -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ item.question | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ item.answer | strip | json }}
          }
        }
        {%- assign rendered_metafield_faq = rendered_metafield_faq | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}
{%- if faq_metaobject == blank and faq_metafield != blank -%}
  {%- if faq_metafield.eyebrow != blank -%}
    {%- assign faq_eyebrow = faq_metafield.eyebrow -%}
  {%- endif -%}
  {%- if faq_metafield.heading != blank -%}
    {%- assign faq_heading = faq_metafield.heading -%}
  {%- endif -%}
  {%- if faq_metafield.intro != blank -%}
    {%- capture faq_intro -%}<p>{{ faq_metafield.intro }}</p>{%- endcapture -%}
  {%- endif -%}
{%- endif -%}
{%- assign has_metafield_faq = false -%}
{%- if metafield_faq_items != blank -%}
  {%- assign has_metafield_faq = true -%}
{%- endif -%}
{%- assign has_metaobject_faq = false -%}
{%- if metaobject_faq_items != blank -%}
  {%- assign has_metaobject_faq = true -%}
{%- endif -%}
{%- assign has_fallback_faq = false -%}
{%- if fallback_faq_items != blank -%}
  {%- assign has_fallback_faq = true -%}
{%- endif -%}

{%- if faq_count > 0 or has_metaobject_faq or has_metafield_faq or has_fallback_faq or request.design_mode -%}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .product-faq-{{ section.id }} .product-faq__header {
      max-width: 84rem;
      margin: 0 auto 3.2rem;
      text-align: left;
    }

    .product-faq-{{ section.id }} .product-faq__eyebrow {
      margin: 0 0 1rem;
      color: #8F5A12;
      opacity: 0.72;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .product-faq-{{ section.id }} .product-faq__heading {
      margin: 0;
      max-width: 18ch;
      line-height: 1.04;
      letter-spacing: 0;
    }

    .product-faq-{{ section.id }} .product-faq__intro {
      max-width: 66rem;
      margin: 1.2rem auto 0;
      color: rgba(var(--color-foreground), 0.75);
      font-size: 1.6rem;
      line-height: 1.75;
    }

    .product-faq-{{ section.id }} .product-faq__list {
      max-width: 86rem;
      margin: 0 auto;
      border: 0.1rem solid rgba(var(--color-foreground), 0.08);
      border-radius: 2.6rem;
      background: linear-gradient(180deg, rgba(var(--color-foreground), 0.025), rgba(var(--color-foreground), 0.01));
      overflow: hidden;
      box-shadow: 0 2.2rem 6rem rgba(27, 58, 48, 0.06);
    }

    .product-faq-{{ section.id }} .product-faq__item + .product-faq__item {
      border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
    }

    .product-faq-{{ section.id }} .product-faq__question {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.6rem;
      width: 100%;
      padding: 2.1rem 2.4rem;
      cursor: pointer;
      list-style: none;
    }

    .product-faq-{{ section.id }} .product-faq__question::-webkit-details-marker {
      display: none;
    }

    .product-faq-{{ section.id }} .product-faq__question-text {
      font-size: 1.7rem;
      font-weight: 600;
      line-height: 1.45;
      color: rgb(var(--color-foreground));
    }

    .product-faq-{{ section.id }} .product-faq__icon {
      flex: 0 0 auto;
      position: relative;
      width: 3rem;
      height: 3rem;
      border-radius: 999px;
      border: 0.1rem solid rgba(var(--color-foreground), 0.12);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: rgb(var(--color-foreground));
      background: rgba(255, 255, 255, 0.7);
    }

    .product-faq-{{ section.id }} .product-faq__icon svg {
      display: none;
    }

    .product-faq-{{ section.id }} .product-faq__icon::before,
    .product-faq-{{ section.id }} .product-faq__icon::after {
      content: '';
      position: absolute;
      width: 1.1rem;
      height: 0.15rem;
      border-radius: 999px;
      background: currentColor;
      transition: opacity var(--duration-default) ease, transform var(--duration-default) ease;
    }

    .product-faq-{{ section.id }} .product-faq__icon::after {
      transform: rotate(90deg);
    }

    .product-faq-{{ section.id }} details[open] .product-faq__icon::after {
      opacity: 0;
      transform: rotate(90deg) scaleX(0.2);
    }

    .product-faq-{{ section.id }} .product-faq__answer {
      padding: 0 2.4rem 2.4rem;
    }

    .product-faq-{{ section.id }} .product-faq__answer > *:first-child {
      margin-top: 0;
    }

    .product-faq-{{ section.id }} .product-faq__answer > *:last-child {
      margin-bottom: 0;
    }

    .product-faq-{{ section.id }} .product-faq__placeholder {
      max-width: 86rem;
      margin: 0 auto;
      padding: 2rem 2.4rem;
      border: 0.1rem dashed rgba(var(--color-foreground), 0.2);
      border-radius: 1.6rem;
      color: rgba(var(--color-foreground), 0.7);
      background: rgba(var(--color-foreground), 0.02);
    }

    @media screen and (max-width: 749px) {
      .product-faq-{{ section.id }} .product-faq__header {
        margin-bottom: 1.8rem;
      }

      .product-faq-{{ section.id }} .product-faq__list {
        border-radius: 1.4rem;
        box-shadow: none;
      }

      .product-faq-{{ section.id }} .product-faq__question {
        gap: 1.2rem;
        padding: 1.5rem 1.4rem;
      }

      .product-faq-{{ section.id }} .product-faq__question-text {
        font-size: 1.45rem;
      }

      .product-faq-{{ section.id }} .product-faq__icon {
        width: 2.6rem;
        height: 2.6rem;
      }

      .product-faq-{{ section.id }} .product-faq__answer {
        padding: 0 1.4rem 1.6rem;
      }
    }
  {%- endstyle -%}

  <div class="color-{{ section.settings.color_scheme }} gradient product-faq-{{ section.id }}">
    <section class="page-width section-{{ section.id }}-padding" aria-labelledby="ProductFaq-{{ section.id }}">
      <div class="product-faq__header">
        {% render 'product-seo-section-header',
          mode: 'faq',
          product_handle: product.handle,
          custom_eyebrow: faq_eyebrow,
          custom_heading: faq_heading,
          custom_intro: faq_intro,
          class_prefix: 'product-faq',
          heading_id: 'ProductFaq-' | append: section.id,
          heading_size: section.settings.heading_size
        %}
      </div>

      {%- if has_metaobject_faq -%}
        <div class="product-faq__list">
          {{ metaobject_faq_items }}
        </div>

        <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {{ metaobject_faq_schema }}
            ]
          }
        </script>
      {%- elsif has_metafield_faq -%}
        <div class="product-faq__list">
          {{ metafield_faq_items }}
        </div>

        <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {{ metafield_faq_schema }}
            ]
          }
        </script>
      {%- elsif faq_count > 0 -%}
        <div class="product-faq__list">
          {%- assign faq_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.question != blank and block.settings.answer != blank -%}
              {%- assign faq_index = faq_index | plus: 1 -%}
              <details class="product-faq__item" {% if section.settings.open_first_item and faq_index == 1 %}open{% endif %} {{ block.shopify_attributes }}>
                <summary class="product-faq__question">
                  <span class="product-faq__question-text">{{ block.settings.question | escape }}</span>
                  <span class="product-faq__icon">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </summary>
                <div class="product-faq__answer rte">
                  {{ block.settings.answer }}
                </div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {%- assign rendered_faq = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.settings.question != blank and block.settings.answer != blank -%}
                  {%- if rendered_faq > 0 -%},{%- endif -%}
                  {
                    "@type": "Question",
                    "name": {{ block.settings.question | strip | json }},
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": {{ block.settings.answer | strip_html | strip_newlines | replace: '  ', ' ' | strip | json }}
                    }
                  }
                  {%- assign rendered_faq = rendered_faq | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            ]
          }
        </script>
      {%- elsif has_fallback_faq -%}
        <div class="product-faq__list">
          {{ fallback_faq_items }}
        </div>

        <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {{ fallback_faq_schema }}
            ]
          }
        </script>
      {%- elsif request.design_mode -%}
        <div class="product-faq__placeholder">
          Add FAQ blocks here to render on product pages and output FAQPage schema for search engines and AI answer engines.
        </div>
      {%- endif -%}
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Questions answered"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Product FAQs"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h0",
          "label": "H0"
        },
        {
          "value": "hxl",
          "label": "HXL"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "open_first_item",
      "label": "Open first FAQ by default",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What makes this product different?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Use this answer to add direct, specific product information for shoppers, search engines, and AI assistants.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ"
    }
  ]
}
{% endschema %}