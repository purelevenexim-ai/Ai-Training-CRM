    {%- liquid
      assign resolved_page_title = page_title
      assign resolved_page_description = page_description
      assign should_noindex = false
        assign append_shop_name = true

        if request.page_type == 'index'
          assign append_shop_name = false

          if shop.metafields.global.homepage_title_tag != blank
            assign resolved_page_title = shop.metafields.global.homepage_title_tag
          else
            assign resolved_page_title = 'Fresh Kerala Spices Online | Farm-Origin Natural Foods - Pureleven'
          endif

          if shop.metafields.global.homepage_description_tag != blank
            assign resolved_page_description = shop.metafields.global.homepage_description_tag
          else
            assign resolved_page_description = 'Shop fresh Kerala spices, raw honey, tea, coffee, and natural foods sourced directly from small family farms in Kerala hill regions for authentic aroma and flavor.'
          endif
        elsif request.page_type == 'product'
        if product.metafields.global.title_tag != blank
          assign resolved_page_title = product.metafields.global.title_tag
        endif

        if product.metafields.global.description_tag != blank
          assign resolved_page_description = product.metafields.global.description_tag
        endif
      elsif request.page_type == 'article'
        if article.metafields.global.title_tag != blank
          assign resolved_page_title = article.metafields.global.title_tag
        endif

        if article.metafields.global.description_tag != blank
          assign resolved_page_description = article.metafields.global.description_tag
        elsif article.excerpt != blank
          assign resolved_page_description = article.excerpt | strip_html | strip_newlines | replace: '  ', ' ' | strip
        elsif article.content != blank
          assign resolved_page_description = article.content | strip_html | strip_newlines | replace: '  ', ' ' | strip | truncatewords: 28
        endif
      elsif request.page_type == 'blog'
        if blog.metafields.global.title_tag != blank
          assign resolved_page_title = blog.metafields.global.title_tag
        endif

        if blog.metafields.global.description_tag != blank
          assign resolved_page_description = blog.metafields.global.description_tag
        endif

        if resolved_page_description == blank
          case blog.handle
            when 'cooking-spices'
              assign resolved_page_description = 'Guides on Kerala spices, flavor, storage, sourcing, buying decisions, and practical kitchen use from Organic Pure Leven.'
            when 'honey'
              assign resolved_page_description = 'Guides on honey purity, sourcing, flavor, comparisons, and everyday use from Organic Pure Leven.'
            when 'herbs'
              assign resolved_page_description = 'Practical herb guides covering flavor, benefits, storage, and kitchen use from Organic Pure Leven.'
            else
              assign resolved_page_description = 'Articles, ingredient guides, and buying help from Organic Pure Leven.'
          endcase
        endif

        if blog.articles_count == 0
          assign should_noindex = true
        endif
      endif

      if append_shop_name and resolved_page_title contains shop.name
        assign append_shop_name = false
      endif
    -%}

