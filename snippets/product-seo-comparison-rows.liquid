{%- assign comparison_group = '' -%}
{%- assign pack_label = '' -%}
{%- assign pack_fit = '' -%}
{%- assign combo_contents = '' -%}
{%- assign combo_fit = '' -%}

{%- case product_handle -%}
  {%- when 'kerala-cardamom-online-100gm' -%}
    {%- assign comparison_group = 'cardamom' -%}
    {%- assign pack_label = '200gm refill pack for frequent cardamom use' -%}
    {%- assign pack_fit = 'better for households that use cardamom more often' -%}
  {%- when 'kerala-cardamom-200gm' -%}
    {%- assign comparison_group = 'cardamom' -%}
    {%- assign pack_label = '100gm pack for daily home use or first purchase' -%}
    {%- assign pack_fit = 'better for smaller kitchens or lighter monthly usage' -%}
  {%- when 'kerala-black-pepper-200gm' -%}
    {%- assign comparison_group = 'black_pepper' -%}
    {%- assign pack_label = '200gm whole-pepper pack' -%}
    {%- assign pack_fit = 'daily home seasoning and grinder refills' -%}
  {%- when 'kerala-black-pepper-350gm' -%}
    {%- assign comparison_group = 'black_pepper' -%}
    {%- assign pack_label = 'larger value pack for kitchen refills' -%}
    {%- assign pack_fit = 'families and frequent cooks who need more volume' -%}
  {%- when 'kerala-clove-100gm' -%}
    {%- assign comparison_group = 'clove' -%}
    {%- assign pack_label = '100gm pack for occasional or moderate use' -%}
    {%- assign pack_fit = 'chai, biryani, and masala use in smaller kitchens' -%}
  {%- when 'kerala-clove-200gm' -%}
    {%- assign comparison_group = 'clove' -%}
    {%- assign pack_label = '200gm refill pack for regular cooking' -%}
    {%- assign pack_fit = 'larger households and repeat clove use' -%}
  {%- when 'kerala-white-pepper' -%}
    {%- assign comparison_group = 'white_pepper' -%}
  {%- when 'cardamom-pepper-clove-combo-pack-special-offer-100-off' -%}
    {%- assign comparison_group = 'combo' -%}
    {%- assign combo_contents = 'Cardamom 50g, Black Pepper 100g, and Clove 100g' -%}
    {%- assign combo_fit = 'gifting and starter kitchen use' -%}
  {%- when 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack-copy' -%}
    {%- assign comparison_group = 'combo' -%}
    {%- assign combo_contents = 'Cardamom 100g, Black Pepper 200g, and Clove 100g' -%}
    {%- assign combo_fit = 'families and more frequent kitchen refills' -%}
  {%- when 'premium-cassia-cinnamon-100g' -%}
    {%- assign comparison_group = 'cassia' -%}
  {%- when 'aromatic-true-cinnamon-ceylon-100g' -%}
    {%- assign comparison_group = 'ceylon' -%}
{%- endcase -%}

{%- case comparison_group -%}
  {%- when 'cardamom' -%}
    <tr>
      <td class="product-comparison__attribute">Source</td>
      <td class="product-comparison__pureleven"><p>Kerala cardamom positioned around Munnar high-range sourcing.</p></td>
      <td class="product-comparison__market"><p>Mixed origin or limited source clarity.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Grade visibility</td>
      <td class="product-comparison__pureleven"><p>8mm whole pods highlighted as the key quality marker.</p></td>
      <td class="product-comparison__market"><p>Pod size and grading are often unclear.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Freshness format</td>
      <td class="product-comparison__pureleven"><p>Whole pods packed to protect aroma until use.</p></td>
      <td class="product-comparison__market"><p>Commodity stock may sit longer before retail sale.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Best fit</td>
      <td class="product-comparison__pureleven"><p>{{ pack_label }} and {{ pack_fit }}.</p></td>
      <td class="product-comparison__market"><p>One-size-fits-all packs with weaker buying guidance.</p></td>
    </tr>
  {%- when 'black_pepper' -%}
    <tr>
      <td class="product-comparison__attribute">Format</td>
      <td class="product-comparison__pureleven"><p>Whole peppercorns intended for fresh grinding and better aroma retention.</p></td>
      <td class="product-comparison__market"><p>Often sold pre-ground or with less emphasis on freshness.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Source</td>
      <td class="product-comparison__pureleven"><p>Kerala black pepper positioned as a farm-linked regional product.</p></td>
      <td class="product-comparison__market"><p>Source region may be broad, blended, or unclear.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Aroma life</td>
      <td class="product-comparison__pureleven"><p>Whole format helps the pepper stay punchier until ground.</p></td>
      <td class="product-comparison__market"><p>Ground pepper loses aroma and heat faster after opening.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Best fit</td>
      <td class="product-comparison__pureleven"><p>{{ pack_label }} built for {{ pack_fit }}.</p></td>
      <td class="product-comparison__market"><p>Less guidance on whether the pack fits daily or bulk use.</p></td>
    </tr>
  {%- when 'clove' -%}
    <tr>
      <td class="product-comparison__attribute">Source</td>
      <td class="product-comparison__pureleven"><p>Kerala clove product positioned around Adimali and spice-farm sourcing.</p></td>
      <td class="product-comparison__market"><p>Source often remains vague or mixed.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Format</td>
      <td class="product-comparison__pureleven"><p>Whole clove buds for visible quality and broader kitchen use.</p></td>
      <td class="product-comparison__market"><p>Breakage or lower visual consistency is more common.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Aroma focus</td>
      <td class="product-comparison__pureleven"><p>Marketed around strong aroma and everyday culinary utility.</p></td>
      <td class="product-comparison__market"><p>Less clarity on freshness and aromatic strength.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Best fit</td>
      <td class="product-comparison__pureleven"><p>{{ pack_label }} for {{ pack_fit }}.</p></td>
      <td class="product-comparison__market"><p>Generic clove packs rarely explain who the size is meant for.</p></td>
    </tr>
  {%- when 'white_pepper' -%}
    <tr>
      <td class="product-comparison__attribute">Flavor profile</td>
      <td class="product-comparison__pureleven"><p>Smoother heat and a more earthy finish than black pepper.</p></td>
      <td class="product-comparison__market"><p>White pepper listings often stay generic and underspecified.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Best dishes</td>
      <td class="product-comparison__pureleven"><p>Soups, sauces, marinades, noodles, and lighter-colored dishes.</p></td>
      <td class="product-comparison__market"><p>Usually described as a general spice without culinary guidance.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Format</td>
      <td class="product-comparison__pureleven"><p>Presented as a premium whole-spice ingredient.</p></td>
      <td class="product-comparison__market"><p>May not clarify whether the pepper is whole or already ground.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Origin story</td>
      <td class="product-comparison__pureleven"><p>Kerala and Western Ghats positioning adds regional context.</p></td>
      <td class="product-comparison__market"><p>Minimal provenance detail.</p></td>
    </tr>
  {%- when 'combo' -%}
    <tr>
      <td class="product-comparison__attribute">Included products</td>
      <td class="product-comparison__pureleven"><p>{{ combo_contents }} in one bundled purchase.</p></td>
      <td class="product-comparison__market"><p>Bundles often focus on price more than source or use clarity.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Buying convenience</td>
      <td class="product-comparison__pureleven"><p>Three core kitchen spices selected together for one-cart simplicity.</p></td>
      <td class="product-comparison__market"><p>Shoppers may still need to compare multiple separate listings.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Use case</td>
      <td class="product-comparison__pureleven"><p>Built for {{ combo_fit }}.</p></td>
      <td class="product-comparison__market"><p>Less clarity on whether the bundle suits gifting, trial, or kitchen refill use.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Regional identity</td>
      <td class="product-comparison__pureleven"><p>Presented as a Kerala spice combo rather than a generic kitchen bundle.</p></td>
      <td class="product-comparison__market"><p>Regional positioning is often weak or missing.</p></td>
    </tr>
  {%- when 'cassia' -%}
    <tr>
      <td class="product-comparison__attribute">Flavor intensity</td>
      <td class="product-comparison__pureleven"><p>Bold, warm cinnamon profile suited to stronger flavor applications.</p></td>
      <td class="product-comparison__market"><p>Generic cinnamon listings often do not distinguish flavor strength.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Best uses</td>
      <td class="product-comparison__pureleven"><p>Chai, baking, breakfast recipes, and savory spice blends.</p></td>
      <td class="product-comparison__market"><p>Broad all-purpose claims with less recipe guidance.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Cinnamon type</td>
      <td class="product-comparison__pureleven"><p>Clearly positioned as cassia cinnamon.</p></td>
      <td class="product-comparison__market"><p>Cinnamon type may be unlabeled or unclear.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Aroma positioning</td>
      <td class="product-comparison__pureleven"><p>Sold around a bold and warm spice identity.</p></td>
      <td class="product-comparison__market"><p>Less distinction between delicate and strong cinnamon styles.</p></td>
    </tr>
  {%- when 'ceylon' -%}
    <tr>
      <td class="product-comparison__attribute">Cinnamon identity</td>
      <td class="product-comparison__pureleven"><p>Clearly positioned as True Ceylon cinnamon.</p></td>
      <td class="product-comparison__market"><p>Many listings do not make the cinnamon type obvious.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Flavor profile</td>
      <td class="product-comparison__pureleven"><p>Lighter, sweeter, and more delicate than cassia.</p></td>
      <td class="product-comparison__market"><p>Generic cinnamon descriptions often flatten these differences.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Best uses</td>
      <td class="product-comparison__pureleven"><p>Tea, desserts, fruit-based recipes, and refined baking.</p></td>
      <td class="product-comparison__market"><p>Less direction on when a softer cinnamon profile is preferable.</p></td>
    </tr>
    <tr>
      <td class="product-comparison__attribute">Buying clarity</td>
      <td class="product-comparison__pureleven"><p>Helps shoppers choose between Ceylon and cassia use cases more clearly.</p></td>
      <td class="product-comparison__market"><p>Shoppers often need to infer differences on their own.</p></td>
    </tr>
{%- endcase -%}