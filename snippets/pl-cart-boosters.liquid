{% comment %} pl-cart-boosters.liquid — Smart recommendations, cart-excluded, 10% off {% endcomment %}

{%- assign topup_coll      = collections[settings.topup_collection] -%}
{%- assign ship_threshold  = settings.free_shipping_threshold | default: 649 -%}
{%- assign ship_paise      = ship_threshold | times: 100 -%}
{%- assign ship_gap_r      = ship_paise | minus: cart.total_price | divided_by: 100 -%}

{%- comment -%} Cart exclusion list {%- endcomment -%}
{%- assign cart_pid_list = '' -%}
{%- for item in cart.items -%}
  {%- capture pid_str -%}|{{ item.product_id }}{%- endcapture -%}
  {%- assign cart_pid_list = cart_pid_list | append: pid_str -%}
{%- endfor -%}

{%- comment -%} Pre-pass: count eligibles + accumulate savings + capture variant IDs {%- endcomment -%}
{%- assign rec_count   = 0 -%}
{%- assign rec_save_p  = 0 -%}
{%- assign rec_v1      = '' -%}
{%- assign rec_v2      = '' -%}
{%- if topup_coll != blank and topup_coll.products.size > 0 -%}
  {%- for p in topup_coll.products limit: 20 -%}
    {%- if rec_count >= 2 -%}{%- break -%}{%- endif -%}
    {%- assign pid_str = p.id | prepend: '|' -%}
    {%- unless cart_pid_list contains pid_str -%}
      {%- assign v = p.variants.first -%}
      {%- assign item_save_p = v.price | times: 10 | divided_by: 100 -%}
      {%- assign rec_save_p  = rec_save_p | plus: item_save_p -%}
      {%- if rec_count == 0 -%}{%- assign rec_v1 = v.id -%}{%- endif -%}
      {%- if rec_count == 1 -%}{%- assign rec_v2 = v.id -%}{%- endif -%}
      {%- assign rec_count = rec_count | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}
{%- assign rec_save_r = rec_save_p | divided_by: 100 -%}

{% if rec_count > 0 %}
<section class="pl-rec-section" id="pl-rec-section" aria-label="Recommended add-ons">

  <div class="pl-rec-header">
    <div class="pl-rec-header-copy">
      <p class="pl-rec-kicker">RECOMMENDED ADD-ONS</p>
      <p class="pl-rec-title">Popular with this order</p>
    </div>
    {% if rec_save_r > 0 %}
    <div class="pl-rec-save-total">
      <span class="pl-rec-save-label">You&nbsp;save</span>
      <span class="pl-rec-save-amount">&#8377;{{ rec_save_r }}</span>
    </div>
    {% endif %}
  </div>

  {% if cart.total_price < ship_paise %}
  <div class="pl-rec-ship-note">
    &#128666; Add <strong>&#8377;{{ ship_gap_r }} more</strong> to unlock FREE delivery
  </div>
  {% endif %}

  <div class="pl-rec-list">
    {%- assign shown = 0 -%}
    {%- for p in topup_coll.products limit: 20 -%}
      {%- if shown >= 2 -%}{%- break -%}{%- endif -%}
      {%- assign pid_str = p.id | prepend: '|' -%}
      {%- unless cart_pid_list contains pid_str -%}
        {%- assign shown   = shown | plus: 1 -%}
        {%- assign v       = p.variants.first -%}
        {%- assign orig_r  = v.price | divided_by: 100 -%}
        {%- assign disc_p  = v.price | times: 90 | divided_by: 100 -%}
        {%- assign disc_r  = disc_p | divided_by: 100 -%}
        {%- assign save_p  = v.price | times: 10 | divided_by: 100 -%}
        {%- assign save_r  = save_p | divided_by: 100 -%}
        <div class="pl-rec-card" data-variant="{{ v.id }}">
          <a href="{{ p.url }}" class="pl-rec-img-wrap" tabindex="-1" aria-hidden="true">
            {% if p.featured_image %}
              <img class="pl-rec-img"
                   src="{{ p.featured_image | image_url: width: 160 }}"
                   alt="{{ p.title | escape }}"
                   width="72" height="72"
                   loading="lazy">
            {% else %}
              <div class="pl-rec-img-ph" aria-hidden="true">&#127807;</div>
            {% endif %}
          </a>
          <div class="pl-rec-info">
            <p class="pl-rec-name">{{ p.title | escape | truncate: 45 }}</p>
            <div class="pl-rec-price-row">
              <span class="pl-rec-price">&#8377;{{ disc_r }}</span>
              <span class="pl-rec-was">&#8377;{{ orig_r }}</span>
            </div>
            <span class="pl-rec-save-chip">&#10004; Save &#8377;{{ save_r }}</span>
          </div>
          <button class="pl-rec-add"
             type="button"
             data-variant="{{ v.id }}"
             aria-label="Add {{ p.title | escape }} to cart at 10% off"
             onclick="plAddUpsell(this)">
            +&nbsp;Add
          </button>
        </div>
      {%- endunless -%}
    {%- endfor -%}
  </div>

  {% if rec_count >= 2 %}
  <div class="pl-rec-footer">
    <button class="pl-rec-add-both"
            type="button"
            data-v1="{{ rec_v1 }}"
            data-v2="{{ rec_v2 }}"
            aria-label="Add both recommended products to cart"
            onclick="plAddBoth(this)">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/><path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2"/></svg>
      Add both &mdash; save &#8377;{{ rec_save_r }} extra
    </button>
    <p class="pl-rec-footer-note">10% off applied automatically at checkout</p>
  </div>
  {% endif %}

</section>
{% endif %}