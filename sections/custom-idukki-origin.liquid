<style>
  .idukki-origin-wrapper { background: #F8F5EE; }
  .idukki-origin { display: flex; flex-direction: column; max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; gap: 4rem; }
  @media(min-width: 750px) { .idukki-origin { flex-direction: row; align-items: center; padding: 8rem 4rem; gap: 8rem; } }
  
  .idukki-origin__image-box { width: 100%; position: relative; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 40px rgba(27, 94, 86, 0.08); }
  .idukki-origin__image-box img { display: block; width: 100%; height: auto; object-fit: cover; }
  @media(min-width: 750px) { 
    .idukki-origin__image-box { 
      width: 50%; 
      aspect-ratio: 1 / 1; 
    } 
    .idukki-origin__image-box img { position: absolute; top: 0; left: 0; height: 100%; }
  }

  .idukki-origin__content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; }
  @media(min-width: 750px) { .idukki-origin__content { padding: 0; } }

  .idukki-origin__badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(27, 94, 86, 0.1); color: #1B5E56; font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 6px 12px; border-radius: 4px; margin-bottom: 2rem; }
  .idukki-origin__badge svg { width: 14px; height: 14px; fill: currentColor; }

  .idukki-origin__heading { font-family: var(--font-heading-family); font-size: 2.8rem; color: #1B3A30; line-height: 1.2; margin-bottom: 2rem; }
  @media(min-width: 750px) { .idukki-origin__heading { font-size: 4rem; } }

  .idukki-origin__text { font-size: 1.5rem; color: #5A6B67; line-height: 1.6; margin-bottom: 3.5rem; max-width: 90%; }
  
  .idukki-origin__btn { display: inline-flex; align-items: center; gap: 10px; font-weight: 600; font-size: 1.4rem; color: #1B5E56; text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 4px; transition: border-color 0.3s ease, gap 0.3s ease; }
  .idukki-origin__btn:hover { border-color: #1B5E56; gap: 14px; }
  .idukki-origin__btn svg { width: 16px; height: 16px; transition: transform 0.3s ease; }
</style>

<div class="idukki-origin-wrapper">
  <div class="idukki-origin">
  <div class="idukki-origin__image-box">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | img_url: '1000x' }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="idukki-origin__content">
    {%- if section.settings.badge_text != blank -%}
      <div class="idukki-origin__badge">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-3H8v3H6v-7h2v2.5h3V8.5h2v6H15v1.5h-4z"/></svg>
        {{ section.settings.badge_text }}
      </div>
    {%- endif -%}

    <h2 class="idukki-origin__heading">{{ section.settings.heading | newline_to_br }}</h2>
    
    <div class="idukki-origin__text">
      {{ section.settings.text }}
    </div>

    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="idukki-origin__btn">
        {{ section.settings.btn_label }}
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    {%- endif -%}
  </div>
</div>
</div>

{% schema %}
{
  "name": "Idukki Origin Split",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Feature Image" },
    { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "100% Organic Origin" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Deep Rooted in Idukki." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Our spices never sit in warehouses. They are handpicked from high-altitude estates and brought straight to your kitchen, preserving every note of aroma.</p>" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Read Our Story" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "presets": [ { "name": "Idukki Origin Split Feature" } ]
}
{% endschema %}