      "settings": {
        "custom_liquid": "<style>\n  .pl-footer { background: #1B3A30; color: #C8D9D6; padding: 60px 0 0; font-family: var(--font-body-family, 'Inter', sans-serif); }\n  .pl-footer a { color: #C8D9D6; text-decoration: none; transition: color 0.2s; }\n  .pl-footer a:hover { color: #F8F5EE; }\n  .pl-footer__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: grid; grid-template-columns: 2fr 1fr 1fr 1.4fr; gap: 40px; }\n  .pl-footer__brand-logo { height: 52px; width: auto; margin-bottom: 16px; display: block; }\n  .pl-footer__brand-wordmark { display: inline-block; margin-bottom: 16px; color: #F8F5EE; font-size: 2.4rem; font-weight: 700; letter-spacing: 0.04em; line-height: 1.1; }\n  .pl-footer__tagline { font-size: 13px; line-height: 1.7; color: #A0B5B0; margin: 0 0 20px; max-width: 260px; }\n  .pl-footer__compliance { font-size: 11px; color: #6D8C87; line-height: 1.6; margin: 0; }\n  .pl-footer__col-title { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #F8F5EE; margin: 0 0 18px; }\n  .pl-footer__links { list-style: none; margin: 0; padding: 0; }\n  .pl-footer__links li { margin-bottom: 10px; }\n  .pl-footer__links a { font-size: 14px; color: #A0B5B0; }\n  .pl-footer__links a:hover { color: #F8F5EE; }\n  .pl-footer__contact-item { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 14px; }\n  .pl-footer__contact-icon { width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px; opacity: 0.6; }\n  .pl-footer__contact-text { font-size: 13px; color: #A0B5B0; line-height: 1.5; }\n  .pl-footer__contact-text strong { color: #F8F5EE; font-weight: 600; display: block; font-size: 12px; }\n  .pl-footer__social { display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap; }\n  .pl-footer__social-link { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #2E5447; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }\n  .pl-footer__social-link:hover { background: #1B5E56; border-color: #1B5E56; }\n  .pl-footer__social-link svg { width: 16px; height: 16px; fill: #A0B5B0; }\n  .pl-footer__social-link:hover svg { fill: #F8F5EE; }\n  .pl-footer__divider { max-width: 1200px; margin: 40px auto 0; padding: 0 24px; border-top: 1px solid #2E5447; }\n  .pl-footer__bottom { max-width: 1200px; margin: 0 auto; padding: 20px 24px 28px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }\n  .pl-footer__copyright { font-size: 12px; color: #6D8C87; }\n  .pl-footer__copyright a { color: #6D8C87; }\n  .pl-footer__copyright a:hover { color: #A0B5B0; }\n  .pl-footer__badge { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; color: #6D8C87; }\n  .pl-footer__badge svg { width: 14px; height: 14px; fill: #4D9B93; }\n  .pl-footer__payment { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }\n  .pl-footer__payment-badge { background: #243D35; border: 1px solid #2E5447; border-radius: 4px; padding: 4px 8px; font-size: 10px; font-weight: 600; color: #A0B5B0; letter-spacing: 0.04em; }\n  @media (max-width: 900px) {\n    .pl-footer__inner { grid-template-columns: 1fr 1fr; gap: 32px; }\n  }\n  @media (max-width: 600px) {\n    .pl-footer { padding: 40px 0 0; }\n    .pl-footer__inner { grid-template-columns: 1fr; gap: 28px; }\n    .pl-footer__tagline { max-width: 100%; }\n    .pl-footer__bottom { flex-direction: column; align-items: flex-start; }\n  }\n</style>\n\n<div class=\"pl-footer\">\n  <div class=\"pl-footer__inner\">\n\n    <!-- Column 1: Brand -->\n    <div>\n      {% if settings.logo != blank %}{{ settings.logo | image_url: width: 320 | image_tag: alt: shop.name, class: 'pl-footer__brand-logo' }}{% else %}<span class=\"pl-footer__brand-wordmark\">{{ shop.name }}</span>{% endif %}\n      <p class=\"pl-footer__tagline\">Premium spices from the heart of Idukki, Kerala — grown with tradition, delivered with care.</p>\n      <p class=\"pl-footer__compliance\">FSSAI Licensed &bull; 100% Natural &bull; No Artificial Additives<br>Pure Leven Exim, 8/621 Rajakumari, Idukki, Kerala 685619</p>\n    </div>\n\n    <!-- Column 2: Shop -->\n    <div>\n      <h3 class=\"pl-footer__col-title\">Shop</h3>\n      <ul class=\"pl-footer__links\">\n        <li><a href=\"/collections/all\">All Spices</a></li>\n        <li><a href=\"/collections/export-quality-cardamom\">Cardamom</a></li>\n        <li><a href=\"/collections/spiciest-black-pepper\">Black Pepper</a></li>\n        <li><a href=\"/collections/cloves\">Cloves</a></li>\n        <li><a href=\"/collections/all?filter.p.tag=combo\">Combo Packs</a></li>\n      </ul>\n    </div>\n\n    <!-- Column 3: Quick Links -->\n    <div>\n      <h3 class=\"pl-footer__col-title\">Quick Links</h3>\n      <ul class=\"pl-footer__links\">\n        <li><a href=\"/pages/about\">Our Story</a></li>\n        <li><a href=\"/pages/contact\">Contact Us</a></li>\n        <li><a href=\"/policies/shipping-policy\">Shipping Policy</a></li>\n        <li><a href=\"/policies/refund-policy\">Returns &amp; Refunds</a></li>\n        <li><a href=\"/policies/privacy-policy\">Privacy Policy</a></li>\n        <li><a href=\"/policies/terms-of-service\">Terms of Service</a></li>\n      </ul>\n    </div>\n\n    <!-- Column 4: Contact + Social -->\n    <div>\n      <h3 class=\"pl-footer__col-title\">Get in Touch</h3>\n      <div class=\"pl-footer__contact-item\">\n        <svg class=\"pl-footer__contact-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.42 2 2 0 0 1 3.6 1.25h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6.16 6.16l.91-1.34a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>\n        <div class=\"pl-footer__contact-text\"><strong>Phone</strong>+91 80755 19579</div>\n      </div>\n      <div class=\"pl-footer__contact-item\">\n        <svg class=\"pl-footer__contact-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"/><polyline points=\"22,6 12,13 2,6\"/></svg>\n        <div class=\"pl-footer__contact-text\"><strong>Email</strong>purelevenexim@gmail.com</div>\n      </div>\n      <div class=\"pl-footer__contact-item\">\n        <svg class=\"pl-footer__contact-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n        <div class=\"pl-footer__contact-text\"><strong>Address</strong>Rajakumari, Idukki, Kerala 685619</div>\n      </div>\n      <div class=\"pl-footer__social\">\n        <a href=\"https://www.instagram.com/pureleven.in/\" class=\"pl-footer__social-link\" aria-label=\"Instagram\">\n          <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z\"/></svg>\n        </a>\n        <a href=\"https://www.facebook.com/pureleven