{%- comment -%}
  sections/basil-checkout-prep.liquid
  Phase 2: Address Intelligence
  Full-page pre-checkout step shown at /pages/checkout-prep.
  Validates pincode, checks COD availability, shows ETA, then redirects to Shopify checkout.
{%- endcomment -%}

{%- assign section_id = section.id -%}

<div
  id="basil-checkout-prep"
  class="basil-checkout-prep page-width"
  data-section-id="{{ section_id }}"
>

  {%- comment -%}── Branded page header ──{%- endcomment -%}
  <div class="basil-prep__page-header">
    <a href="{{ routes.root_url }}" class="basil-prep__logo-link" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="80" height="32" class="basil-prep__logo-img">
      {%- else -%}
        <span class="basil-prep__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <div class="basil-prep__page-trust">
      <span class="basil-prep__trust-badge">🔒 Secure Checkout</span>
    </div>
  </div>

  {%- comment -%}── Breadcrumb / progress steps ──{%- endcomment -%}
  <div class="basil-prep__steps" aria-label="Checkout progress">
    <div class="basil-prep__step is-active">
      <div class="basil-prep__step-dot">1</div>
      <span>Delivery</span>
    </div>
    <div class="basil-prep__step-line"></div>
    <div class="basil-prep__step">
      <div class="basil-prep__step-dot">2</div>
      <span>Payment</span>
    </div>
    <div class="basil-prep__step-line"></div>
    <div class="basil-prep__step">
      <div class="basil-prep__step-dot">3</div>
      <span>Confirm</span>
    </div>
  </div>

  {%- comment -%}── Mobile: sticky order summary trigger ──{%- endcomment -%}

  <div class="basil-prep__grid">

    {%- comment -%}── Left: Address Form ──{%- endcomment -%}
    <div class="basil-prep__form-col">

      {%- comment -%}── Mobile sticky order summary trigger (inside form col, visible on mobile only) ──{%- endcomment -%}
      <div id="basil-summary-trigger" class="basil-summary-trigger" data-basil-sheet-open aria-label="View order summary">
        <div class="basil-summary-trigger__left">
          <span class="basil-summary-trigger__count">{{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}</span>
          <span class="basil-summary-trigger__dot">·</span>
          <span class="basil-summary-trigger__total">{{ cart.total_price | money_without_trailing_zeros }}</span>
        </div>
        <div class="basil-summary-trigger__right">
          <span>Order Summary</span>
          <span class="basil-summary-trigger__arrow">▲</span>
        </div>
      </div>

      {%- comment -%}── PHASE 3: OTP Login Section ──{%- endcomment -%}
      <div class="basil-otp-container">
        <div class="basil-otp__header">
          <span class="basil-otp__icon">📱</span>
          <div>
            <h2 class="basil-otp__title">Verify Your Phone</h2>
            <p class="basil-otp__subtitle">Get order updates and track shipment via WhatsApp</p>
          </div>
        </div>

        <div class="basil-otp__message"></div>

        {%- comment -%}── STAGE 1: Phone Input ──{%- endcomment -%}
        <div class="basil-otp-stage basil-otp-stage--phone active">
          <div class="basil-otp__phone-group">
            <input
              id="otp-phone-input"
              type="text"
              inputmode="numeric"
              class="basil-otp__phone-input"
              placeholder="Enter 10-digit number"
              maxlength="10"
            >
            <button type="button" id="otp-send-btn" class="basil-otp__send-btn">📱 Send OTP</button>
          </div>
          <button type="button" class="basil-otp__toggle">Use email instead</button>
        </div>

        {%- comment -%}── STAGE 2: OTP Input ──{%- endcomment -%}
        <div class="basil-otp-stage basil-otp-stage--otp">
          <p style="font-size: 0.95rem; color: #666; margin-bottom: 1rem;">
            Enter the 6-digit code sent to your phone
          </p>
          <div class="basil-otp__otp-group">
            <input type="text" class="basil-otp__digit" maxlength="1" inputmode="numeric">
            <input type="text" class="basil-otp__digit" maxlength="1" inputmode="numeric">
            <input type="text" class="basil-otp__digit" maxlength="1" inputmode="numeric">
            <input type="text" class="basil-otp__digit" maxlength="1" inputmode="numeric">
            <input type="text" class="basil-otp__digit" maxlength="1" inputmode="numeric">
            <input type="text" class="basil-otp__digit" maxlength="1" inputmode="numeric">
          </div>
          <div class="basil-otp__timer"></div>

          <div class="basil-otp__actions">
            <button type="button" id="otp-verify-btn" class="basil-otp__verify-btn" disabled>✓ Verify OTP</button>
            <button type="button" class="basil-otp__change-phone">Change Phone</button>
          </div>

          <div class="basil-otp__resend">
            Didn't receive? <button type="button" class="basil-otp__resend-btn">Resend OTP</button>
          </div>
        </div>
      </div>

      {%- comment -%}── PHASE 4: Customer Tier Indicator ──{%- endcomment -%}
      <div class="basil-prep__tier-indicator"></div>

      <h1 class="basil-prep__heading">Confirm Delivery Details</h1>

      {%- comment -%}── Saved Addresses — rendered by basil-checkout-prep.js from localStorage ──{%- endcomment -%}
      <div id="basil-saved-addresses-section" hidden>
        <div class="basil-saved-header">
          <span class="basil-saved-header__title">📍 Saved Addresses</span>
          <button type="button" class="basil-saved-header__new" id="basil-add-new-address">+ New Address</button>
        </div>
        <div id="basil-saved-addresses-list" class="basil-saved-list" role="list"></div>
      </div>

      <form id="basil-address-form" class="basil-prep__form" novalidate autocomplete="on">

        {%- comment -%}── Pincode row ──{%- endcomment -%}
        <div class="basil-field">
          <label class="basil-field__label" for="basil-pincode">Pincode</label>
          <div class="basil-field__pincode-row">
            <input
              id="basil-pincode"
              name="zip"
              type="text"
              inputmode="numeric"
              maxlength="6"
              pattern="[0-9]{6}"
              class="basil-field__input"
              placeholder="6-digit PIN code"
              autocomplete="postal-code"
              required
            >
            <button
              type="button"
              id="basil-pincode-check-btn"
              class="button button--secondary basil-field__pincode-btn"
              data-basil-action="check-pincode"
            >
              Check
            </button>
          </div>
          <div id="basil-pincode-feedback" class="basil-field__feedback" aria-live="polite"></div>
        </div>

        {%- comment -%}── Address fields (shown after pincode validated) ──{%- endcomment -%}
        <div id="basil-address-fields" class="basil-address-fields" hidden>

          <div class="basil-field">
            <label class="basil-field__label" for="basil-full-name">Full Name</label>
            <input
              id="basil-full-name"
              name="name"
              type="text"
              class="basil-field__input"
              placeholder="As on order"
              autocomplete="name"
              required
            >
          </div>

          <div class="basil-field">
            <label class="basil-field__label" for="basil-phone">Phone</label>
            <input
              id="basil-phone"
              name="phone"
              type="tel"
              inputmode="numeric"
              maxlength="10"
              class="basil-field__input"
              placeholder="10-digit mobile"
              autocomplete="tel"
              required
            >
          </div>

          <div class="basil-field">
            <label class="basil-field__label" for="basil-address1">Address Line 1</label>
            <input
              id="basil-address1"
              name="address1"
              type="text"
              class="basil-field__input"
              placeholder="House / Flat / Building"
              autocomplete="address-line1"
              required
            >
          </div>

          <div class="basil-field">
            <label class="basil-field__label" for="basil-address2">Address Line 2 <span class="basil-field__optional">(optional)</span></label>
            <input
              id="basil-address2"
              name="address2"
              type="text"
              class="basil-field__input"
              placeholder="Area / Locality / Street"
              autocomplete="address-line2"
            >
          </div>

          <div class="basil-field-row">
            <div class="basil-field">
              <label class="basil-field__label" for="basil-city">City</label>
              <input
                id="basil-city"
                name="city"
                type="text"
                class="basil-field__input"
                placeholder="City"
                autocomplete="address-level2"
                required
              >
            </div>
            <div class="basil-field">
              <label class="basil-field__label" for="basil-state">State</label>
              <input
                id="basil-state"
                name="province"
                type="text"
                class="basil-field__input"
                placeholder="State"
                autocomplete="address-level1"
                required
                readonly
              >
            </div>
          </div>

        </div>{%- comment -%}/#basil-address-fields{%- endcomment -%}

        {%- comment -%}── COD toggle ──{%- endcomment -%}
        <div id="basil-cod-section" class="basil-cod-section" hidden>
          <div class="basil-cod-option">
            <div class="basil-cod-option__check" id="basil-cod-badge"></div>
            <div class="basil-cod-option__text">
              <strong>Cash on Delivery</strong>
              <span id="basil-cod-label" class="basil-cod-option__sub">Checking availability…</span>
            </div>
          </div>
        </div>

        {%- comment -%}── ETA bar ──{%- endcomment -%}
        <div id="basil-eta-section" class="basil-eta-section" hidden>
          <div class="basil-eta-bar">
            <span class="basil-eta-bar__icon">📦</span>
            <span id="basil-eta-text" class="basil-eta-bar__text">Estimated delivery: --</span>
          </div>
        </div>

        {%- comment -%}── Payment Method Preview (psychological trust) ──{%- endcomment -%}
        <div class="basil-payment-methods">
          <span class="basil-payment-methods__label">Pay via</span>
          <div class="basil-payment-methods__grid">
            <div class="basil-payment-method">
              <span class="basil-payment-method__icon">⚡</span>
              <span class="basil-payment-method__name">UPI</span>
            </div>
            <div class="basil-payment-method">
              <span class="basil-payment-method__icon">🏦</span>
              <span class="basil-payment-method__name">Net Banking</span>
            </div>
            <div class="basil-payment-method">
              <span class="basil-payment-method__icon">💳</span>
              <span class="basil-payment-method__name">Cards</span>
            </div>
            <div class="basil-payment-method">
              <span class="basil-payment-method__icon">💵</span>
              <span class="basil-payment-method__name">COD</span>
            </div>
          </div>
        </div>

        {%- comment -%}── Trust + Offer Reinforcement ──{%- endcomment -%}
        <div class="basil-prep__pre-cta">
          <div class="basil-prep__trust-strip">
            <span class="basil-prep__trust-item">✓ 100% Secure Payments</span>
            <span class="basil-prep__trust-item">✓ Trusted by 10,000+ customers</span>
          </div>
          {%- if cart.total_discount > 0 -%}
            <div class="basil-prep__offer-unlock">
              <span class="basil-prep__offer-icon">🎁</span>
              <span class="basil-prep__offer-text">You unlocked ₹{{ cart.total_discount | money_without_trailing_zeros }} OFF!</span>
            </div>
          {%- endif -%}
        </div>

        <button
          type="submit"
          id="basil-continue-btn"
          class="basil-checkout-btn button button--full-width button--primary"
          disabled
          data-basil-cta="continue-to-checkout"
        >
          <span class="basil-checkout-btn__icon">🔒</span>
          <span class="basil-checkout-btn__label">Continue to Secure Payment</span>
        </button>

      </form>
    </div>{%- comment -%}/.basil-prep__form-col{%- endcomment -%}

    {%- comment -%}── Right: Order Summary ──{%- endcomment -%}
    <div class="basil-prep__summary-col">
      <div class="basil-prep__order-summary">
        <h2 class="basil-prep__summary-heading">Order Summary</h2>

        {%- for item in cart.items -%}
          <div class="basil-prep-item">
            <div class="basil-prep-item__img-wrap">
              {%- if item.image -%}
                <img
                  src="{{ item.image | image_url: width: 80 }}"
                  alt="{{ item.image.alt | escape }}"
                  width="40"
                  height="40"
                  loading="lazy"
                  class="basil-prep-item__img"
                >
              {%- endif -%}
              <span class="basil-prep-item__qty-badge">{{ item.quantity }}</span>
            </div>
            <div class="basil-prep-item__meta">
              <span class="basil-prep-item__name">{{ item.product_title }}</span>
              {%- unless item.variant_title == 'Default Title' -%}
                <span class="basil-prep-item__variant">{{ item.variant_title }}</span>
              {%- endunless -%}
            </div>
            <span class="basil-prep-item__price">{{ item.final_line_price | money_without_trailing_zeros }}</span>
          </div>
        {%- endfor -%}

        <div class="basil-prep__summary-totals">
          <div class="basil-prep__row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money_without_trailing_zeros }}</span>
          </div>
          <div class="basil-prep__row" id="basil-shipping-row">
            <span>Shipping</span>
            <span id="basil-shipping-value">--</span>
          </div>
          {%- if cart.total_discount > 0 -%}
            <div class="basil-prep__row basil-prep__row--discount">
              <span>Discount</span>
              <span>−{{ cart.total_discount | money_without_trailing_zeros }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="basil-prep__trust">
        <span>🔒 Secure SSL</span>
        <span>📦 Easy Returns</span>
        <span>⭐ 4.8/5 Rating</span>
      </div>
    </div>

  </div>
</div>

{%- comment -%}── Order Summary Bottom Sheet ──{%- endcomment -%}
<div id="basil-summary-overlay" class="basil-summary-overlay" aria-hidden="true"></div>
<div
  id="basil-summary-sheet"
  class="basil-summary-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Order summary"
  aria-hidden="true"
>
  <div class="basil-summary-sheet__handle"></div>
  <div class="basil-summary-sheet__header">
    <h3 class="basil-summary-sheet__title">Order Summary ({{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }})</h3>
    <button type="button" class="basil-summary-sheet__close" data-basil-sheet-close aria-label="Close">✕</button>
  </div>
  <div class="basil-summary-sheet__body">
    {%- for item in cart.items -%}
      <div class="basil-prep-item">
        <div class="basil-prep-item__img-wrap">
          {%- if item.image -%}
            <img src="{{ item.image | image_url: width: 80 }}" alt="{{ item.image.alt | escape }}" width="40" height="40" loading="lazy" class="basil-prep-item__img">
          {%- endif -%}
          <span class="basil-prep-item__qty-badge">{{ item.quantity }}</span>
        </div>
        <div class="basil-prep-item__meta">
          <span class="basil-prep-item__name">{{ item.product_title }}</span>
          {%- unless item.variant_title == 'Default Title' -%}
            <span class="basil-prep-item__variant">{{ item.variant_title }}</span>
          {%- endunless -%}
        </div>
        <span class="basil-prep-item__price">{{ item.final_line_price | money_without_trailing_zeros }}</span>
      </div>
    {%- endfor -%}
    <div class="basil-summary-sheet__totals">
      <div class="basil-prep__row"><span>Subtotal</span><span>{{ cart.original_total_price | money_without_trailing_zeros }}</span></div>
      {%- if cart.total_discount > 0 -%}
        <div class="basil-prep__row basil-prep__row--discount"><span>Discount</span><span>−{{ cart.total_discount | money_without_trailing_zeros }}</span></div>
      {%- endif -%}
      <div class="basil-prep__row" id="basil-sheet-shipping-row"><span>Delivery</span><span id="basil-sheet-shipping-value">Calculated at checkout</span></div>
      <div class="basil-prep__row basil-prep__row--total"><span>Total</span><span>{{ cart.total_price | money_without_trailing_zeros }}</span></div>
    </div>
    <div class="basil-upi-banner">
      <span class="basil-upi-banner__icon">⚡</span>
      <span class="basil-upi-banner__text">Pay via UPI / Prepaid — enjoy fast delivery on all prepaid orders</span>
      {%- if settings.basil_cart_prepaid_saving != blank -%}
        <span class="basil-upi-banner__save">Save ₹{{ settings.basil_cart_prepaid_saving }}</span>
      {%- endif -%}
    </div>
    <div class="basil-payment-strip">
      <span class="basil-payment-strip__label">Pay via:</span>
      <span class="basil-payment-badge">⚡ UPI</span>
      <span class="basil-payment-badge">🏦 Net Banking</span>
      <span class="basil-payment-badge">💳 Card</span>
      <span class="basil-payment-badge">💵 COD</span>
    </div>
  </div>
</div>

{%- comment -%}── Exit Intent Modal ──{%- endcomment -%}
<div id="basil-exit-overlay" class="basil-exit-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Special offer before you go">

  <div class="basil-exit-modal">
    <button type="button" class="basil-exit-modal__close" id="basil-exit-close" aria-label="Close">✕</button>

    <div class="basil-exit-modal__header">
      <span class="basil-exit-modal__icon">🎁</span>
      <h2 class="basil-exit-modal__title">Wait! Before you go…</h2>
      <p class="basil-exit-modal__subtitle">Your cart is ready. Here's a little push.</p>
    </div>

    <div class="basil-exit-modal__body">

      <div class="basil-exit-urgency">
        <span>⏳</span>
        <span>Products in huge demand — might go out of stock!</span>
      </div>

      {%- comment -%}── Cart Items Mini Summary ──{%- endcomment -%}
      <div class="basil-exit-items">
        {%- for item in cart.items limit: 3 -%}
          <div class="basil-exit-item">
            {%- if item.image -%}
              <img
                src="{{ item.image | image_url: width: 96 }}"
                alt="{{ item.image.alt | escape }}"
                width="48"
                height="48"
                loading="lazy"
                class="basil-exit-item__img"
              >
            {%- endif -%}
            <div class="basil-exit-item__info">
              <div class="basil-exit-item__name">{{ item.product_title }}</div>
              <div class="basil-exit-item__price">
                {{ item.final_line_price | money_without_trailing_zeros }}
                {%- if item.original_line_price != item.final_line_price -%}
                  <s style="color:#ccc;margin-left:4px;">{{ item.original_line_price | money_without_trailing_zeros }}</s>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
        {%- if cart.item_count > 3 -%}
          <div style="font-size:1.2rem;color:#888;text-align:center;">+ {{ cart.item_count | minus: 3 }} more item{{ cart.item_count | minus: 3 | pluralize: '', 's' }}</div>
        {%- endif -%}
      </div>

      {%- comment -%}── Coupon Offer ──{%- endcomment -%}
      <div class="basil-exit-coupon">
        <span class="basil-exit-coupon__label">Use this exclusive coupon at checkout</span>
        <span class="basil-exit-coupon__code" id="basil-exit-coupon-code">{{ section.settings.exit_coupon_code | default: 'FIRSTORDER' }}</span>
        <span class="basil-exit-coupon__desc">✓ {{ section.settings.exit_coupon_desc | default: 'Extra ₹100 off on your first order' }}</span>
      </div>

      <div class="basil-exit-modal__actions">
        <button type="button" class="basil-exit-modal__cta basil-exit-modal__cta--primary" id="basil-exit-complete-btn">
          🔒 Complete My Purchase
        </button>
        <button type="button" class="basil-exit-modal__cta basil-exit-modal__cta--secondary" id="basil-exit-dismiss-btn">
          No thanks, I'll skip the discount
        </button>
      </div>

    </div>
  </div>
</div>

{{ 'basil-checkout-prep.css' | asset_url | stylesheet_tag }}
{{ 'basil-checkout-otp.css' | asset_url | stylesheet_tag }}
{{ 'basil-tier-indicators.css' | asset_url | stylesheet_tag }}
<script src="{{ 'basil-checkout-prep.js' | asset_url }}" defer></script>
<script src="{{ 'basil-checkout-otp.js' | asset_url }}" defer></script>
<script src="{{ 'basil-customer-tier.js' | asset_url }}" defer></script>
<script src="{{ 'basil-loyalty.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Checkout Prep",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "exit_coupon_code",
      "label": "Exit intent coupon code",
      "default": "FIRSTORDER",
      "info": "Coupon shown in exit-intent popup"
    },
    {
      "type": "text",
      "id": "exit_coupon_desc",
      "label": "Exit intent coupon description",
      "default": "Extra ₹100 off on your first order"
    }
  ]
}
{% endschema %}
