{
  "name": "Pureleven — Cart Abandonment Recovery",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 10 }] }
      },
      "name": "Every 10 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "https://track.pureleven.com/api/crm/abandonment/cart",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "window_minutes", "value": "30" },
            { "name": "limit", "value": "50" }
          ]
        },
        "options": {}
      },
      "name": "Get Cart Abandoners",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "number": [{ "value1": "={{ $json.count }}", "operation": "larger", "value2": 0 }]
        }
      },
      "name": "Any abandoners?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "candidates",
        "options": {}
      },
      "name": "Split Candidates",
      "type": "n8n-nodes-base.splitOut",
      "position": [900, 200]
    },
    {
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.phone }}", "operation": "isNotEmpty" }]
        }
      },
      "name": "Has phone?",
      "type": "n8n-nodes-base.if",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "url": "https://api.wabis.in/v1/send-template",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to", "value": "={{ $json.phone }}" },
            { "name": "template", "value": "cart_recovery_v1" },
            {
              "name": "params",
              "value": "={{ JSON.stringify([ $json.first_name || 'there' ]) }}"
            }
          ]
        },
        "options": {}
      },
      "name": "WhatsApp Cart Reminder",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 140],
      "notes": "Template: cart_recovery_v1\nMessage: 'Hi {{first_name}}, you left something in your cart! Grab your Kerala spices before they run out.'"
    },
    {
      "parameters": {
        "url": "=https://track.pureleven.com/api/crm/abandonment/{{ $json.event_id }}/mark_notified",
        "requestMethod": "PATCH",
        "options": {}
      },
      "name": "Mark Notified",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1560, 200]
    }
  ],
  "connections": {
    "Every 10 minutes":   { "main": [[{ "node": "Get Cart Abandoners", "type": "main", "index": 0 }]] },
    "Get Cart Abandoners":{ "main": [[{ "node": "Any abandoners?", "type": "main", "index": 0 }]] },
    "Any abandoners?":    { "main": [[{ "node": "Split Candidates", "type": "main", "index": 0 }], []] },
    "Split Candidates":   { "main": [[{ "node": "Has phone?", "type": "main", "index": 0 }]] },
    "Has phone?":         { "main": [[{ "node": "WhatsApp Cart Reminder", "type": "main", "index": 0 }], [{ "node": "Mark Notified", "type": "main", "index": 0 }]] },
    "WhatsApp Cart Reminder": { "main": [[{ "node": "Mark Notified", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "pureleven-retargeting" }]
}
