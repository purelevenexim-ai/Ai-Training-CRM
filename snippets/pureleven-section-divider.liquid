{%- liquid
  assign divider_eyebrow = eyebrow
  assign divider_heading = heading
  assign divider_subtitle = subtitle
  assign divider_heading_tag = heading_tag | default: 'h2'
  assign divider_icon = icon | default: 'seed'
  assign divider_icon_size = icon_size | default: 24
  assign divider_show_ornament = true
  if show_ornament == false
    assign divider_show_ornament = false
  endif
-%}

<div class="pl-section-divider{% if extra_class != blank %} {{ extra_class }}{% endif %}">
  {%- if divider_eyebrow != blank -%}
    <span class="pl-section-divider__tag">{{ divider_eyebrow }}</span>
  {%- endif -%}

  {%- if divider_heading != blank -%}
    <{{ divider_heading_tag }} class="pl-section-divider__title">{{ divider_heading }}</{{ divider_heading_tag }}>
  {%- endif -%}

  {%- if divider_show_ornament -%}
    <div class="pl-section-divider__ornament" aria-hidden="true">
      <div class="pl-section-divider__ornament-line"></div>
      {%- case divider_icon -%}
        {%- when 'star' -%}
          <svg class="pl-section-divider__ornament-svg" width="{{ divider_icon_size }}" height="{{ divider_icon_size }}" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
          </svg>
        {%- when 'leaf' -%}
          <svg class="pl-section-divider__ornament-svg" width="{{ divider_icon_size }}" height="{{ divider_icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M19 4c-7.5.4-12 4.8-12 11.1 0 2 1 4.9 3.2 4.9 1.8 0 3.1-1.7 3.7-3.5.5-1.5 1.2-3 2.1-4.2 1.3-1.7 3-3 4-3.8-.1 2.5-.8 5.1-2.7 7.3-2.2 2.7-5.9 4.2-11.3 4.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        {%- else -%}
          <svg class="pl-section-divider__ornament-svg" width="{{ divider_icon_size }}" height="{{ divider_icon_size }}" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C9.24 2 7 4.24 7 7c0 2.85 2.92 6.21 5 8.44C14.08 13.21 17 9.85 17 7c0-2.76-2.24-5-5-5zm0 6.5c-.83 0-1.5-.67-1.5-1.5S11.17 5.5 12 5.5s1.5.67 1.5 1.5S12.83 8.5 12 8.5zM5 20v-1c0-1.1 2.69-2 7-2s7 .9 7 2v1H5z" />
          </svg>
      {%- endcase -%}
      <div class="pl-section-divider__ornament-line"></div>
    </div>
  {%- endif -%}

  {%- if divider_subtitle != blank -%}
    <p class="pl-section-divider__subtitle">{{ divider_subtitle }}</p>
  {%- endif -%}
</div>