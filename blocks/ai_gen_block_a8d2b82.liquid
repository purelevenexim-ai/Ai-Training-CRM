{% doc %}
  @prompt
    TRUST BAR (Small Icons Section)
    
    Add icons in Shopify:
    
    ✔ Freshly Packed
    ✔ Kerala High Range Origin
    ✔ Wholesale & Retail
    ✔ Fast Shipping Across India
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_vertical }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-trust-bar-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    flex-wrap: wrap;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-trust-bar-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-trust-bar-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-bar-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-trust-bar-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-bar-container-{{ ai_gen_id }} {
      gap: {{ block.settings.item_spacing | times: 0.7 }}px;
    }

    .ai-trust-bar-item-{{ ai_gen_id }} {
      gap: {{ block.settings.icon_text_gap | times: 0.7 }}px;
    }

    .ai-trust-bar-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-bar-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-bar-container-{{ ai_gen_id }}">
    {% if block.settings.show_item_1 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 7h-9"></path>
            <path d="M14 17H5"></path>
            <circle cx="17" cy="17" r="3"></circle>
            <circle cx="7" cy="7" r="3"></circle>
          </svg>
        </div>
        <span class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.item_1_text }}</span>
      </div>
    {% endif %}

    {% if block.settings.show_item_2 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
        </div>
        <span class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.item_2_text }}</span>
      </div>
    {% endif %}

    {% if block.settings.show_item_3 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z"></path>
            <path d="m3 9 2.45-4.9A2 2 0 0 1 7.24 3h9.52a2 2 0 0 1 1.8 1.1L21 9"></path>
            <path d="M12 3v6"></path>
          </svg>
        </div>
        <span class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.item_3_text }}</span>
      </div>
    {% endif %}

    {% if block.settings.show_item_4 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 3h5v5"></path>
            <path d="M8 3H3v5"></path>
            <path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"></path>
            <path d="m15 9 6-6"></path>
          </svg>
        </div>
        <span class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.item_4_text }}</span>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Trust bar",
  "settings": [
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "checkbox",
      "id": "show_item_1",
      "label": "Show item 1",
      "default": true
    },
    {
      "type": "text",
      "id": "item_1_text",
      "label": "Text",
      "default": "Freshly Packed"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "checkbox",
      "id": "show_item_2",
      "label": "Show item 2",
      "default": true
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Text",
      "default": "Kerala High Range Origin"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "checkbox",
      "id": "show_item_3",
      "label": "Show item 3",
      "default": true
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Text",
      "default": "Wholesale & Retail"
    },
    {
      "type": "header",
      "content": "Item 4"
    },
    {
      "type": "checkbox",
      "id": "show_item_4",
      "label": "Show item 4",
      "default": true
    },
    {
      "type": "text",
      "id": "item_4_text",
      "label": "Text",
      "default": "Fast Shipping Across India"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#078362"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#fce477"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Space between items",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Icon to text spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Trust bar"
    }
  ]
}
{% endschema %}
