{% comment %} pl-sticky-bar.liquid — Pure Leven Cart {% endcomment %}

{% assign total_rupees     = cart.total_price | divided_by: 100 %}
{% assign discount_rupees  = cart.total_discount | default: 0 | divided_by: 100 %}
{% assign ship_threshold   = settings.free_shipping_threshold | default: 649 %}
{% assign ship_threshold_p = ship_threshold | times: 100 %}
{% assign ship_unlocked    = false %}
{% if cart.total_price >= ship_threshold_p %}{% assign ship_unlocked = true %}{% endif %}

{% comment %} Savings from compare_at_price across all items {% endcomment %}
{% assign total_savings_p = 0 %}
{% for item in cart.items %}
  {% if item.variant.compare_at_price > item.price %}
    {% assign line_saving = item.variant.compare_at_price | minus: item.price | times: item.quantity %}
    {% assign total_savings_p = total_savings_p | plus: line_saving %}
  {% endif %}
{% endfor %}
{% assign savings_rupees = total_savings_p | divided_by: 100 %}

<div class="pl-sticky-bar" id="pl-sticky-bar">
  <div class="pl-sticky-inner">

    <div class="pl-sticky-left">
      <!-- Total -->
      <div class="pl-sticky-meta-row">
        <span class="pl-sticky-total-label">Total</span>
        <span class="pl-sticky-total-amt">&#8377;{{ total_rupees }}</span>
        <span class="pl-sticky-urg" id="pl-sticky-urg" aria-live="polite">
          &#9203; <strong id="pl-sticky-urg-time">--:--</strong>
        </span>
      </div>

      <!-- Mini order summary chips -->
      <div class="pl-sticky-summary">
        {% if ship_unlocked %}
          <span class="pl-ss-chip pl-ss-ship">&#10003; FREE shipping</span>
        {% endif %}
        {% if savings_rupees > 0 %}
          <span class="pl-ss-chip pl-ss-saved">Saved &#8377;{{ savings_rupees }}</span>
        {% endif %}
        {% if discount_rupees > 0 %}
          <span class="pl-ss-chip pl-ss-coupon">Coupon &minus;&#8377;{{ discount_rupees }}</span>
        {% endif %}
      </div>

      <!-- Security line -->
      <p class="pl-sticky-secure">&#128274; Secure &middot; Delivery in 4&ndash;5 days</p>
    </div>

    <!-- RIGHT: buy now button (Shiprocket Fastrr only) -->
    <div class="pl-sticky-right">
      <div class="shiprocket-headless pl-sr-wrap pl-sticky-sr" aria-label="Checkout"></div>
      <a href="https://wa.me/918848265849?text=Hi%2C+I+have+a+question+before+ordering"
         target="_blank" rel="noopener noreferrer"
         class="pl-sticky-wa-link"
         aria-label="Chat on WhatsApp">
        &#128242; Need help?
      </a>
    </div>

  </div>
</div>
