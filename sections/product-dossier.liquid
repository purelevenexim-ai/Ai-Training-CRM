{%- capture dossier_content -%}
  {% render 'product-dossier-content', product_handle: product.handle %}
{%- endcapture -%}

{%- if dossier_content != blank or request.design_mode -%}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .product-dossier-{{ section.id }} .product-dossier__shell {
      display: grid;
      gap: 2.4rem;
      padding: clamp(2.4rem, 4vw, 4.8rem);
      border: 0.1rem solid rgba(var(--color-foreground), 0.08);
      border-radius: 3rem;
      background:
        radial-gradient(circle at top left, rgba(212, 130, 26, 0.12), transparent 34%),
        linear-gradient(180deg, rgba(var(--color-foreground), 0.02), rgba(var(--color-foreground), 0.01));
      box-shadow: 0 2.4rem 7rem rgba(27, 58, 48, 0.08);
      overflow: hidden;
    }

    @media screen and (min-width: 990px) {
      .product-dossier-{{ section.id }} .product-dossier__shell {
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.2fr);
        gap: 3.2rem;
        align-items: start;
      }
    }

    .product-dossier-{{ section.id }} .product-dossier__eyebrow {
      margin: 0 0 1.2rem;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #8F5A12;
    }

    .product-dossier-{{ section.id }} .product-dossier__heading {
      margin: 0;
      font-family: var(--font-heading-family, 'Bodoni Moda', serif);
      font-size: clamp(3rem, 4.1vw, 4.8rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
      color: rgb(var(--color-foreground));
      max-width: 14ch;
    }

    .product-dossier-{{ section.id }} .product-dossier__intro {
      margin: 1.8rem 0 0;
      font-size: 1.65rem;
      line-height: 1.75;
      color: rgba(var(--color-foreground), 0.8);
      max-width: 56rem;
    }

    .product-dossier-{{ section.id }} .product-dossier__ribbon {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      margin: 2rem 0 0;
      padding: 1rem 1.4rem;
      border-radius: 999px;
      background: rgba(27, 94, 86, 0.08);
      color: #1B5E56;
      font-size: 1.25rem;
      line-height: 1.45;
      font-weight: 600;
      max-width: 54rem;
    }

    .product-dossier-{{ section.id }} .product-dossier__grid {
      display: grid;
      gap: 1.4rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-self: stretch;
    }

    .product-dossier-{{ section.id }} .product-dossier__card {
      min-height: 18rem;
      padding: 2rem;
      border-radius: 2.2rem;
      background: rgba(255, 255, 255, 0.76);
      border: 0.1rem solid rgba(var(--color-foreground), 0.08);
      box-shadow: 0 1.2rem 3.2rem rgba(27, 58, 48, 0.05);
      backdrop-filter: blur(8px);
    }

    .product-dossier-{{ section.id }} .product-dossier__index {
      display: inline-flex;
      margin-bottom: 1.8rem;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(var(--color-foreground), 0.48);
    }

    .product-dossier-{{ section.id }} .product-dossier__label {
      margin: 0;
      font-size: 1.6rem;
      font-weight: 700;
      color: rgb(var(--color-foreground));
    }

    .product-dossier-{{ section.id }} .product-dossier__copy {
      margin: 0.9rem 0 0;
      font-size: 1.45rem;
      line-height: 1.7;
      color: rgba(var(--color-foreground), 0.78);
    }

    .product-dossier-{{ section.id }} .product-dossier__placeholder {
      padding: 2.4rem;
      border-radius: 2rem;
      border: 0.1rem dashed rgba(var(--color-foreground), 0.2);
      color: rgba(var(--color-foreground), 0.7);
    }

    @media screen and (max-width: 749px) {
      .product-dossier-{{ section.id }} .product-dossier__grid {
        grid-template-columns: 1fr;
      }

      .product-dossier-{{ section.id }} .product-dossier__heading {
        max-width: none;
      }
    }
  {%- endstyle -%}

  <div class="color-{{ section.settings.color_scheme }} gradient product-dossier-{{ section.id }}">
    <section class="page-width section-{{ section.id }}-padding" aria-label="Product dossier">
      {%- if dossier_content != blank -%}
        {{ dossier_content }}
      {%- elsif request.design_mode -%}
        <div class="product-dossier__placeholder">Add product dossier content here to enrich the page with stronger product-specific storytelling and buying guidance.</div>
      {%- endif -%}
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product dossier",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Product dossier"
    }
  ]
}
{% endschema %}