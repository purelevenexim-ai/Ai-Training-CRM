{%- assign eyebrow = '' -%}
{%- assign heading = '' -%}
{%- assign intro = '' -%}
{%- assign ribbon = '' -%}
{%- assign metafield_cards = blank -%}
{%- assign card_1_title = '' -%}
{%- assign card_1_body = '' -%}
{%- assign card_2_title = '' -%}
{%- assign card_2_body = '' -%}
{%- assign card_3_title = '' -%}
{%- assign card_3_body = '' -%}
{%- assign card_4_title = '' -%}
{%- assign card_4_body = '' -%}

{%- assign product_dossier_metaobject = product.metafields.custom.product_dossier_entry.value -%}
{%- if product_dossier_metaobject != blank -%}
  {%- assign heading = product_dossier_metaobject.heading.value | default: product_dossier_metaobject.heading -%}
  {%- if heading != blank -%}
    {%- assign eyebrow = product_dossier_metaobject.eyebrow.value | default: product_dossier_metaobject.eyebrow -%}
    {%- assign intro = product_dossier_metaobject.intro.value | default: product_dossier_metaobject.intro -%}
    {%- assign ribbon = product_dossier_metaobject.ribbon.value | default: product_dossier_metaobject.ribbon -%}
    {%- assign card_1_title = product_dossier_metaobject.card_1_title.value | default: product_dossier_metaobject.card_1_title -%}
    {%- assign card_1_body = product_dossier_metaobject.card_1_body.value | default: product_dossier_metaobject.card_1_body -%}
    {%- assign card_2_title = product_dossier_metaobject.card_2_title.value | default: product_dossier_metaobject.card_2_title -%}
    {%- assign card_2_body = product_dossier_metaobject.card_2_body.value | default: product_dossier_metaobject.card_2_body -%}
    {%- assign card_3_title = product_dossier_metaobject.card_3_title.value | default: product_dossier_metaobject.card_3_title -%}
    {%- assign card_3_body = product_dossier_metaobject.card_3_body.value | default: product_dossier_metaobject.card_3_body -%}
    {%- assign card_4_title = product_dossier_metaobject.card_4_title.value | default: product_dossier_metaobject.card_4_title -%}
    {%- assign card_4_body = product_dossier_metaobject.card_4_body.value | default: product_dossier_metaobject.card_4_body -%}
  {%- endif -%}
{%- endif -%}

{%- assign product_dossier_metafield = product.metafields.custom.product_dossier.value -%}
{%- if heading == blank and product_dossier_metafield != blank and product_dossier_metafield.heading != blank -%}
  {%- assign eyebrow = product_dossier_metafield.eyebrow -%}
  {%- assign heading = product_dossier_metafield.heading -%}
  {%- assign intro = product_dossier_metafield.intro -%}
  {%- assign ribbon = product_dossier_metafield.ribbon -%}
  {%- assign metafield_cards = product_dossier_metafield.cards -%}
{%- endif -%}

{%- if heading == blank -%}
  {%- case product_handle -%}
    {%- when 'kerala-cardamom-online-100gm' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'Built for kitchens that want cardamom to smell alive the moment the pod opens.' -%}
      {%- assign intro = 'This larger pack leans into what matters with cardamom: pod size, aroma retention, and enough volume for repeat chai, dessert, and masala use.' -%}
      {%- assign ribbon = 'Best in chai, rice dishes, desserts, and regular whole-spice use.' -%}
      {%- assign card_1_title = 'Source language' -%}
      {%- assign card_1_body = 'Positioned around Kerala and Munnar high-range sourcing instead of anonymous mixed-origin stock.' -%}
      {%- assign card_2_title = 'Why 8mm matters' -%}
      {%- assign card_2_body = 'Larger pods usually mean stronger aroma and a more premium whole-cardamom experience.' -%}
      {%- assign card_3_title = 'Flavor behavior' -%}
      {%- assign card_3_body = 'A sweet, cooling lift that shows up best when pods are cracked close to use time.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'The larger refill size makes more sense for kitchens that use cardamom regularly rather than as an occasional garnish.' -%}
    {%- when 'kerala-cardamom-200gm' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'A smaller cardamom pack with the same whole-pod logic, just less commitment.' -%}
      {%- assign intro = 'This version keeps the same 8mm whole-pod positioning but suits buyers who want freshness in a lighter-use pack.' -%}
      {%- assign ribbon = 'Best for home chai, sweets, and buyers trying the product for the first time.' -%}
      {%- assign card_1_title = 'Source language' -%}
      {%- assign card_1_body = 'Kerala / Munnar positioning gives the product a stronger identity than generic elaichi listings.' -%}
      {%- assign card_2_title = 'Why 8mm matters' -%}
      {%- assign card_2_body = 'Bigger pods usually retain more aroma and feel meaningfully different when used whole.' -%}
      {%- assign card_3_title = 'Freshness logic' -%}
      {%- assign card_3_body = 'A smaller pack helps lighter-use kitchens finish the product while aroma is still strong.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'This size works better for everyday home use when you want less stock sitting too long in the kitchen cupboard.' -%}
    {%- when 'kerala-black-pepper-200gm' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'The kind of pepper that only starts talking after the grinder turns.' -%}
      {%- assign intro = 'Whole-pepper logic is the real story here: hold aroma in the peppercorn, crack it fresh, and let the heat open in the pan instead of fading in the pouch.' -%}
      {%- assign ribbon = 'Best for grinder refills, finishing, soups, marinades, and daily seasoning.' -%}
      {%- assign card_1_title = 'Source language' -%}
      {%- assign card_1_body = 'Kerala black pepper gives the product a clearer regional identity than broad commodity pepper listings.' -%}
      {%- assign card_2_title = 'Format advantage' -%}
      {%- assign card_2_body = 'Whole peppercorns keep volatile aroma compounds locked in longer than pre-ground pepper.' -%}
      {%- assign card_3_title = 'Flavor profile' -%}
      {%- assign card_3_body = 'Expect sharper heat, more lift, and a fresher finish when ground close to serving.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'This 200gm size sits in the sweet spot for regular home use without feeling like bulk kitchen stock.' -%}
    {%- when 'kerala-black-pepper-350gm' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'A pepper refill pack for kitchens that burn through grinders instead of collecting spice jars.' -%}
      {%- assign intro = 'The bigger pack is not just about quantity. It is for cooks who use pepper constantly and want whole-corn freshness with better refill economics.' -%}
      {%- assign ribbon = 'Best for frequent cooks, larger households, and refill-led kitchen use.' -%}
      {%- assign card_1_title = 'Source language' -%}
      {%- assign card_1_body = 'Kerala provenance gives the pack more identity than generic bulk pepper sold only on price.' -%}
      {%- assign card_2_title = 'Format advantage' -%}
      {%- assign card_2_body = 'Whole peppercorns still matter more than size; the value pack only works because the format protects aroma.' -%}
      {%- assign card_3_title = 'Kitchen behavior' -%}
      {%- assign card_3_body = 'This is the practical choice if your grinder is always in use and pepper disappears quickly in savory cooking.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'The larger size is for volume and refill convenience, not for occasional cooks who use pepper rarely.' -%}
    {%- when 'kerala-clove-100gm' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'Clove works best when the bud still looks serious before it ever touches the pot.' -%}
      {%- assign intro = 'Whole-bud quality, warm aroma, and visible freshness are the main reasons to choose this smaller Kerala clove pack over generic spice shelf stock.' -%}
      {%- assign ribbon = 'Best for chai, biryani, masala blends, and smaller household use.' -%}
      {%- assign card_1_title = 'Source language' -%}
      {%- assign card_1_body = 'Adimali and Kerala positioning gives the product a stronger identity than vague whole-clove listings.' -%}
      {%- assign card_2_title = 'Whole-bud quality' -%}
      {%- assign card_2_body = 'You want cloves that still look intact and smell assertive when pressed or broken.' -%}
      {%- assign card_3_title = 'Flavor profile' -%}
      {%- assign card_3_body = 'Warm, sweet-spicy intensity that works in both slow-cooked dishes and small aromatic infusions like chai.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = '100gm suits kitchens that want cloves available without sitting on a big refill pack for too long.' -%}
    {%- when 'kerala-clove-200gm' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'A bigger clove pack only makes sense when the aroma still feels worth opening.' -%}
      {%- assign intro = 'This version leans into the same whole-bud quality story but makes more sense for kitchens that use clove often in chai, rice, and masala work.' -%}
      {%- assign ribbon = 'Best for repeat clove use, spice blends, and larger family kitchens.' -%}
      {%- assign card_1_title = 'Source language' -%}
      {%- assign card_1_body = 'Kerala / Adimali context helps position the spice as more than just another unlabeled clove pouch.' -%}
      {%- assign card_2_title = 'Whole-bud quality' -%}
      {%- assign card_2_body = 'The visual cue still matters: intact cloves generally feel fresher and more useful than broken stock.' -%}
      {%- assign card_3_title = 'Aroma behavior' -%}
      {%- assign card_3_body = 'The product should feel deep and sweet-spicy enough to perfume a pot quickly when heated.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'A larger pouch is the right move only if cloves are already part of the weekly cooking rhythm.' -%}
    {%- when 'kerala-white-pepper' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'White pepper earns its place by being more precise, not louder.' -%}
      {%- assign intro = 'The point of white pepper is smoother heat and a cleaner finish in dishes where black pepper can feel visually or aromatically too blunt.' -%}
      {%- assign ribbon = 'Best for soups, sauces, noodles, marinades, and lighter-colored dishes.' -%}
      {%- assign card_1_title = 'Flavor logic' -%}
      {%- assign card_1_body = 'This is about smoother warmth and an earthier finish rather than the brighter spike of black pepper.' -%}
      {%- assign card_2_title = 'Kitchen fit' -%}
      {%- assign card_2_body = 'White pepper is useful when you want pepper presence without visible dark specks or a rougher finish.' -%}
      {%- assign card_3_title = 'Regional identity' -%}
      {%- assign card_3_body = 'Kerala / Western Ghats positioning gives the product a clearer provenance story than generic pepper listings.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'The value is in culinary precision, so the right buyer is someone who knows where white pepper performs better than black.' -%}
    {%- when 'cardamom-pepper-clove-combo-pack-special-offer-100-off' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'This bundle works when it behaves like a starter kitchen kit, not a random discount stack.' -%}
      {%- assign intro = 'The smaller combo is strongest when it solves a real kitchen problem: getting three essential spices in one cleaner buying decision.' -%}
      {%- assign ribbon = 'Best for gifting, kitchen setup, and first-time buyers exploring core Kerala spices.' -%}
      {%- assign card_1_title = 'What is inside' -%}
      {%- assign card_1_body = 'Cardamom, black pepper, and clove cover three of the most useful whole-spice needs in one purchase.' -%}
      {%- assign card_2_title = 'Why it is useful' -%}
      {%- assign card_2_body = 'You reduce comparison fatigue and get a more coherent kitchen starting point than buying separate small listings.' -%}
      {%- assign card_3_title = 'Who it fits' -%}
      {%- assign card_3_body = 'The smaller bundle suits gifting, trial, and kitchens that want breadth before committing to larger refill sizes.' -%}
      {%- assign card_4_title = 'Regional identity' -%}
      {%- assign card_4_body = 'It works best when buyers understand it as a Kerala spice trio rather than only a price-led combo.' -%}
    {%- when 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack-copy' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'The larger combo makes sense when the kitchen is already active, not theoretical.' -%}
      {%- assign intro = 'This is the bundle for kitchens that know these spices will move. The bigger pack works because it matches repeat use rather than impulse buying.' -%}
      {%- assign ribbon = 'Best for larger households, repeat cooks, and kitchen refills with bundle convenience.' -%}
      {%- assign card_1_title = 'What is inside' -%}
      {%- assign card_1_body = 'Higher quantities across the same core spice trio give the bundle a stronger kitchen-refill case than the starter pack.' -%}
      {%- assign card_2_title = 'Why it is useful' -%}
      {%- assign card_2_body = 'The value is convenience plus volume, especially when you already use cardamom, pepper, and clove regularly.' -%}
      {%- assign card_3_title = 'Who it fits' -%}
      {%- assign card_3_body = 'This size is better for families and repeat cooks than for light-use or occasional spice buyers.' -%}
      {%- assign card_4_title = 'Regional identity' -%}
      {%- assign card_4_body = 'The bundle feels stronger when framed as a Kerala kitchen trio rather than a generic bulk combo.' -%}
    {%- when 'premium-cassia-cinnamon-100g' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'Cassia wins when you want cinnamon to announce itself instead of whispering.' -%}
      {%- assign intro = 'This page should make the style clear: warmer, bolder, and more assertive than Ceylon, especially in chai, baking, and savory spice work.' -%}
      {%- assign ribbon = 'Best for chai, cakes, cookies, breakfast bowls, and savory blends that need stronger warmth.' -%}
      {%- assign card_1_title = 'Style of cinnamon' -%}
      {%- assign card_1_body = 'Cassia is the stronger, warmer branch of the category and should be sold with that confidence.' -%}
      {%- assign card_2_title = 'Where it wins' -%}
      {%- assign card_2_body = 'It holds its own in milk tea, spiced baking, porridges, and richer savory preparations.' -%}
      {%- assign card_3_title = 'Buyer expectation' -%}
      {%- assign card_3_body = 'People choosing cassia usually want intensity, not delicacy.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'A 100g pack suits kitchens that actually use cinnamon often enough to justify a bolder everyday option.' -%}
    {%- when 'aromatic-true-cinnamon-ceylon-100g' -%}
      {%- assign eyebrow = 'Kitchen dossier' -%}
      {%- assign heading = 'True cinnamon deserves a softer, more exact story than standard cinnamon packs.' -%}
      {%- assign intro = 'The value of Ceylon is not loudness. It is sweetness, finesse, and the ability to add warmth without overpowering tea, desserts, or fruit-led recipes.' -%}
      {%- assign ribbon = 'Best for tea, desserts, fruit, subtle baking, and buyers who want a gentler cinnamon profile.' -%}
      {%- assign card_1_title = 'Style of cinnamon' -%}
      {%- assign card_1_body = 'Ceylon sits on the lighter, sweeter, and more delicate end of the cinnamon spectrum.' -%}
      {%- assign card_2_title = 'Where it wins' -%}
      {%- assign card_2_body = 'It works especially well in tea, yogurt, fruit, pastry, and recipes where heavy cinnamon would dominate.' -%}
      {%- assign card_3_title = 'Buyer expectation' -%}
      {%- assign card_3_body = 'People choosing true cinnamon usually want refinement, not brute spice intensity.' -%}
      {%- assign card_4_title = 'Pack logic' -%}
      {%- assign card_4_body = 'The product makes most sense for buyers who care about style difference, not only category label.' -%}
  {%- endcase -%}
{%- endif -%}

{%- if heading != blank -%}
  <div class="product-dossier__shell">
    <div class="product-dossier__lead">
      <p class="product-dossier__eyebrow">{{ eyebrow | escape }}</p>
      <h2 class="product-dossier__heading">{{ heading }}</h2>
      <p class="product-dossier__intro">{{ intro }}</p>
      <p class="product-dossier__ribbon">{{ ribbon }}</p>
    </div>

    <div class="product-dossier__grid">
      {%- if metafield_cards != blank -%}
        {%- for card in metafield_cards -%}
          {%- if card.title != blank and card.body != blank -%}
            <article class="product-dossier__card">
              <span class="product-dossier__index">0{{ forloop.index }}</span>
              <p class="product-dossier__label">{{ card.title }}</p>
              <p class="product-dossier__copy">{{ card.body }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <article class="product-dossier__card">
          <span class="product-dossier__index">01</span>
          <p class="product-dossier__label">{{ card_1_title }}</p>
          <p class="product-dossier__copy">{{ card_1_body }}</p>
        </article>
        <article class="product-dossier__card">
          <span class="product-dossier__index">02</span>
          <p class="product-dossier__label">{{ card_2_title }}</p>
          <p class="product-dossier__copy">{{ card_2_body }}</p>
        </article>
        <article class="product-dossier__card">
          <span class="product-dossier__index">03</span>
          <p class="product-dossier__label">{{ card_3_title }}</p>
          <p class="product-dossier__copy">{{ card_3_body }}</p>
        </article>
        <article class="product-dossier__card">
          <span class="product-dossier__index">04</span>
          <p class="product-dossier__label">{{ card_4_title }}</p>
          <p class="product-dossier__copy">{{ card_4_body }}</p>
        </article>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}