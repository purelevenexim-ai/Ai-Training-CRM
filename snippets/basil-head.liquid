{%- comment -%}
  Basil Commerce OS — Head Bootstrap
  Phase 1: Event gateway config + cart asset injection
  Target: Coffee Page QA theme only
{%- endcomment -%}

{%- liquid
  comment
    Feature flags (will be migrated to PostgreSQL → Metafields in Phase 2)
    These are the theme-level defaults until the backend runtime config is live.
  endcomment
  assign basil_feature_smart_cart       = true
  assign basil_feature_event_gateway    = true
  assign basil_feature_reward_engine    = true
  assign basil_feature_checkout_prep    = settings.basil_checkout_prep_enabled | default: false
  assign basil_feature_analytics        = true

  comment
    Tracking IDs — sourced from theme settings or hard-coded until metafield cache is built
  endcomment
  assign basil_meta_pixel_id  = settings.basil_meta_pixel_id  | default: '609256704464862'
  assign basil_ga4_id         = settings.basil_ga4_id         | default: 'G-3FRSK7TEN2'
  assign basil_event_endpoint = settings.basil_event_endpoint | default: ''

  comment
    Reward thresholds (paise) — mirrors main-cart-footer.liquid
  endcomment
  assign basil_threshold_ship = 64900
  assign basil_threshold_mid  = 99900
  assign basil_threshold_gift = 144900
-%}

{%- if basil_feature_smart_cart -%}
  {{ 'basil-cart.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- render 'basil-analytics-head' -%}

<script>
  window.__BASIL__ = {
    version: '1.0.0',
    phase: 4,
    shopDomain: {{ shop.domain | json }},
    currency: {{ cart.currency.iso_code | json }},
    customerId: {{ customer.id | json }},
    customerEmail: {{ customer.email | json }},
    cartToken: {{ cart.token | json }},
    locale: {{ request.locale.iso_code | json }},
    metaPixelId: {{ basil_meta_pixel_id | json }},
    ga4Id: {{ basil_ga4_id | json }},
    eventEndpoint: {{ basil_event_endpoint | json }},
    features: {
      smartCart:     {{ basil_feature_smart_cart | json }},
      eventGateway:  {{ basil_feature_event_gateway | json }},
      rewardEngine:  {{ basil_feature_reward_engine | json }},
      checkoutPrep:  {{ basil_feature_checkout_prep | json }},
      analytics:     {{ basil_feature_analytics | json }}
    },
    rewards: {
      thresholdShip: {{ basil_threshold_ship }},
      thresholdMid:  {{ basil_threshold_mid }},
      thresholdGift: {{ basil_threshold_gift }}
    }
  };
</script>

{%- if basil_feature_smart_cart -%}
  <script src="{{ 'basil-cart.js' | asset_url }}" defer></script>
{%- endif -%}
