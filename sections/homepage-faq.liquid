<style>
.pl-faq {
  background: linear-gradient(180deg, #F8F5EE 0%, #FFFFFF 40%);
}
.pl-faq__container {
  max-width: 820px;
  margin: 0 auto;
  padding: 0 2.4rem;
}
.pl-faq__header {
  text-align: center;
  margin-bottom: 4rem;
}
.pl-faq__eyebrow {
  display: inline-block;
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 1.15rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #D4821A;
  margin: 0 0 1rem 0;
}
.pl-faq__heading {
  font-family: var(--font-heading-family, 'Bodoni Moda', serif);
  font-size: clamp(2.6rem, 4vw, 3.6rem);
  font-weight: 400;
  color: #1B3A30;
  margin: 0 0 1rem 0;
  letter-spacing: -0.01em;
  line-height: 1.2;
}
.pl-faq__subtitle {
  font-size: 1.5rem;
  color: #6B7B78;
  margin: 0;
  line-height: 1.65;
  font-family: var(--font-body-family, 'Inter', sans-serif);
}
.pl-faq__list {
  background: #FFFFFF;
  border-radius: 20px;
  box-shadow: 0 4px 24px rgba(27, 94, 86, 0.07);
  overflow: hidden;
  border: 1.5px solid #E8E5DC;
}
.pl-faq__item {
  border-bottom: 1px solid #EEE9E0;
  transition: background 0.2s ease;
}
.pl-faq__item:last-child { border-bottom: none; }
.pl-faq__item[open] {
  background: #F5FBF9;
}
.pl-faq__question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 2.2rem 2.8rem;
  cursor: pointer;
  list-style: none;
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 1.55rem;
  font-weight: 500;
  color: #1B3A30;
  line-height: 1.5;
  user-select: none;
  transition: color 0.2s ease;
}
.pl-faq__question::-webkit-details-marker { display: none; }
.pl-faq__question:hover { color: #1B5E56; }
.pl-faq__chevron {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  background: #E8F5F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1B5E56;
  transition: transform 0.25s ease, background 0.2s ease;
  padding: 4px;
  box-sizing: border-box;
}
.pl-faq__item[open] .pl-faq__chevron {
  transform: rotate(180deg);
  background: #1B5E56;
  color: #FFFFFF;
}
.pl-faq__item[open] .pl-faq__question {
  color: #1B5E56;
  font-weight: 600;
}
.pl-faq__answer {
  padding: 0 2.8rem 2.4rem;
  border-left: 3px solid #1B5E56;
  margin: 0 2.8rem 0 2.8rem;
  padding-left: 1.6rem;
  margin-bottom: 2rem;
}
.pl-faq__answer p {
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 1.45rem;
  color: #5A6B67;
  line-height: 1.8;
  margin: 0;
}
.pl-faq__answer strong {
  color: #1B3A30;
}
.pl-faq__answer a {
  color: #1B5E56;
  font-weight: 500;
  text-decoration: underline;
  text-decoration-color: rgba(27, 94, 86, 0.35);
  text-underline-offset: 2px;
  transition: text-decoration-color 0.2s;
}
.pl-faq__answer a:hover {
  text-decoration-color: #1B5E56;
}
@media (max-width: 749px) {
  .pl-faq__question { padding: 1.8rem 1.8rem; }
  .pl-faq__answer { margin: 0 1.8rem 1.8rem; }
}
</style>

{% schema %}
{
  "name": "FAQ Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "FAQ Section"
    }
  ]
}
{% endschema %}
