{% comment %} pl-milestone-bar.liquid — Pure Leven Cart v3 — 3-tier {% endcomment %}

{%- assign ship_threshold = settings.basil_cart_free_delivery_threshold | default: settings.free_shipping_threshold | default: 649 -%}
{%- assign mid_threshold  = settings.basil_cart_mid_threshold | default: settings.cart_mid_threshold | default: 999 -%}
{%- assign top_threshold  = settings.basil_cart_gift_threshold | default: settings.gift_threshold | default: 1449 -%}
{%- assign mid_discount   = settings.basil_cart_mid_discount | default: 100 -%}
{%- assign top_discount   = settings.basil_cart_gift_discount | default: 200 -%}

<div class="pl-ms-card"
     id="pl-ms-bar"
     data-sub="{{ cart.total_price }}"
     data-ship="{{ ship_threshold | times: 100 }}"
     data-mid="{{ mid_threshold | times: 100 }}"
     data-gift="{{ top_threshold | times: 100 }}"
     data-ship-label="FREE Delivery"
     data-mid-label="₹{{ mid_discount }} off"
     data-gift-label="₹{{ top_discount }} off + Free Gift">

  <p class="pl-ms-title" id="pl-ms-title">Add ₹{{ ship_threshold }} for FREE Delivery 🚚</p>

  <div class="pl-ms-track-outer">
    <div class="pl-ms-track">
      <div class="pl-ms-fill" id="pl-ms-fill" style="width:0%"></div>
      <span class="pl-ms-node pl-ms-node-ship" id="pl-ms-node-ship" aria-hidden="true"></span>
      <span class="pl-ms-node pl-ms-node-mid" id="pl-ms-node-mid" aria-hidden="true"></span>
      <span class="pl-ms-node pl-ms-node-top" id="pl-ms-node-top" aria-hidden="true"></span>
    </div>
  </div>
</div>
