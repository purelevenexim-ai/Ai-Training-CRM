{%- liquid
  assign divider_label = section.settings.heading | strip_html | strip
  if divider_label == blank
    assign divider_label = section.settings.eyebrow | strip
  endif
  if divider_label == blank
    assign divider_label = 'Section divider'
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .pureleven-section-divider-{{ section.id }} {
    background: transparent;
  }

  .pureleven-section-divider-{{ section.id }}.pureleven-section-divider--cream {
    background: #f8f5ee;
  }

  .pureleven-section-divider-{{ section.id }}.pureleven-section-divider--white {
    background: #ffffff;
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 2.4rem;
    text-align: center;
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.5rem 1.4rem;
    border-radius: 999px;
    background: #d4821a;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__title {
    margin: 1.6rem 0 1.4rem;
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 600;
    line-height: 1.25;
    color: #1b3a30;
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.6rem;
    margin: 0 0 1.2rem;
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__ornament-line {
    flex: 1;
    max-width: 12rem;
    height: 0.1rem;
    background: linear-gradient(to right, transparent, #b8ddd9);
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__ornament-line:last-child {
    background: linear-gradient(to left, transparent, #b8ddd9);
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__ornament-svg {
    color: #1b5e56;
  }

  .pureleven-section-divider-{{ section.id }} .pl-section-divider__subtitle {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.6;
    color: #5a6b67;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .pureleven-section-divider-{{ section.id }} .pl-section-divider {
      padding: 0 3.2rem;
    }
  }
{%- endstyle -%}

<div class="pureleven-section-divider-{{ section.id }} pureleven-section-divider--{{ section.settings.background_style }}">
  <section class="section-{{ section.id }}-padding" aria-label="{{ divider_label | escape }}">
    {% render 'pureleven-section-divider',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subtitle: section.settings.subtitle,
      icon: section.settings.icon,
      show_ornament: section.settings.show_ornament
    %}
  </section>
</div>

{% schema %}
{
  "name": "Pureleven Section Divider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best Value"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Kerala Spice Combo Packs"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Bundle and save - farm-direct value"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Ornament icon",
      "default": "seed",
      "options": [
        {
          "value": "seed",
          "label": "Seed"
        },
        {
          "value": "star",
          "label": "Star"
        },
        {
          "value": "leaf",
          "label": "Leaf"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_ornament",
      "label": "Show ornament",
      "default": true
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background",
      "default": "cream",
      "options": [
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "cream",
          "label": "Warm cream"
        },
        {
          "value": "white",
          "label": "White"
        }
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Pureleven Section Divider"
    }
  ]
}
{% endschema %}