{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart-total-bar.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign free_delivery_threshold_rupees = settings.basil_cart_free_delivery_threshold | default: 649 | plus: 0
  assign mid_threshold_rupees = settings.basil_cart_mid_threshold | default: 999 | plus: 0
  assign free_gift_threshold_rupees = settings.basil_cart_gift_threshold | default: 1449 | plus: 0
  assign top_threshold_rupees = settings.basil_cart_top_threshold | default: 1999 | plus: 0
  assign free_delivery_threshold = free_delivery_threshold_rupees | times: 100
  assign mid_threshold = mid_threshold_rupees | times: 100
  assign free_gift_threshold = free_gift_threshold_rupees | times: 100
  assign top_threshold = top_threshold_rupees | times: 100
  assign mid_discount = settings.basil_cart_mid_discount | default: 100 | plus: 0
  assign gift_discount = settings.basil_cart_gift_discount | default: 200 | plus: 0
  assign top_discount = settings.basil_cart_top_discount | default: 400 | plus: 0
  assign cart_total = cart.total_price
  assign free_delivery_unlocked = false
  assign mid_unlocked = false
  assign free_gift_unlocked = false
  assign top_unlocked = false
  assign free_delivery_remaining = free_delivery_threshold | minus: cart_total
  assign mid_remaining = mid_threshold | minus: cart_total
  assign free_gift_remaining = free_gift_threshold | minus: cart_total
  assign top_remaining = top_threshold | minus: cart_total
  assign reward_progress = 0

  if free_delivery_remaining < 0
    assign free_delivery_remaining = 0
  endif

  if mid_remaining < 0
    assign mid_remaining = 0
  endif

  if free_gift_remaining < 0
    assign free_gift_remaining = 0
  endif

  if top_remaining < 0
    assign top_remaining = 0
  endif

  if cart_total >= free_delivery_threshold
    assign free_delivery_unlocked = true
  endif

  if cart_total >= mid_threshold
    assign mid_unlocked = true
  endif

  if cart_total >= free_gift_threshold
    assign free_gift_unlocked = true
  endif

  if cart_total >= top_threshold
    assign top_unlocked = true
  endif

  if cart_total > 0
    if cart_total < mid_threshold
      assign reward_progress = cart_total | times: 25 | divided_by: mid_threshold
    elsif cart_total < free_gift_threshold
      assign reward_segment = free_gift_threshold | minus: mid_threshold
      assign reward_progress = cart_total | minus: mid_threshold
      assign reward_progress = reward_progress | times: 25 | divided_by: reward_segment
      assign reward_progress = reward_progress | plus: 25
    elsif cart_total < top_threshold
      assign reward_segment = top_threshold | minus: free_gift_threshold
      assign reward_progress = cart_total | minus: free_gift_threshold
      assign reward_progress = reward_progress | times: 25 | divided_by: reward_segment
      assign reward_progress = reward_progress | plus: 50
    else
      assign reward_progress = 75
    endif
  endif

  if reward_progress > 75
    assign reward_progress = 75
  endif

  assign pill_prefix = settings.basil_cart_pill_tag_prefix | default: 'pill:'
  assign pill_prefix_len = pill_prefix | size
-%}

<cart-items class="gradient color-{{ section.settings.color_scheme }} isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}">
  <div class="page-width">
    {%- if cart != empty -%}
      <div class="basil-cart-mobile-review" aria-label="Customer review">
        <span class="basil-cart-mobile-review__stars" aria-hidden="true">★★★★★</span>
        <p class="basil-cart-mobile-review__quote">"{{ settings.basil_cart_review_quote | default: 'Very fresh aroma compared to supermarket spices. You can feel the difference!' | escape }}"</p>
        <span class="basil-cart-mobile-review__author">— {{ settings.basil_cart_review_author | default: 'Mary, Kochi' | escape }}</span>
      </div>
    {%- endif -%}

    <div class="title-wrapper-with-link">
      <h1 class="title title--primary">
        {{ 'sections.cart.title' | t }}
        <span class="cart-header-badge">🌿 {{ settings.basil_cart_freshness_badge | default: 'Packed fresh in Kerala' }}</span>
      </h1>
      <a href="{{ routes.all_products_collection_url }}" class="underlined-link">
        {{- 'general.continue_shopping' | t -}}
      </a>
    </div>

    <div id="basil-cart-hero-region" class="basil-cart-hero-region">
      {%- if cart != empty -%}
        <section
          class="basil-reward-strip"
          aria-label="Cart reward progress"
          data-basil-cart-state
          data-cart-item-count="{{ cart.item_count }}"
          data-cart-total="{{ cart.total_price }}"
          data-delivery-threshold="{{ free_delivery_threshold }}"
          data-mid-threshold="{{ mid_threshold }}"
          data-gift-threshold="{{ free_gift_threshold }}"
          data-top-threshold="{{ top_threshold }}"
          data-delivery-unlocked="{{ free_delivery_unlocked }}"
          data-mid-unlocked="{{ mid_unlocked }}"
          data-gift-unlocked="{{ free_gift_unlocked }}"
          data-top-unlocked="{{ top_unlocked }}"
        >

          <div class="basil-reward-strip__head">
            <div class="basil-reward-strip__copy">
              <p class="basil-reward-strip__shipping-note">
                All orders above ₹{{ free_delivery_threshold_rupees }} get free shipping
                {%- if free_delivery_unlocked -%}
                  <span class="basil-reward-strip__shipping-badge">Unlocked</span>
                {%- endif -%}
              </p>
              <p class="basil-reward-strip__status">
              {%- if top_unlocked -%}
                🎉 ₹{{ top_discount }} OFF unlocked
              {%- elsif free_gift_unlocked -%}
                Add {{ top_remaining | money_without_trailing_zeros }} to unlock ₹{{ top_discount }} OFF
              {%- elsif free_delivery_unlocked -%}
                {%- if mid_unlocked -%}
                  Add {{ free_gift_remaining | money_without_trailing_zeros }} to unlock ₹{{ gift_discount }} OFF
                {%- else -%}
                  Add {{ mid_remaining | money_without_trailing_zeros }} to unlock ₹{{ mid_discount }} OFF
                {%- endif -%}
              {%- else -%}
                Add {{ free_delivery_remaining | money_without_trailing_zeros }} for free shipping
              {%- endif -%}
              </p>
            </div>
            <a href="{{ routes.all_products_collection_url }}" class="basil-reward-strip__view-link">View all rewards</a>
          </div>

          <div
            class="basil-reward-strip__track-wrap"
            style="--brs-fill: {{ reward_progress }}%;"
          >
            <div class="basil-reward-strip__bar" role="presentation" aria-hidden="true">
              <span class="basil-reward-strip__fill"></span>
              <span class="basil-reward-strip__node basil-reward-strip__node--mid{% if mid_unlocked %} is-unlocked{% endif %}" style="left: 25%">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="8" width="18" height="14" rx="1" stroke="currentColor" stroke-width="2"/><path d="M3 8h18M12 8V22M8 8c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="2"/></svg>
              </span>
              <span class="basil-reward-strip__node basil-reward-strip__node--gift{% if free_gift_unlocked %} is-unlocked{% endif %}" style="left: 50%">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="8" width="18" height="14" rx="1" stroke="currentColor" stroke-width="2"/><path d="M3 8h18M12 8V22M8 8c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="2"/></svg>
              </span>
              <span class="basil-reward-strip__node basil-reward-strip__node--top{% if top_unlocked %} is-unlocked{% endif %}" style="left: 75%">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="8" width="18" height="14" rx="1" stroke="currentColor" stroke-width="2"/><path d="M3 8h18M12 8V22M8 8c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="2"/></svg>
              </span>
              <span class="basil-reward-strip__node basil-reward-strip__node--tail" style="left: 100%" aria-hidden="true"></span>
            </div>

            <div class="basil-reward-strip__milestones">
              <div class="basil-reward-strip__milestone basil-reward-strip__milestone--mid{% if mid_unlocked %} is-unlocked{% else %} is-active{% endif %}" style="left: 25%">
                <strong>₹{{ mid_threshold_rupees }}</strong>
                <span>+ ₹{{ mid_discount }} OFF</span>
              </div>
              <div class="basil-reward-strip__milestone basil-reward-strip__milestone--gift{% if free_gift_unlocked %} is-unlocked{% elsif mid_unlocked %} is-active{% endif %}" style="left: 50%">
                <strong>₹{{ free_gift_threshold_rupees }}</strong>
                <span>+ ₹{{ gift_discount }} OFF</span>
              </div>
              <div class="basil-reward-strip__milestone basil-reward-strip__milestone--top{% if top_unlocked %} is-unlocked{% elsif free_gift_unlocked %} is-active{% endif %}" style="left: 75%">
                <strong>₹{{ top_threshold_rupees }}</strong>
                <span>+ ₹{{ top_discount }} OFF</span>
              </div>
            </div>
          </div>
        </section>

        <div class="basil-cart-toast" data-basil-cart-toast aria-live="polite" aria-hidden="true">
          <span data-basil-cart-toast-copy>{{ settings.basil_cart_add_toast | default: 'Cart updated' }}</span>
        </div>

        <script>
        document.addEventListener('DOMContentLoaded', function () {
          var state = document.querySelector('[data-basil-cart-state]');
          var toast = document.querySelector('[data-basil-cart-toast]');

          if (!state) return;

          var storageKey = 'basil-cart:reward-state';
          var deliveryThreshold = Number(state.dataset.deliveryThreshold || 0);
          var midThreshold = Number(state.dataset.midThreshold || 0);
          var giftThreshold = Number(state.dataset.giftThreshold || 0);
          var topThreshold = Number(state.dataset.topThreshold || 0);

          function readCurrent(cartData) {
            var total = Number((cartData && cartData.total_price) || document.querySelector('[data-basil-cart-state]')?.dataset.cartTotal || 0);
            var itemCount = Number((cartData && cartData.item_count) || document.querySelector('[data-basil-cart-state]')?.dataset.cartItemCount || 0);

            return {
              itemCount: itemCount,
              cartTotal: total,
              deliveryUnlocked: total >= deliveryThreshold,
              midUnlocked: total >= midThreshold,
              giftUnlocked: total >= giftThreshold,
              topUnlocked: total >= topThreshold
            };
          }

          function showMotion(message) {
            if (!message || !toast) return;

            toast.querySelector('[data-basil-cart-toast-copy]').textContent = message;
            toast.setAttribute('aria-hidden', 'false');
            window.setTimeout(function () {
              toast.setAttribute('aria-hidden', 'true');
            }, 3200);
          }

          function handleTransition(currentState, previousState) {
            if (!previousState) return;

            var classList = document.documentElement.classList;
            classList.remove('basil-cart-gift-unlocked', 'basil-cart-delivery-unlocked', 'basil-cart-top-unlocked');

            if (!previousState.topUnlocked && currentState.topUnlocked) {
              classList.add('basil-cart-top-unlocked');
              showMotion('₹{{ top_discount }} OFF unlocked 🎉');
            } else if (!previousState.giftUnlocked && currentState.giftUnlocked) {
              classList.add('basil-cart-gift-unlocked');
              showMotion('₹{{ gift_discount }} OFF unlocked 🎉');
            } else if (!previousState.midUnlocked && currentState.midUnlocked) {
              classList.add('basil-cart-delivery-unlocked');
              showMotion('₹{{ mid_discount }} OFF unlocked 🎉');
            } else if (!previousState.deliveryUnlocked && currentState.deliveryUnlocked) {
              classList.add('basil-cart-delivery-unlocked');
              showMotion({{ settings.basil_cart_delivery_unlocked_toast | default: 'Free delivery unlocked' | json }});
            }
          }

          var current = readCurrent();
          var previous = null;

          try {
            previous = JSON.parse(window.localStorage.getItem(storageKey) || 'null');
          } catch (error) {
            previous = null;
          }

          handleTransition(current, previous);

          try {
            window.localStorage.setItem(storageKey, JSON.stringify(current));
          } catch (error) {}

          if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.cartUpdate) {
            subscribe(PUB_SUB_EVENTS.cartUpdate, function (event) {
              var previousState = null;

              try {
                previousState = JSON.parse(window.localStorage.getItem(storageKey) || 'null');
              } catch (error) {
                previousState = null;
              }

              var nextState = readCurrent(event && event.cartData);
              handleTransition(nextState, previousState);

              try {
                window.localStorage.setItem(storageKey, JSON.stringify(nextState));
              } catch (error) {}
            });
          }
        });
        </script>
      {%- endif -%}
    </div>

    <div class="cart__warnings">
      <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="button">
        {{ 'general.continue_shopping' | t }}
      </a>

      {%- if shop.customer_accounts_enabled and customer == null -%}
        <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
        <p class="cart__login-paragraph">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}
            <table class="cart-items">
              <caption class="visually-hidden">
                {{ 'sections.cart.title' | t }}
              </caption>
              <thead>
                <tr>
                  <th class="caption-with-letter-spacing" colspan="2" scope="col">
                    {{ 'sections.cart.headings.product' | t }}
                  </th>
                  <th class="medium-hide large-up-hide right caption-with-letter-spacing" colspan="1" scope="col">
                    {{ 'sections.cart.headings.total' | t }}
                  </th>
                  <th
                    class="cart-items__heading--wide cart-items__heading--quantity small-hide caption-with-letter-spacing"
                    colspan="1"
                    scope="col"
                  >
                    {{ 'sections.cart.headings.quantity' | t }}
                  </th>
                  <th class="small-hide right caption-with-letter-spacing" colspan="1" scope="col">
                    {{ 'sections.cart.headings.total' | t }}
                  </th>
                </tr>
              </thead>

              <tbody>
                {%- for item in cart.items -%}
                  <tr
                    class="cart-item {% if item.parent_relationship.parent != null %}cart-item__nested-line{% endif %}"
                    id="CartItem-{{ item.index | plus: 1 }}"
                    {% if item.parent_relationship.parent != null %}
                      aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
                    {% endif %}
                  >
                    <td class="cart-item__media">
                      {% if item.image %}
                        {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                        <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"> </a>
                        <div class="cart-item__image-container gradient {% if item.parent_relationship.parent == null %}global-media-settings{% endif %}">
                          <img
                            src="{{ item.image | image_url: width: 300 }}"
                            class="cart-item__image {% if item.parent_relationship.parent != null %}global-media-settings{% endif %}"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="150"
                            height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                          >
                        </div>
                      {% endif %}
                    </td>

                    <td class="cart-item__details">
                      {%- if settings.show_vendor -%}
                        <p class="caption-with-letter-spacing">{{ item.product.vendor }}</p>
                      {%- endif -%}

                      <a href="{{ item.url }}" class="cart-item__name h4 break">{{ item.product.title | escape }}</a>

                      {%- if item.original_price != item.final_price -%}
                        <div class="cart-item__discounted-prices">
                          <span class="visually-hidden">
                            {{ 'products.product.price.regular_price' | t }}
                          </span>
                          <s class="cart-item__old-price product-option">
                            {{- item.original_price | money -}}
                          </s>
                          <span class="visually-hidden">
                            {{ 'products.product.price.sale_price' | t }}
                          </span>
                          <strong class="cart-item__final-price product-option">
                            {{ item.final_price | money }}
                          </strong>
                        </div>
                      {%- else -%}
                        <div class="product-option">
                          {{ item.original_price | money }}
                        </div>
                      {%- endif -%}

                      {%- if item.product.has_only_default_variant == false
                        or item.properties.size != 0
                        or item.selling_plan_allocation != null
                      -%}
                        <dl>
                          {%- if item.product.has_only_default_variant == false -%}
                            {%- for option in item.options_with_values -%}
                              <div class="product-option">
                                <dt>{{ option.name }}:</dt>
                                <dd>{{ option.value }}</dd>
                              </div>
                            {%- endfor -%}
                          {%- endif -%}

                          {%- for property in item.properties -%}
                            {%- assign property_first_char = property.first | slice: 0 -%}
                            {%- if property.last != blank and property_first_char != '_' -%}
                              <div class="product-option">
                                <dt>{{ property.first }}:</dt>
                                <dd>
                                  {%- if property.last contains '/uploads/' -%}
                                    <a href="{{ property.last }}" class="link" target="_blank">
                                      {{ property.last | split: '/' | last }}
                                    </a>
                                  {%- else -%}
                                    {{ property.last }}
                                  {%- endif -%}
                                </dd>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </dl>

                        <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}

                      {%- comment -%}── Attribute pills from product tags ──{%- endcomment -%}
                      {%- assign has_pills = false -%}
                      {%- for tag in item.product.tags -%}
                        {%- assign tag_start = tag | slice: 0, pill_prefix_len -%}
                        {%- if tag_start == pill_prefix -%}
                          {%- unless has_pills -%}
                            <div class="cart-item__pills">
                          {%- endunless -%}
                          {%- assign has_pills = true -%}
                          <span class="cart-item__pill">{{ tag | remove_first: pill_prefix }}</span>
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if has_pills -%}</div>{%- endif -%}

                      <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                        {%- for discount in item.line_level_discount_allocations -%}
                          <li class="discounts__discount">
                            {{- 'icon-discount.svg' | inline_asset_content -}}
                            {{ discount.discount_application.title | escape }}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </td>

                    <td class="cart-item__totals right medium-hide large-up-hide">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                        {%- if item.original_line_price != item.final_line_price -%}
                          <dl class="cart-item__discounted-prices">
                            <dt class="visually-hidden">
                              {{ 'products.product.price.regular_price' | t }}
                            </dt>
                            <dd>
                              <s class="cart-item__old-price price price--end">
                                {{ item.original_line_price | money }}
                              </s>
                            </dd>
                            <dt class="visually-hidden">
                              {{ 'products.product.price.sale_price' | t }}
                            </dt>
                            <dd class="price price--end">
                              {{ item.final_line_price | money }}
                            </dd>
                          </dl>
                        {%- else -%}
                          <span class="price price--end">
                            {{ item.original_line_price | money }}
                          </span>
                        {%- endif -%}

                        {%- if item.variant.available and item.unit_price_measurement -%}
                          {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                        {%- endif -%}
                      </div>
                    </td>
                    {%- liquid
                      assign has_qty_rules = false
                      if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                        assign has_qty_rules = true
                      endif

                      assign has_vol_pricing = false
                      if item.variant.quantity_price_breaks.size > 0
                        assign has_vol_pricing = true
                      endif
                    -%}
                    <td class="cart-item__quantity{% if has_qty_rules or has_vol_pricing %} cart-item__quantity--info{% endif %}">
                      <quantity-popover>
                        <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                          <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                            {{ 'products.product.quantity.label' | t }}
                          </label>
                          <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button
                                type="button"
                                aria-expanded="false"
                                class="quantity-popover__info-button quantity-popover__info-button--icon-only button button--tertiary small-hide medium-hide"
                              >
                                {{- 'icon-info.svg' | inline_asset_content -}}
                              </button>
                            {%- endif -%}
                            <quantity-input class="quantity cart-quantity">
                              {% assign can_update_quantity = item.instructions.can_update_quantity | default: true %}
                              <button
                                class="quantity__button"
                                name="minus"
                                type="button"
                                {% if can_update_quantity == false %}
                                  disabled
                                {% endif %}
                              >
                                <span class="visually-hidden">
                                  {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                                </span>
                                <span class="svg-wrapper">
                                  {{- 'icon-minus.svg' | inline_asset_content -}}
                                </span>
                              </button>
                              <input
                                class="quantity__input"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                type="number"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                {% # theme-check-disable %}
                                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                min="0"
                                data-min="{{ item.variant.quantity_rule.min }}"
                                {% if item.variant.quantity_rule.max != null %}
                                  max="{{ item.variant.quantity_rule.max }}"
                                {% endif %}
                                step="{{ item.variant.quantity_rule.increment }}"
                                {% # theme-check-enable %}
                                aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                id="Quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                                {% if can_update_quantity == false %}
                                  disabled
                                {% endif %}
                              >
                              <button
                                class="quantity__button"
                                name="plus"
                                type="button"
                                {% if can_update_quantity == false %}
                                  disabled
                                {% endif %}
                              >
                                <span class="visually-hidden">
                                  {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                                </span>
                                <span class="svg-wrapper">
                                  {{- 'icon-plus.svg' | inline_asset_content -}}
                                </span>
                              </button>
                            </quantity-input>
                          </div>
                          <cart-remove-button
                            id="Remove-{{ item.index | plus: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                            {% assign can_remove = item.instructions.can_remove | default: true %}
                            {% if can_remove == false %}
                              class="hidden"
                            {% endif %}
                          >
                            <a
                              href="{{ item.url_to_remove }}"
                              class="button button--tertiary"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-remove.svg' | inline_asset_content -}}
                              </span>
                            </a>
                          </cart-remove-button>
                        </div>
                        {%- if has_qty_rules or has_vol_pricing -%}
                          <button
                            type="button"
                            class="quantity-popover__info-button quantity-popover__info-button--icon-with-label button button--tertiary large-up-hide"
                            aria-expanded="false"
                          >
                            {{- 'icon-info.svg' | inline_asset_content -}}
                            <span>
                              {%- if has_vol_pricing -%}
                                {{ 'products.product.volume_pricing.note' | t }}
                              {%- elsif has_qty_rules -%}
                                {{ 'products.product.quantity.note' | t }}
                              {%- endif -%}
                            </span>
                          </button>
                        {%- endif -%}
                        {%- if has_vol_pricing or has_qty_rules -%}
                          <div
                            class="cart-items__info global-settings-popup quantity-popover__info"
                            tabindex="-1"
                            hidden
                          >
                            {%- if has_qty_rules == false -%}
                              <span class="volume-pricing-label caption">
                                {{- 'products.product.volume_pricing.title' | t -}}
                              </span>
                            {%- endif -%}
                            <div class="quantity__rules caption">
                              {%- if item.variant.quantity_rule.increment > 1 -%}
                                <span class="divider">
                                  {{-
                                    'products.product.quantity.multiples_of'
                                    | t: quantity: item.variant.quantity_rule.increment
                                  -}}
                                </span>
                              {%- endif -%}
                              {%- if item.variant.quantity_rule.min > 1 -%}
                                <span class="divider">
                                  {{-
                                    'products.product.quantity.min_of'
                                    | t: quantity: item.variant.quantity_rule.min
                                  -}}
                                </span>
                              {%- endif -%}
                              {%- if item.variant.quantity_rule.max != null -%}
                                <span class="divider">
                                  {{-
                                    'products.product.quantity.max_of'
                                    | t: quantity: item.variant.quantity_rule.max
                                  -}}
                                </span>
                              {%- endif -%}
                            </div>
                            <button
                              class="button-close button button--tertiary large-up-hide"
                              type="button"
                              aria-label="{{ 'accessibility.close' | t }}"
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-close.svg' | inline_asset_content -}}
                              </span>
                            </button>
                            {%- if item.variant.quantity_price_breaks.size > 0 -%}
                              <volume-pricing class="parent-display">
                                <ul class="list-unstyled">
                                  <li>
                                    <span>{{ item.variant.quantity_rule.min }}+</span>
                                    {%- assign price = item.variant.price | money_with_currency -%}
                                    <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                  </li>
                                  {%- for price_break in item.variant.quantity_price_breaks -%}
                                    <li>
                                      <span>
                                        {{- price_break.minimum_quantity -}}
                                        <span aria-hidden="true">+</span></span
                                      >
                                      {%- assign price = price_break.price | money_with_currency -%}
                                      <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              </volume-pricing>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                        <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                          <small class="cart-item__error-text"></small>
                          <span class="svg-wrapper">
                            {{- 'icon-error.svg' | inline_asset_content -}}
                          </span>
                        </div>
                      </quantity-popover>
                    </td>

                    <td class="cart-item__totals right small-hide">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                        {%- if item.original_line_price != item.final_line_price -%}
                          <dl class="cart-item__discounted-prices">
                            <dt class="visually-hidden">
                              {{ 'products.product.price.regular_price' | t }}
                            </dt>
                            <dd>
                              <s class="cart-item__old-price price price--end">
                                {{ item.original_line_price | money }}
                              </s>
                            </dd>
                            <dt class="visually-hidden">
                              {{ 'products.product.price.sale_price' | t }}
                            </dt>
                            <dd class="price price--end">
                              {{ item.final_line_price | money }}
                            </dd>
                          </dl>
                        {%- else -%}
                          <span class="price price--end">
                            {{ item.original_line_price | money }}
                          </span>
                        {%- endif -%}

                        {%- if item.variant.available and item.unit_price_measurement -%}
                          {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                        {%- endif -%}
                      </div>
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- endif -%}
        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p
        class="visually-hidden"
        id="shopping-cart-line-item-status"
        aria-live="polite"
        aria-hidden="true"
        role="status"
      >
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </div>
</cart-items>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
