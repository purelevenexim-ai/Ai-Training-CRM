{%- comment -%}
  snippets/basil-analytics-head.liquid
  Phase 4: Session recording + identity hook.
  Injected once in <head> via basil-head.liquid.
  Loads Microsoft Clarity and wires session_id into __BASIL__ config.
{%- endcomment -%}

{%- if settings.basil_clarity_project_id != blank -%}
<script>
  (function(c,l,a,r,i,t,y){
    c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
    t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
    y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window,document,"clarity","script","{{ settings.basil_clarity_project_id | escape }}");

  // Wire Clarity session to Basil
  window.addEventListener('clarity:ready', function () {
    if (window.__BASIL__ && typeof clarity === 'function') {
      clarity('identify', window.__BASIL__.customerId || window.__BASIL__.sessionId || 'anon');
      window.__BASIL__.claritySessionId = window.clarity && clarity('get', 'sessionId');
    }
  });
</script>
{%- endif -%}

{%- comment -%}
  Session ID bootstrap: assign a persistent session ID for anonymous tracking.
  Uses sessionStorage for tab-scoped dedup; persisted by basil-cart.js.
{%- endcomment -%}
<script>
(function () {
  try {
    var key = 'basil_sid';
    var sid = sessionStorage.getItem(key);
    if (!sid) {
      sid = 'bs_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 9);
      sessionStorage.setItem(key, sid);
    }
    if (window.__BASIL__) {
      window.__BASIL__.sessionId = sid;
    }
  } catch (_) {}
})();
</script>
