{%- assign eyebrow = custom_eyebrow -%}
{%- assign heading = custom_heading -%}
{%- assign intro = custom_intro -%}
{%- assign intro_is_fallback = false -%}

{%- assign comparison_placeholder_intro = '<p>Add source, process, quality, and use-case differences here to help shoppers and AI systems understand why this product is different.</p>' -%}
{%- assign faq_placeholder_intro = '<p>Add direct-answer FAQ items here for SEO, AEO, and customer confidence.</p>' -%}

{%- assign fallback_eyebrow = '' -%}
{%- assign fallback_heading = '' -%}
{%- assign fallback_intro = '' -%}

{%- case mode -%}
  {%- when 'comparison' -%}
    {%- case product_handle -%}
      {%- when 'kerala-cardamom-online-100gm', 'kerala-cardamom-200gm', 'kerala-cardamom-50gm', 'kerala-cardamom-8mm-200gm', 'kerala-cardamom-8mm-fruit-100gm', 'kerala-cardamom-500gm' -%}
        {%- assign fallback_eyebrow = 'Grade clarity' -%}
        {%- assign fallback_heading = 'What separates this cardamom from loose market stock' -%}
        {%- assign fallback_intro = 'Bigger pods, clearer source language, and stronger whole-pod aroma are the real buying differences here.' -%}
      {%- when 'kerala-black-pepper-100gm', 'kerala-black-pepper-200gm', 'kerala-black-pepper-300gm', 'kerala-black-pepper-350gm', 'kerala-black-pepper-500gm' -%}
        {%- assign fallback_eyebrow = 'Pepper benchmark' -%}
        {%- assign fallback_heading = 'What better pepper looks like before it hits the grinder' -%}
        {%- assign fallback_intro = 'This comparison focuses on whole-pepper freshness, aroma retention, and whether the pack is built for real kitchen use.' -%}
      {%- when 'kerala-clove-100gm', 'kerala-clove-200gm' -%}
        {%- assign fallback_eyebrow = 'Clove benchmark' -%}
        {%- assign fallback_heading = 'How this clove differs from commodity spice packs' -%}
        {%- assign fallback_intro = 'The useful differences are whole-bud quality, aroma strength, and how clearly the pack tells you what it is best for.' -%}
      {%- when 'kerala-white-pepper', 'kerala-white-pepper-100gm' -%}
        {%- assign fallback_eyebrow = 'Flavor comparison' -%}
        {%- assign fallback_heading = 'Why white pepper deserves a separate place in the kitchen' -%}
        {%- assign fallback_intro = 'This is less about heat alone and more about finish, use-case precision, and where white pepper performs better than standard pepper listings.' -%}
      {%- when 'cardamom-pepper-clove-combo-pack-special-offer-100-off', 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack-copy', 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack', 'cardamom-100g-black-pepper-200g-clove-100g-3-in-1-spice-combo-pack' -%}
        {%- assign fallback_eyebrow = 'Bundle logic' -%}
        {%- assign fallback_heading = 'Why this combo is more useful than a random bundled spice pack' -%}
        {%- assign fallback_intro = 'The value here is not only price. It is source identity, kitchen logic, and whether the bundle actually matches how people cook or gift spices.' -%}
      {%- when 'premium-cassia-cinnamon-100g', 'premium-cassia-cinnamon-200g' -%}
        {%- assign fallback_eyebrow = 'Cinnamon profile' -%}
        {%- assign fallback_heading = 'Why this cassia lands differently in chai and baking' -%}
        {%- assign fallback_intro = 'Cassia should feel warm, bold, and direct. The comparison matters because many cinnamon listings do not tell buyers what style they are actually getting.' -%}
      {%- when 'aromatic-true-cinnamon-ceylon-100g', 'aromatic-true-cinnamon-ceylon-200g' -%}
        {%- assign fallback_eyebrow = 'True cinnamon profile' -%}
        {%- assign fallback_heading = 'Why Ceylon needs a gentler, more precise pitch' -%}
        {%- assign fallback_intro = 'This page should help buyers understand sweetness, softness, and where true cinnamon makes more sense than a stronger cassia profile.' -%}
    {%- endcase -%}
  {%- when 'faq' -%}
    {%- case product_handle -%}
      {%- when 'kerala-cardamom-online-100gm', 'kerala-cardamom-200gm', 'kerala-cardamom-50gm', 'kerala-cardamom-8mm-200gm', 'kerala-cardamom-8mm-fruit-100gm', 'kerala-cardamom-500gm' -%}
        {%- assign fallback_eyebrow = 'Buying guidance' -%}
        {%- assign fallback_heading = 'Cardamom questions buyers usually ask first' -%}
        {%- assign fallback_intro = 'Storage, grading, pack choice, and what to expect from whole 8mm pods are usually the first practical questions.' -%}
      {%- when 'kerala-black-pepper-100gm', 'kerala-black-pepper-200gm', 'kerala-black-pepper-300gm', 'kerala-black-pepper-350gm', 'kerala-black-pepper-500gm' -%}
        {%- assign fallback_eyebrow = 'Pepper questions' -%}
        {%- assign fallback_heading = 'What shoppers need to know before buying peppercorns' -%}
        {%- assign fallback_intro = 'These answers focus on freshness, whole-vs-ground logic, storage, and which pack size actually fits a working kitchen.' -%}
      {%- when 'kerala-clove-100gm', 'kerala-clove-200gm' -%}
        {%- assign fallback_eyebrow = 'Clove questions' -%}
        {%- assign fallback_heading = 'The practical questions behind aroma, storage, and use' -%}
        {%- assign fallback_intro = 'Short answers for buyers comparing whole clove packs, deciding on pack size, and checking freshness expectations.' -%}
      {%- when 'kerala-white-pepper', 'kerala-white-pepper-100gm' -%}
        {%- assign fallback_eyebrow = 'White pepper questions' -%}
        {%- assign fallback_heading = 'When white pepper is the right kitchen choice' -%}
        {%- assign fallback_intro = 'This section clears up the usual confusion around flavor profile, best dishes, and how white pepper differs from black pepper in practice.' -%}
      {%- when 'cardamom-pepper-clove-combo-pack-special-offer-100-off', 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack-copy', 'cardamom-50g-black-pepper-100g-clove-100g-3-in-1-spice-combo-pack', 'cardamom-100g-black-pepper-200g-clove-100g-3-in-1-spice-combo-pack' -%}
        {%- assign fallback_eyebrow = 'Bundle questions' -%}
        {%- assign fallback_heading = 'What this combo solves for a kitchen or gift order' -%}
        {%- assign fallback_intro = 'These are the questions shoppers ask when deciding whether a bundled purchase is actually more useful than buying spices one by one.' -%}
      {%- when 'premium-cassia-cinnamon-100g', 'premium-cassia-cinnamon-200g' -%}
        {%- assign fallback_eyebrow = 'Cassia questions' -%}
        {%- assign fallback_heading = 'How to buy cassia with the right expectations' -%}
        {%- assign fallback_intro = 'A quick guide to flavor strength, use-case fit, and storage so buyers know what cassia is meant to do well.' -%}
      {%- when 'aromatic-true-cinnamon-ceylon-100g', 'aromatic-true-cinnamon-ceylon-200g' -%}
        {%- assign fallback_eyebrow = 'True cinnamon questions' -%}
        {%- assign fallback_heading = 'How to choose Ceylon with confidence' -%}
        {%- assign fallback_intro = 'These answers help buyers understand what true cinnamon is, how it differs from cassia, and where it shines in daily use.' -%}
    {%- endcase -%}
{%- endcase -%}

{%- if mode == 'comparison' -%}
  {%- if eyebrow == blank or eyebrow == 'Why compare' -%}
    {%- assign eyebrow = fallback_eyebrow -%}
  {%- endif -%}
  {%- if heading == blank or heading == 'How this product compares' -%}
    {%- assign heading = fallback_heading -%}
  {%- endif -%}
  {%- if intro == blank or intro == comparison_placeholder_intro -%}
    {%- assign intro = fallback_intro -%}
    {%- assign intro_is_fallback = true -%}
  {%- endif -%}
{%- elsif mode == 'faq' -%}
  {%- if eyebrow == blank or eyebrow == 'Questions answered' -%}
    {%- assign eyebrow = fallback_eyebrow -%}
  {%- endif -%}
  {%- if heading == blank or heading == 'Product FAQs' -%}
    {%- assign heading = fallback_heading -%}
  {%- endif -%}
  {%- if intro == blank or intro == faq_placeholder_intro -%}
    {%- assign intro = fallback_intro -%}
    {%- assign intro_is_fallback = true -%}
  {%- endif -%}
{%- endif -%}

{%- if eyebrow != blank -%}
  <p class="{{ class_prefix }}__eyebrow">{{ eyebrow | escape }}</p>
{%- endif -%}
<h2 id="{{ heading_id }}" class="{{ class_prefix }}__heading inline-richtext {{ heading_size }}">{{ heading }}</h2>
{%- if intro != blank -%}
  <div class="{{ class_prefix }}__intro rte">{%- if intro_is_fallback -%}<p>{{ intro }}</p>{%- else -%}{{ intro }}{%- endif -%}</div>
{%- endif -%}