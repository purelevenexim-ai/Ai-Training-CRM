{% comment %} basil-reward-strip.liquid — 4-tier reward progress bar from live theme {% endcomment %}
{%- liquid
  assign free_delivery_threshold_rupees = settings.basil_cart_free_delivery_threshold | default: 649 | plus: 0
  assign mid_threshold_rupees           = settings.basil_cart_mid_threshold           | default: 999 | plus: 0
  assign free_gift_threshold_rupees     = settings.basil_cart_gift_threshold          | default: 1449 | plus: 0
  assign top_threshold_rupees           = settings.basil_cart_top_threshold           | default: 1999 | plus: 0
  assign free_delivery_threshold = free_delivery_threshold_rupees | times: 100
  assign mid_threshold           = mid_threshold_rupees           | times: 100
  assign free_gift_threshold     = free_gift_threshold_rupees     | times: 100
  assign top_threshold           = top_threshold_rupees           | times: 100
  assign mid_discount  = settings.basil_cart_mid_discount  | default: 100  | plus: 0
  assign gift_discount = settings.basil_cart_gift_discount | default: 200  | plus: 0
  assign top_discount  = settings.basil_cart_top_discount  | default: 400  | plus: 0
  assign cart_total = cart.total_price

  assign free_delivery_unlocked = false
  assign mid_unlocked           = false
  assign free_gift_unlocked     = false
  assign top_unlocked           = false

  assign free_delivery_remaining = free_delivery_threshold | minus: cart_total
  assign mid_remaining           = mid_threshold           | minus: cart_total
  assign free_gift_remaining     = free_gift_threshold     | minus: cart_total
  assign top_remaining           = top_threshold           | minus: cart_total
  assign free_delivery_remaining_r = free_delivery_remaining | divided_by: 100
  assign mid_remaining_r           = mid_remaining           | divided_by: 100
  assign free_gift_remaining_r     = free_gift_remaining     | divided_by: 100
  assign top_remaining_r           = top_remaining           | divided_by: 100
  assign reward_progress = 0

  if free_delivery_remaining < 0
    assign free_delivery_remaining = 0
  endif
  if mid_remaining < 0
    assign mid_remaining = 0
  endif
  if free_gift_remaining < 0
    assign free_gift_remaining = 0
  endif
  if top_remaining < 0
    assign top_remaining = 0
  endif

  if cart_total >= free_delivery_threshold
    assign free_delivery_unlocked = true
  endif
  if cart_total >= mid_threshold
    assign mid_unlocked = true
  endif
  if cart_total >= free_gift_threshold
    assign free_gift_unlocked = true
  endif
  if cart_total >= top_threshold
    assign top_unlocked = true
  endif

  if cart_total > 0
    if cart_total < mid_threshold
      assign reward_progress = cart_total | times: 25 | divided_by: mid_threshold
    elsif cart_total < free_gift_threshold
      assign reward_segment  = free_gift_threshold | minus: mid_threshold
      assign reward_progress = cart_total | minus: mid_threshold
      assign reward_progress = reward_progress | times: 25 | divided_by: reward_segment
      assign reward_progress = reward_progress | plus: 25
    elsif cart_total < top_threshold
      assign reward_segment  = top_threshold | minus: free_gift_threshold
      assign reward_progress = cart_total | minus: free_gift_threshold
      assign reward_progress = reward_progress | times: 25 | divided_by: reward_segment
      assign reward_progress = reward_progress | plus: 50
    else
      assign reward_progress = 75
    endif
  endif
  if reward_progress > 75
    assign reward_progress = 75
  endif
-%}

<style>
.basil-reward-strip{width:100%;box-sizing:border-box;background:linear-gradient(180deg,#fffef9 0%,#fffaf0 100%);border:1px solid rgba(192,158,85,.28);border-radius:1.6rem;box-shadow:0 10px 24px rgba(32,48,32,.06);padding:1.45rem 1.6rem 2rem;margin:0 0 1rem}
.basil-reward-strip__head{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1.6rem}
.basil-reward-strip__copy{min-width:0}
.basil-reward-strip__shipping-note{display:inline-flex;align-items:center;flex-wrap:wrap;gap:.45rem;margin:0 0 .45rem;font-size:1.08rem;line-height:1.25;color:#4f6d48}
.basil-reward-strip__shipping-badge{display:inline-flex;align-items:center;justify-content:center;padding:.18rem .65rem;border-radius:999px;background:rgba(53,126,80,.13);color:#2f7b57;font-size:.98rem;font-weight:700}
.basil-reward-strip__status{font-size:1.35rem;font-weight:600;color:#223328;margin:0;line-height:1.4}
.basil-reward-strip__view-link{font-size:1.2rem;color:#335f44;text-decoration:none;white-space:nowrap;flex-shrink:0}
.basil-reward-strip__view-link:hover{text-decoration:underline}
.basil-reward-strip__track-wrap{position:relative;padding-bottom:4.8rem}
.basil-reward-strip__bar{position:relative;height:8px;background:linear-gradient(90deg,rgba(47,123,87,.08) 0%,rgba(214,178,74,.12) 56%,rgba(214,125,51,.1) 100%);border-radius:999px;overflow:visible}
.basil-reward-strip__fill{position:absolute;left:0;top:0;height:100%;width:var(--brs-fill,0%);background:linear-gradient(90deg,#2f7b57 0%,#d5b24d 58%,#d67d33 100%);border-radius:999px;transition:none}
.basil-reward-strip__node{position:absolute;top:50%;transform:translate(-50%,-50%);width:26px;height:26px;border-radius:50%;background:#fffdf7;border:2px solid #d7e0d1;display:flex;align-items:center;justify-content:center;color:#8d9485;box-shadow:0 0 0 5px rgba(255,250,240,.96);transition:none;z-index:2}
.basil-reward-strip__node.is-unlocked{border-color:#2f7b57;background:#2f7b57;color:#fff}
.basil-reward-strip__node--mid{border-color:rgba(213,178,77,.55);color:#b4871f}
.basil-reward-strip__node--gift{border-color:rgba(200,143,51,.58);color:#b07118}
.basil-reward-strip__node--top{border-color:rgba(214,125,51,.6);color:#c96f2a}
.basil-reward-strip__node--mid.is-unlocked{border-color:#e4c45b;background:#e4c45b;color:#4f3f14}
.basil-reward-strip__node--gift.is-unlocked{border-color:#d2a147;background:#d2a147;color:#fff8ec}
.basil-reward-strip__node--top.is-unlocked{border-color:#d67d33;background:#d67d33;color:#fff5ec}
.basil-reward-strip__node--tail{width:16px;height:16px;background:#fffef9;border-color:#eadfc8;color:transparent}
.basil-reward-strip__milestones{position:absolute;left:0;right:0;top:16px;height:4.8rem}
.basil-reward-strip__milestone{position:absolute;transform:translateX(-50%);text-align:center;min-width:7rem;padding-top:.6rem}
.basil-reward-strip__milestone strong{display:block;font-size:1.25rem;font-weight:700;color:#233129;line-height:1.2}
.basil-reward-strip__milestone span{display:block;font-size:1rem;color:#6c7363;line-height:1.3;margin-top:.2rem;white-space:nowrap}
.basil-reward-strip__milestone--mid strong,.basil-reward-strip__milestone--mid span{color:#9b7721}
.basil-reward-strip__milestone--gift strong,.basil-reward-strip__milestone--gift span{color:#a66d1a}
.basil-reward-strip__milestone--top strong,.basil-reward-strip__milestone--top span{color:#bc6625}
.basil-reward-strip__milestone.is-unlocked strong{color:#2f7b57}
.basil-reward-strip__milestone.is-unlocked span{color:#53734d}
.basil-reward-strip__milestone--mid.is-unlocked strong,.basil-reward-strip__milestone--mid.is-unlocked span{color:#8e6e17}
.basil-reward-strip__milestone--gift.is-unlocked strong,.basil-reward-strip__milestone--gift.is-unlocked span{color:#966018}
.basil-reward-strip__milestone--top.is-unlocked strong,.basil-reward-strip__milestone--top.is-unlocked span{color:#ae5920}
.basil-reward-strip__milestone.is-active strong{color:#1a3a2a}
.basil-reward-strip__milestone.is-active span{color:#555;font-weight:600}
.basil-reward-strip__milestone--mid.is-active{background:rgba(228,196,91,.16);border:1px solid rgba(212,170,55,.38);border-radius:8px;padding:.4rem .6rem}
.basil-reward-strip__milestone--gift.is-active{background:rgba(210,161,71,.14);border:1px solid rgba(187,127,34,.36);border-radius:8px;padding:.4rem .6rem}
.basil-reward-strip__milestone--top.is-active{background:rgba(214,125,51,.13);border:1px solid rgba(196,104,29,.34);border-radius:8px;padding:.4rem .6rem}
.basil-cart-toast{position:fixed;bottom:calc(108px + env(safe-area-inset-bottom) + 1rem);left:50%;transform:translateX(-50%) translateY(12px);z-index:9999;background:#1a3a2a;color:#fff;font-size:1.3rem;font-weight:600;padding:.75rem 1.6rem;border-radius:32px;box-shadow:0 4px 24px rgba(0,0,0,.18);opacity:0;pointer-events:none;transition:opacity .22s ease,transform .22s ease;white-space:nowrap}
.basil-cart-toast[aria-hidden="false"]{opacity:1;transform:translateX(-50%) translateY(0)}
@media screen and (min-width:750px){.basil-cart-toast{bottom:calc(80px + env(safe-area-inset-bottom) + 1.2rem)}}
</style>

{%- if cart != empty -%}
  <section
    class="basil-reward-strip"
    aria-label="Cart reward progress"
    data-basil-cart-state
    data-cart-item-count="{{ cart.item_count }}"
    data-cart-total="{{ cart.total_price }}"
    data-delivery-threshold="{{ free_delivery_threshold }}"
    data-mid-threshold="{{ mid_threshold }}"
    data-gift-threshold="{{ free_gift_threshold }}"
    data-top-threshold="{{ top_threshold }}"
    data-delivery-unlocked="{{ free_delivery_unlocked }}"
    data-mid-unlocked="{{ mid_unlocked }}"
    data-gift-unlocked="{{ free_gift_unlocked }}"
    data-top-unlocked="{{ top_unlocked }}"
  >
    <div class="basil-reward-strip__head">
      <div class="basil-reward-strip__copy">
        <p class="basil-reward-strip__shipping-note">
          All orders above ₹{{ free_delivery_threshold_rupees }} get free shipping
          {%- if free_delivery_unlocked -%}
            <span class="basil-reward-strip__shipping-badge">Unlocked</span>
          {%- endif -%}
        </p>
        <p class="basil-reward-strip__status">
          {%- if top_unlocked -%}
            🎉 ₹{{ top_discount }} OFF unlocked
          {%- elsif free_gift_unlocked -%}
            Add ₹{{ top_remaining_r }} to unlock ₹{{ top_discount }} OFF
          {%- elsif free_delivery_unlocked -%}
            {%- if mid_unlocked -%}
              Add ₹{{ free_gift_remaining_r }} to unlock ₹{{ gift_discount }} OFF
            {%- else -%}
              Add ₹{{ mid_remaining_r }} to unlock ₹{{ mid_discount }} OFF
            {%- endif -%}
          {%- else -%}
            Add ₹{{ free_delivery_remaining_r }} for free shipping
          {%- endif -%}
        </p>
      </div>
      <a href="{{ routes.all_products_collection_url }}" class="basil-reward-strip__view-link">View all rewards</a>
    </div>

    <div class="basil-reward-strip__track-wrap" style="--brs-fill: {{ reward_progress }}%;">
      <div class="basil-reward-strip__bar" role="presentation" aria-hidden="true">
        <span class="basil-reward-strip__fill"></span>
        <span class="basil-reward-strip__node basil-reward-strip__node--mid{% if mid_unlocked %} is-unlocked{% endif %}" style="left: 25%">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="8" width="18" height="14" rx="1" stroke="currentColor" stroke-width="2"/><path d="M3 8h18M12 8V22M8 8c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="2"/></svg>
        </span>
        <span class="basil-reward-strip__node basil-reward-strip__node--gift{% if free_gift_unlocked %} is-unlocked{% endif %}" style="left: 50%">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="8" width="18" height="14" rx="1" stroke="currentColor" stroke-width="2"/><path d="M3 8h18M12 8V22M8 8c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="2"/></svg>
        </span>
        <span class="basil-reward-strip__node basil-reward-strip__node--top{% if top_unlocked %} is-unlocked{% endif %}" style="left: 75%">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="8" width="18" height="14" rx="1" stroke="currentColor" stroke-width="2"/><path d="M3 8h18M12 8V22M8 8c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="2"/></svg>
        </span>
        <span class="basil-reward-strip__node basil-reward-strip__node--tail" style="left: 100%" aria-hidden="true"></span>
      </div>
      <div class="basil-reward-strip__milestones">
        <div class="basil-reward-strip__milestone basil-reward-strip__milestone--mid{% if mid_unlocked %} is-unlocked{% else %} is-active{% endif %}" style="left: 25%">
          <strong>₹{{ mid_threshold_rupees }}</strong>
          <span>+ ₹{{ mid_discount }} OFF</span>
        </div>
        <div class="basil-reward-strip__milestone basil-reward-strip__milestone--gift{% if free_gift_unlocked %} is-unlocked{% elsif mid_unlocked %} is-active{% endif %}" style="left: 50%">
          <strong>₹{{ free_gift_threshold_rupees }}</strong>
          <span>+ ₹{{ gift_discount }} OFF</span>
        </div>
        <div class="basil-reward-strip__milestone basil-reward-strip__milestone--top{% if top_unlocked %} is-unlocked{% elsif free_gift_unlocked %} is-active{% endif %}" style="left: 75%">
          <strong>₹{{ top_threshold_rupees }}</strong>
          <span>+ ₹{{ top_discount }} OFF</span>
        </div>
      </div>
    </div>
  </section>

  <div class="basil-cart-toast" data-basil-cart-toast aria-live="polite" aria-hidden="true">
    <span data-basil-cart-toast-copy>{{ settings.basil_cart_add_toast | default: 'Cart updated' }}</span>
  </div>

  <script>
  (function () {
    var state = document.querySelector('[data-basil-cart-state]');
    var toast = document.querySelector('[data-basil-cart-toast]');
    if (!state) return;

    var storageKey = 'basil-cart:reward-state';
    var deliveryThreshold = Number(state.dataset.deliveryThreshold || 0);
    var midThreshold      = Number(state.dataset.midThreshold      || 0);
    var giftThreshold     = Number(state.dataset.giftThreshold     || 0);
    var topThreshold      = Number(state.dataset.topThreshold      || 0);

    function readCurrent(cartData) {
      var total = Number((cartData && cartData.total_price) ||
        document.querySelector('[data-basil-cart-state]')?.dataset.cartTotal || 0);
      return {
        cartTotal:        total,
        deliveryUnlocked: total >= deliveryThreshold,
        midUnlocked:      total >= midThreshold,
        giftUnlocked:     total >= giftThreshold,
        topUnlocked:      total >= topThreshold
      };
    }

    function showToast(message) {
      if (!message || !toast) return;
      toast.querySelector('[data-basil-cart-toast-copy]').textContent = message;
      toast.setAttribute('aria-hidden', 'false');
      window.setTimeout(function () { toast.setAttribute('aria-hidden', 'true'); }, 3200);
    }

    function handleTransition(curr, prev) {
      if (!prev) return;
      var cls = document.documentElement.classList;
      cls.remove('basil-cart-gift-unlocked', 'basil-cart-delivery-unlocked', 'basil-cart-top-unlocked');
      if (!prev.topUnlocked && curr.topUnlocked) {
        cls.add('basil-cart-top-unlocked');
        showToast('₹{{ top_discount }} OFF unlocked 🎉');
      } else if (!prev.giftUnlocked && curr.giftUnlocked) {
        cls.add('basil-cart-gift-unlocked');
        showToast('₹{{ gift_discount }} OFF unlocked 🎉');
      } else if (!prev.midUnlocked && curr.midUnlocked) {
        cls.add('basil-cart-delivery-unlocked');
        showToast('₹{{ mid_discount }} OFF unlocked 🎉');
      } else if (!prev.deliveryUnlocked && curr.deliveryUnlocked) {
        cls.add('basil-cart-delivery-unlocked');
        showToast({{ settings.basil_cart_delivery_unlocked_toast | default: 'Free delivery unlocked 🚚' | json }});
      }
    }

    var current = readCurrent();
    var previous = null;
    try { previous = JSON.parse(window.localStorage.getItem(storageKey) || 'null'); } catch(e) {}
    handleTransition(current, previous);
    try { window.localStorage.setItem(storageKey, JSON.stringify(current)); } catch(e) {}

    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.cartUpdate) {
      subscribe(PUB_SUB_EVENTS.cartUpdate, function (event) {
        var prev = null;
        try { prev = JSON.parse(window.localStorage.getItem(storageKey) || 'null'); } catch(e) {}
        var next = readCurrent(event && event.cartData);
        handleTransition(next, prev);
        try { window.localStorage.setItem(storageKey, JSON.stringify(next)); } catch(e) {}
      });
    }
  }());
  </script>
{%- endif -%}
