{%- assign guide_uid = section_id | append: '-' | append: block_id -%}

<div class="product-quick-guide__surface">
  <div class="product-quick-guide__header">
    <p class="product-quick-guide__eyebrow">3 quick answers</p>
    <h2 class="product-quick-guide__heading h4">{{ guide_heading }}</h2>
    <p class="product-quick-guide__intro">{{ guide_intro }}</p>
  </div>

  <div class="product-quick-guide__tabs" aria-label="Quick kitchen guide">
    <input
      class="product-quick-guide__tab-input product-quick-guide__tab-input--fit"
      type="radio"
      name="ProductQuickGuide-{{ guide_uid }}"
      id="ProductQuickGuideFit-{{ guide_uid }}"
      checked
    >
    <label class="product-quick-guide__tab-label" for="ProductQuickGuideFit-{{ guide_uid }}">Best for</label>

    <input
      class="product-quick-guide__tab-input product-quick-guide__tab-input--use"
      type="radio"
      name="ProductQuickGuide-{{ guide_uid }}"
      id="ProductQuickGuideUse-{{ guide_uid }}"
    >
    <label class="product-quick-guide__tab-label" for="ProductQuickGuideUse-{{ guide_uid }}">Use it</label>

    <input
      class="product-quick-guide__tab-input product-quick-guide__tab-input--store"
      type="radio"
      name="ProductQuickGuide-{{ guide_uid }}"
      id="ProductQuickGuideStore-{{ guide_uid }}"
    >
    <label class="product-quick-guide__tab-label" for="ProductQuickGuideStore-{{ guide_uid }}">Keep it fresh</label>

    <div class="product-quick-guide__panels">
      <article class="product-quick-guide__panel product-quick-guide__panel--fit">
        <p class="product-quick-guide__panel-kicker">Best for</p>
        <h3 class="product-quick-guide__panel-title">{{ fit_title }}</h3>
        <p class="product-quick-guide__panel-text">{{ fit_body }}</p>
        <ul class="product-quick-guide__list list-unstyled" role="list">
          <li>{{ fit_point_1 }}</li>
          <li>{{ fit_point_2 }}</li>
          <li>{{ fit_point_3 }}</li>
        </ul>
      </article>

      <article class="product-quick-guide__panel product-quick-guide__panel--use">
        <p class="product-quick-guide__panel-kicker">Use it</p>
        <h3 class="product-quick-guide__panel-title">{{ use_title }}</h3>
        <p class="product-quick-guide__panel-text">{{ use_body }}</p>
        <ul class="product-quick-guide__list list-unstyled" role="list">
          <li>{{ use_point_1 }}</li>
          <li>{{ use_point_2 }}</li>
          <li>{{ use_point_3 }}</li>
        </ul>
      </article>

      <article class="product-quick-guide__panel product-quick-guide__panel--store">
        <p class="product-quick-guide__panel-kicker">Keep it fresh</p>
        <h3 class="product-quick-guide__panel-title">{{ store_title }}</h3>
        <p class="product-quick-guide__panel-text">{{ store_body }}</p>
        <ul class="product-quick-guide__list list-unstyled" role="list">
          <li>{{ store_point_1 }}</li>
          <li>{{ store_point_2 }}</li>
          <li>{{ store_point_3 }}</li>
        </ul>
      </article>
    </div>
  </div>

  <div class="product-quick-guide__footer">
    <p class="product-quick-guide__footer-label">Good match for</p>
    <ul class="product-quick-guide__chips list-unstyled" role="list">
      <li>{{ chip_1 }}</li>
      <li>{{ chip_2 }}</li>
      <li>{{ chip_3 }}</li>
    </ul>
    {%- if guide_link_label != blank and guide_link_url != blank -%}
      <a class="product-quick-guide__link" href="{{ guide_link_url }}">{{ guide_link_label }}</a>
    {%- endif -%}
    <p class="product-quick-guide__footer-note">{{ footer_note }}</p>
  </div>
</div>