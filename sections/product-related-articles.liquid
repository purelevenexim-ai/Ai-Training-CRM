{%- assign article_1_title = '' -%}
{%- assign article_1_url = '' -%}
{%- assign article_1_copy = '' -%}
{%- assign article_2_title = '' -%}
{%- assign article_2_url = '' -%}
{%- assign article_2_copy = '' -%}
{%- assign article_3_title = '' -%}
{%- assign article_3_url = '' -%}
{%- assign article_3_copy = '' -%}

{%- if product.handle contains 'combo-pack' -%}
  {%- assign article_1_title = 'How to Check Quality of Spices' -%}
  {%- assign article_1_url = '/blogs/cooking-spices/spice-checklist-how-to-check-quality-of-spices' -%}
  {%- assign article_1_copy = 'Help bundle buyers understand what good kitchen staples should look and smell like after opening.' -%}
  {%- assign article_2_title = 'How to Store Spices for Freshness' -%}
  {%- assign article_2_url = '/blogs/cooking-spices/how-to-store-spices' -%}
  {%- assign article_2_copy = 'A strong retention piece for bundle buyers who need simple storage guidance after the first purchase.' -%}
  {%- assign article_3_title = 'History of Indian Spice Trade' -%}
  {%- assign article_3_url = '/blogs/cooking-spices/rich-history-of-indian-spice-trade' -%}
  {%- assign article_3_copy = 'Add emotional and cultural depth so the bundle feels like a Kerala kitchen story, not just a price-led combo.' -%}
{%- elsif product.handle contains 'cardamom' -%}
  {%- assign article_1_title = 'Difference Between Green and Black Cardamom' -%}
  {%- assign article_1_url = '/blogs/cooking-spices/difference-between-green-and-black-cardamom' -%}
  {%- assign article_1_copy = 'Help shoppers understand cardamom type, aroma, and why whole green pods behave differently in the kitchen.' -%}
  {%- assign article_2_title = 'How to Make Cardamom Powder' -%}
  {%- assign article_2_url = '/blogs/cooking-spices/guide-how-to-make-cardamom-powder' -%}
  {%- assign article_2_copy = 'A practical use-case article that supports whole-pod buying intent and reinforces freshness-first grinding.' -%}
  {%- assign article_3_title = 'Factors Affecting Cardamom Price' -%}
  {%- assign article_3_url = '/blogs/cooking-spices/factors-affecting-cardamom-price-todays-market' -%}
  {%- assign article_3_copy = 'Build premium positioning by explaining why sourcing, grade, and market quality change what buyers pay.' -%}
{%- elsif product.handle contains 'black-pepper' -%}
  {%- assign article_1_title = 'Kerala Black Pepper Varieties' -%}
  {%- assign article_1_url = '/blogs/cooking-spices/spice-of-kings-kerala-black-pepper-varieties' -%}
  {%- assign article_1_copy = 'Connect the product page to regional pepper identity, flavor depth, and variety-driven buying confidence.' -%}
  {%- assign article_2_title = 'Malabar vs Tellicherry Pepper' -%}
  {%- assign article_2_url = '/blogs/cooking-spices/difference-between-malabar-and-tellicherry-pepper' -%}
  {%- assign article_2_copy = 'A comparison guide that helps the shopper understand why pepper is not a one-note commodity category.' -%}
  {%- assign article_3_title = 'Black Pepper Essential Oil Journey' -%}
  {%- assign article_3_url = '/blogs/cooking-spices/black-pepper-essential-oil' -%}
  {%- assign article_3_copy = 'A deeper provenance and processing story for buyers who care about quality beyond simple heat.' -%}
{%- elsif product.handle contains 'clove' -%}
  {%- assign article_1_title = 'Health Benefits of Clove' -%}
  {%- assign article_1_url = '/blogs/cooking-spices/health-benefits-of-clove' -%}
  {%- assign article_1_copy = 'Give the clove page a stronger story around daily value, warming use, and why whole buds matter.' -%}
  {%- assign article_2_title = 'How to Check Quality of Spices' -%}
  {%- assign article_2_url = '/blogs/cooking-spices/spice-checklist-how-to-check-quality-of-spices' -%}
  {%- assign article_2_copy = 'Support trust by teaching buyers what freshness, aroma, and visible whole-spice quality should look like.' -%}
  {%- assign article_3_title = 'How to Store Spices for Freshness' -%}
  {%- assign article_3_url = '/blogs/cooking-spices/how-to-store-spices' -%}
  {%- assign article_3_copy = 'Reduce buyer hesitation with a practical guide on preserving aroma after purchase.' -%}
{%- elsif product.handle contains 'white-pepper' -%}
  {%- assign article_1_title = 'Kerala Black Pepper Varieties' -%}
  {%- assign article_1_url = '/blogs/cooking-spices/spice-of-kings-kerala-black-pepper-varieties' -%}
  {%- assign article_1_copy = 'Use a nearby pepper guide to explain regional quality and build confidence in the pepper category.' -%}
  {%- assign article_2_title = 'How to Check Quality of Spices' -%}
  {%- assign article_2_url = '/blogs/cooking-spices/spice-checklist-how-to-check-quality-of-spices' -%}
  {%- assign article_2_copy = 'Reinforce whole-spice quality, storage, and freshness expectations on a more refined pepper product.' -%}
  {%- assign article_3_title = 'How to Store Spices for Freshness' -%}
  {%- assign article_3_url = '/blogs/cooking-spices/how-to-store-spices' -%}
  {%- assign article_3_copy = 'Support the smoother, aroma-led white pepper proposition with better post-purchase guidance.' -%}
{%- elsif product.handle contains 'cassia' or product.handle contains 'ceylon' or product.handle contains 'cinnamon' -%}
  {%- assign article_1_title = 'How to Store Spices for Freshness' -%}
  {%- assign article_1_url = '/blogs/cooking-spices/how-to-store-spices' -%}
  {%- assign article_1_copy = 'Useful for cinnamon buyers who want to preserve aroma and sweetness instead of letting the spice flatten in storage.' -%}
  {%- assign article_2_title = 'How to Check Quality of Spices' -%}
  {%- assign article_2_url = '/blogs/cooking-spices/spice-checklist-how-to-check-quality-of-spices' -%}
  {%- assign article_2_copy = 'Build stronger buying confidence by giving shoppers a quality framework instead of generic cinnamon claims.' -%}
  {%- assign article_3_title = 'Medicinal Uses of Kerala Spices' -%}
  {%- assign article_3_url = '/blogs/cooking-spices/medicinal-uses-of-kerala-spices' -%}
  {%- assign article_3_copy = 'Supports broader spice-journal exploration and adds lifestyle value beyond the immediate product purchase.' -%}
{%- endif -%}

{%- assign has_related_articles = false -%}
{%- if article_1_title != blank and article_1_url != blank -%}
  {%- assign has_related_articles = true -%}
{%- endif -%}

{%- if has_related_articles or request.design_mode -%}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .product-related-articles-{{ section.id }} .product-related-articles__header {
      max-width: 74rem;
      margin: 0 auto 3rem;
      text-align: center;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__eyebrow {
      margin: 0 0 0.8rem;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #8F5A12;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__heading {
      margin: 0;
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__intro {
      margin: 1.2rem 0 0;
      font-size: 1.6rem;
      line-height: 1.75;
      color: rgba(var(--color-foreground), 0.76);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__grid {
      display: grid;
      gap: 1.6rem;
    }

    @media screen and (min-width: 990px) {
      .product-related-articles-{{ section.id }} .product-related-articles__grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card {
      display: flex;
      flex-direction: column;
      gap: 1.4rem;
      height: 100%;
      padding: 2.2rem;
      border: 0.1rem solid rgba(var(--color-foreground), 0.08);
      border-radius: 2.2rem;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(var(--color-foreground), 0.02));
      box-shadow: 0 1.6rem 4rem rgba(27, 58, 48, 0.06);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card-eyebrow {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(var(--color-foreground), 0.55);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card-title {
      margin: 0;
      font-size: 2rem;
      line-height: 1.2;
      letter-spacing: -0.03em;
      color: rgb(var(--color-foreground));
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card-copy {
      margin: 0;
      font-size: 1.45rem;
      line-height: 1.7;
      color: rgba(var(--color-foreground), 0.74);
      flex-grow: 1;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card-link,
    .product-related-articles-{{ section.id }} .product-related-articles__actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 4.4rem;
      padding: 1.1rem 1.6rem;
      border-radius: 999px;
      text-decoration: none;
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      transition: transform var(--duration-default) ease, background var(--duration-default) ease, border-color var(--duration-default) ease;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card-link:hover,
    .product-related-articles-{{ section.id }} .product-related-articles__actions a:hover {
      transform: translateY(-0.1rem);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__card-link {
      align-self: flex-start;
      color: #1B5E56;
      border: 0.1rem solid rgba(27, 94, 86, 0.22);
      background: rgba(27, 94, 86, 0.08);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      margin-top: 2.2rem;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__actions a:first-child {
      color: #ffffff;
      background: #1B5E56;
      border: 0.1rem solid #1B5E56;
    }

    .product-related-articles-{{ section.id }} .product-related-articles__actions a:last-child {
      color: rgb(var(--color-foreground));
      background: rgba(var(--color-foreground), 0.02);
      border: 0.1rem solid rgba(var(--color-foreground), 0.12);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__footer-note {
      margin: 1.6rem auto 0;
      max-width: 58rem;
      text-align: center;
      font-size: 1.3rem;
      line-height: 1.65;
      color: rgba(var(--color-foreground), 0.68);
    }

    .product-related-articles-{{ section.id }} .product-related-articles__placeholder {
      max-width: 72rem;
      margin: 0 auto;
      padding: 2rem 2.4rem;
      border: 0.1rem dashed rgba(var(--color-foreground), 0.2);
      border-radius: 1.8rem;
      color: rgba(var(--color-foreground), 0.7);
      background: rgba(var(--color-foreground), 0.02);
    }
  {%- endstyle -%}

  <div class="color-{{ section.settings.color_scheme }} gradient product-related-articles-{{ section.id }}">
    <section class="page-width section-{{ section.id }}-padding" aria-labelledby="ProductRelatedArticles-{{ section.id }}">
      <div class="product-related-articles__header">
        <p class="product-related-articles__eyebrow">Keep exploring</p>
        <h2 id="ProductRelatedArticles-{{ section.id }}" class="product-related-articles__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        <p class="product-related-articles__intro">{{ section.settings.intro }}</p>
      </div>

      {%- if has_related_articles -%}
        <div class="product-related-articles__grid">
          <article class="product-related-articles__card">
            <p class="product-related-articles__card-eyebrow">Spice guide</p>
            <h3 class="product-related-articles__card-title">{{ article_1_title }}</h3>
            <p class="product-related-articles__card-copy">{{ article_1_copy }}</p>
            <a class="product-related-articles__card-link" href="{{ article_1_url }}">Read guide</a>
          </article>
          {%- if article_2_title != blank and article_2_url != blank -%}
            <article class="product-related-articles__card">
              <p class="product-related-articles__card-eyebrow">Buying help</p>
              <h3 class="product-related-articles__card-title">{{ article_2_title }}</h3>
              <p class="product-related-articles__card-copy">{{ article_2_copy }}</p>
              <a class="product-related-articles__card-link" href="{{ article_2_url }}">Read guide</a>
            </article>
          {%- endif -%}
          {%- if article_3_title != blank and article_3_url != blank -%}
            <article class="product-related-articles__card">
              <p class="product-related-articles__card-eyebrow">Brand story</p>
              <h3 class="product-related-articles__card-title">{{ article_3_title }}</h3>
              <p class="product-related-articles__card-copy">{{ article_3_copy }}</p>
              <a class="product-related-articles__card-link" href="{{ article_3_url }}">Read guide</a>
            </article>
          {%- endif -%}
        </div>

        <div class="product-related-articles__actions">
          <a href="/blogs/cooking-spices">Explore all spice guides</a>
          <a href="/collections/all">Shop best sellers</a>
        </div>
        <p class="product-related-articles__footer-note">From Kerala soil to your kitchen. Use these guides to compare, choose, store, and enjoy the spice more confidently.</p>
      {%- elsif request.design_mode -%}
        <div class="product-related-articles__placeholder">Add product-specific guide links here so each product page supports deeper reading, stronger internal linking, and higher purchase confidence.</div>
      {%- endif -%}
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product related articles",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read before you buy"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Support the purchase decision with a few strong guides on quality, sourcing, storage, and spice use."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h0",
          "label": "Display"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Product related articles"
    }
  ]
}
{% endschema %}