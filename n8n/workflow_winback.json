{
  "name": "Pureleven — Winback (Lapsed Buyers 60+ days)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 24 }]
        }
      },
      "name": "Daily at 11am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "https://track.pureleven.com/api/crm/audiences/lapsed_buyer/export",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "format", "value": "meta" }]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.PURELEVEN_INTERNAL_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "name": "Fetch Lapsed Buyers",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "number": [{ "value1": "={{ $json.count }}", "operation": "larger", "value2": 0 }]
        }
      },
      "name": "Any lapsed?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "data",
        "options": {}
      },
      "name": "Split Customers",
      "type": "n8n-nodes-base.splitOut",
      "position": [900, 200]
    },
    {
      "parameters": {
        "url": "https://api.wabis.in/v1/send-template",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to", "value": "={{ $json.phone }}" },
            { "name": "template", "value": "winback_v1" },
            {
              "name": "params",
              "value": "={{ JSON.stringify([ $json.first_name || 'there', 'WELCOME15' ]) }}"
            }
          ]
        },
        "options": {}
      },
      "name": "WhatsApp Winback",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 200],
      "notes": "Template: winback_v1\nMessage: 'We miss you, {{first_name}}! Use WELCOME15 for 15% off your comeback order. Valid 48 hours.'"
    },
    {
      "parameters": {
        "amount": 7,
        "unit": "days"
      },
      "name": "Wait 7 days",
      "type": "n8n-nodes-base.wait",
      "position": [1340, 200]
    },
    {
      "parameters": {
        "url": "https://api.wabis.in/v1/send-template",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to", "value": "={{ $json.phone }}" },
            { "name": "template", "value": "winback_followup_v1" },
            {
              "name": "params",
              "value": "={{ JSON.stringify([ $json.first_name || 'there' ]) }}"
            }
          ]
        },
        "options": {}
      },
      "name": "WhatsApp Follow-up",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1560, 200],
      "notes": "Template: winback_followup_v1\nMessage: 'Hi {{first_name}}, new products just arrived from Kerala! Take a look 👀'"
    }
  ],
  "connections": {
    "Daily at 11am":     { "main": [[{ "node": "Fetch Lapsed Buyers", "type": "main", "index": 0 }]] },
    "Fetch Lapsed Buyers":{ "main": [[{ "node": "Any lapsed?", "type": "main", "index": 0 }]] },
    "Any lapsed?":       { "main": [[{ "node": "Split Customers", "type": "main", "index": 0 }], []] },
    "Split Customers":   { "main": [[{ "node": "WhatsApp Winback", "type": "main", "index": 0 }]] },
    "WhatsApp Winback":  { "main": [[{ "node": "Wait 7 days", "type": "main", "index": 0 }]] },
    "Wait 7 days":       { "main": [[{ "node": "WhatsApp Follow-up", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "pureleven-retargeting" }]
}
