    <script>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function() {
        window.dataLayer.push(arguments);
      };
    </script>

    <script>
      (function(w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({
          'gtm.start': new Date().getTime(),
          event: 'gtm.js'
        });
        var firstScript = d.getElementsByTagName(s)[0];
        var tag = d.createElement(s);
        var dataLayerParam = l !== 'dataLayer' ? '&l=' + l : '';
        tag.async = true;
        tag.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dataLayerParam;
        firstScript.parentNode.insertBefore(tag, firstScript);
      })(window, document, 'script', 'dataLayer', 'GTM-TFHBWPLM');
    </script>

    <script>
      (function() {
        var targetMeasurementId = 'G-3FRSK7TEN2';
        var serverTrackingUrl = 'https://track.pureleven.com';
        var configStartedAt = null;
        var pageContext = {
          pagePath: {{ request.path | append: request.query_string | json }},
          pageLocation: {{ canonical_url | json }},
          pageTitle: {{ resolved_page_title | json }},
          pageType: {{ request.page_type | json }},
          searchTerm: {% if request.page_type == 'search' and search.terms != blank %}{{ search.terms | json }}{% else %}null{% endif %},
          product: {% if request.page_type == 'product' and product %}{
            item_id: {{ product.selected_or_first_available_variant.id | prepend: 'shopify_IN_' | append: '_' | append: product.selected_or_first_available_variant.id | json }},
            item_name: {{ product.title | json }},
            item_brand: {{ product.vendor | default: shop.name | json }},
            item_category: {{ product.type | default: product.product_type | json }},
            item_variant: {{ product.selected_or_first_available_variant.title | json }},
            price: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }}
          }{% else %}null{% endif %}
        };

        function activeCurrency() {
          if (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) {
            return window.Shopify.currency.active;
          }

          return 'INR';
        }

        function ensureConfig() {
          if (typeof window.gtag !== 'function') {
            return false;
          }

          if (configStartedAt === null) {
            window.gtag('config', targetMeasurementId, {
              send_page_view: false,
              transport_url: serverTrackingUrl
            });
            configStartedAt = Date.now();
            return false;
          }

          return Date.now() - configStartedAt >= 1200;
        }

        function sendEvent(eventName, params) {
          if (!ensureConfig()) {
            return false;
          }

          window.gtag('event', eventName, Object.assign({}, params, {
            send_to: targetMeasurementId
          }));

          return true;
        }

        function sendPageView() {
          return sendEvent('page_view', {
            page_location: window.location.href,
            page_title: document.title,
            page_path: window.location.pathname + window.location.search
          });
        }

        function sendSearch() {
          if (!pageContext.searchTerm) {
            return true;
          }

          return sendEvent('search', {
            search_term: pageContext.searchTerm
          });
        }

        function sendViewItem() {
          if (!pageContext.product) {
            return true;
          }

          return sendEvent('view_item', {
            currency: activeCurrency(),
            value: pageContext.product.price,
            items: [pageContext.product]
          });
        }

        function sendInitialEvents() {
          var pageSent = sendPageView();
          var searchSent = sendSearch();
          var viewItemSent = sendViewItem();

          if (pageSent && searchSent && viewItemSent) {
            window.clearInterval(initialEventTimer);
          }
        }

        document.addEventListener('submit', function(event) {
          if (!pageContext.product) {
            return;
          }

          if (!(event.target instanceof HTMLFormElement) || event.target.action.indexOf('/cart/add') === -1) {
            return;
          }

          sendEvent('add_to_cart', {
            currency: activeCurrency(),
            value: pageContext.product.price,
            items: [pageContext.product]
          });
        });

        var initialEventTimer = window.setInterval(sendInitialEvents, 400);
      })();
    </script>

