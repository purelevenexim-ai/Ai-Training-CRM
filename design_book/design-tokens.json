{
  "brand": {
    "name": "PURELEVEN",
    "tagline": "Pure ingredients for everyday living.",
    "promise": "A bright, modern, approachable organic living brand designed for everyday healthy lifestyles.",
    "description": "A modern organic living brand focused on natural foods, wellness, and everyday healthy living inspired by Simply Organic"
  },
  "colors": {
    "primary": {
      "main": "#1B5E56",
      "dark": "#154039",
      "light": "#4D9B93",
      "name": "Teal Green"
    },
    "secondary": {
      "main": "#4D9B93",
      "name": "Light Teal"
    },
    "background": {
      "main": "#F8F5EE",
      "name": "Cream White"
    },
    "accent": {
      "main": "#E8E5DC",
      "name": "Light Sand"
    },
    "highlight": {
      "main": "#7FA89F",
      "name": "Sage Green"
    },
    "dark": {
      "coffee": "#5A3E36",
      "charcoal": "#2C2C2C"
    },
    "supporting": {
      "sage": "#7FA89F",
      "cream": "#F8F5EE",
      "sand": "#E8E5DC",
      "terracotta": "#B45E3C",
      "honey_gold": "#C89A3D",
      "coffee_brown": "#5A3E36"
    },
    "categories": {
      "spices": "#B45E3C",
      "honey": "#C89A3D",
      "tea": "#4D9B93",
      "coffee": "#5A3E36",
      "grains": "#E8E5DC",
      "wellness": "#7FA89F"
    },
    "status": {
      "error": "#C62828",
      "success": "#2E7D32",
      "warning": "#F57C00",
      "info": "#1976D2"
    },
    "text": {
      "primary": "#2C2C2C",
      "secondary": "#666666",
      "muted": "#888888",
      "light": "#CCCCCC"
    }
  },
  "typography": {
    "fonts": {
      "heading": {
        "family": "Nunito Sans",
        "fallback": "-apple-system, BlinkMacSystemFont, system-ui, sans-serif",
        "weights": [400, 600, 700],
        "usage": "Headlines, buttons, navigation, UI labels, all interface text"
      },
      "secondary": {
        "family": "Inter",
        "fallback": "-apple-system, BlinkMacSystemFont, system-ui, sans-serif",
        "weights": [400, 500, 600, 700],
        "usage": "Body text, product descriptions, forms, menus, educational content"
      },
      "body": {
        "family": "Inter",
        "fallback": "-apple-system, BlinkMacSystemFont, system-ui, sans-serif",
        "weights": [400, 500, 600, 700],
        "usage": "Body copy, UI text, forms, menus, buttons"
      }
    },
    "scales": {
      "h1": {
        "mobile": "32px",
        "desktop": "56px",
        "weight": 500,
        "lineHeight": 1.2,
        "letterSpacing": "0.02em"
      },
      "h2": {
        "mobile": "24px",
        "desktop": "42px",
        "weight": 500,
        "lineHeight": 1.3,
        "letterSpacing": "0.01em"
      },
      "h3": {
        "mobile": "20px",
        "desktop": "32px",
        "weight": 500,
        "lineHeight": 1.3,
        "letterSpacing": "0.01em"
      },
      "h4": {
        "mobile": "18px",
        "desktop": "24px",
        "weight": 500,
        "lineHeight": 1.3
      },
      "h5": {
        "size": "18px",
        "weight": 600,
        "lineHeight": 1.4
      },
      "h6": {
        "size": "16px",
        "weight": 600,
        "lineHeight": 1.4
      },
      "body-large": {
        "size": "18px",
        "weight": 400,
        "lineHeight": 1.6
      },
      "body": {
        "size": "16px",
        "weight": 400,
        "lineHeight": 1.6
      },
      "small": {
        "size": "14px",
        "weight": 400,
        "lineHeight": 1.5
      },
      "label": {
        "size": "12px",
        "weight": 600,
        "lineHeight": 1.4,
        "letterSpacing": "0.05em"
      },
      "button": {
        "size": "16px",
        "weight": 600,
        "lineHeight": 1.4
      }
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "40px",
    "2xl": "64px",
    "3xl": "96px"
  },
  "borders": {
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "24px",
      "full": "9999px"
    }
  },
  "shadows": {
    "xs": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "sm": "0 2px 4px rgba(0, 0, 0, 0.08)",
    "md": "0 4px 12px rgba(0, 0, 0, 0.1)",
    "lg": "0 8px 24px rgba(0, 0, 0, 0.12)",
    "xl": "0 12px 32px rgba(0, 0, 0, 0.15)"
  },
  "components": {
    "button": {
      "primary": {
        "background": "#1B5E56",
        "color": "#FFFFFF",
        "padding": "14px 28px",
        "radius": "8px",
        "border": "none",
        "shadow": "0 2px 8px rgba(27, 94, 86, 0.12)",
        "hover": {
          "background": "#154039",
          "shadow": "0 4px 16px rgba(27, 94, 86, 0.2)",
          "transform": "translateY(-2px)"
        }
      },
      "secondary": {
        "background": "transparent",
        "color": "#1B5E56",
        "border": "1.5px solid #1B5E56",
        "padding": "13px 27px",
        "radius": "8px",
        "hover": {
          "background": "#1B5E56",
          "color": "#FFFFFF"
        }
      },
      "tertiary": {
        "background": "none",
        "color": "#1B5E56",
        "border": "none",
        "hover": {
          "color": "#7FA89F"
        }
      }
    },
    "input": {
      "padding": "12px 16px",
      "border": "1.5px solid #E8E5DC",
      "radius": "8px",
      "background": "#FFFFFF",
      "focus": {
        "border": "#1B5E56",
        "shadow": "0 0 0 3px rgba(27, 94, 86, 0.1)"
      }
    },
    "card": {
      "background": "#FFFFFF",
      "border": "1px solid #E7DFD1",
      "radius": "12px",
      "shadow": "0 2px 8px rgba(0, 0, 0, 0.04)",
      "hover": {
        "shadow": "0 8px 24px rgba(0, 0, 0, 0.1)",
        "transform": "translateY(-4px)"
      }
    }
  },
  "breakpoints": {
    "mobile": "< 640px",
    "tablet": "641px - 1024px",
    "desktop": ">= 1025px",
    "mobile-max": "640px",
    "tablet-min": "641px",
    "tablet-max": "1024px",
    "desktop-min": "1025px"
  },
  "container": {
    "maxWidth": "1200px",
    "paddingDesktop": "2rem",
    "paddingTablet": "1.5rem",
    "paddingMobile": "1rem",
    "gridColumns": 12,
    "gapDesktop": "24px",
    "gapTablet": "16px",
    "gapMobile": "8px"
  },
  "zIndex": {
    "dropdown": 100,
    "sticky": 200,
    "modal": 1000,
    "tooltip": 1100
  },
  "accessibility": {
    "contrastPrimary": "7:1",
    "contrastMinimum": "4.5:1",
    "contrastLargeText": "3:1",
    "focusOutlineWidth": "2px",
    "focusOutlineOffset": "3px",
    "minTouchTarget": "44px"
  },
  "animation": {
    "duration": {
      "short": "100ms",
      "default": "200ms",
      "medium": "300ms",
      "long": "500ms",
      "extended": "600ms"
    },
    "easing": {
      "ease-out-slow": "cubic-bezier(0, 0, 0.3, 1)",
      "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-out": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },
