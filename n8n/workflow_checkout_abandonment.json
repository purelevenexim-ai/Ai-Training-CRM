{
  "name": "Pureleven — Checkout Abandonment Recovery",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 5 }] }
      },
      "name": "Every 5 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "https://track.pureleven.com/api/crm/abandonment/checkout",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "window_minutes", "value": "15" },
            { "name": "limit", "value": "50" }
          ]
        },
        "options": {}
      },
      "name": "Get Checkout Abandoners",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "number": [{ "value1": "={{ $json.count }}", "operation": "larger", "value2": 0 }]
        }
      },
      "name": "Any abandoners?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "candidates",
        "options": {}
      },
      "name": "Split Candidates",
      "type": "n8n-nodes-base.splitOut",
      "position": [900, 200]
    },
    {
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.phone }}", "operation": "isNotEmpty" }]
        }
      },
      "name": "Has phone?",
      "type": "n8n-nodes-base.if",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "url": "https://api.wabis.in/v1/send-template",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to", "value": "={{ $json.phone }}" },
            {
              "name": "template",
              "value": "checkout_recovery_v1"
            },
            {
              "name": "params",
              "value": "={{ JSON.stringify([ $json.first_name || 'there', $json.cart_value || '' ]) }}"
            }
          ]
        },
        "options": {
          "allowUnauthorizedCerts": false
        }
      },
      "name": "WhatsApp T+15min",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 140],
      "notes": "Wabis API — template: checkout_recovery_v1\nMessage: 'Hi {{first_name}}, your order is waiting! Complete it now with COD available. [link]'"
    },
    {
      "parameters": {
        "url": "=https://track.pureleven.com/api/crm/abandonment/{{ $json.event_id }}/mark_notified",
        "requestMethod": "PATCH",
        "options": {}
      },
      "name": "Mark Notified",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1560, 200]
    },
    {
      "parameters": {
        "amount": 45,
        "unit": "minutes"
      },
      "name": "Wait 45 min (T+1hr total)",
      "type": "n8n-nodes-base.wait",
      "position": [1780, 200]
    },
    {
      "parameters": {
        "url": "https://api.wabis.in/v1/send-template",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to", "value": "={{ $json.phone }}" },
            { "name": "template", "value": "social_proof_v1" },
            {
              "name": "params",
              "value": "={{ JSON.stringify([ $json.first_name || 'there' ]) }}"
            }
          ]
        },
        "options": {}
      },
      "name": "WhatsApp Social Proof",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2000, 200],
      "notes": "Template: social_proof_v1\nMessage: '500+ happy customers across India love our Kerala spices. Complete your order today!'"
    },
    {
      "parameters": {
        "amount": 5,
        "unit": "days"
      },
      "name": "Wait 5 days",
      "type": "n8n-nodes-base.wait",
      "position": [2220, 200]
    },
    {
      "parameters": {
        "url": "https://api.wabis.in/v1/send-template",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to", "value": "={{ $json.phone }}" },
            { "name": "template", "value": "discount_offer_v1" },
            {
              "name": "params",
              "value": "={{ JSON.stringify([ $json.first_name || 'there', 'PL100OFF' ]) }}"
            }
          ]
        },
        "options": {}
      },
      "name": "WhatsApp ₹100 Offer",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2440, 200],
      "notes": "Template: discount_offer_v1\nMessage: 'Hi {{first_name}}, use code PL100OFF for ₹100 off. Expires in 24 hours!'"
    }
  ],
  "connections": {
    "Every 5 minutes":        { "main": [[{ "node": "Get Checkout Abandoners", "type": "main", "index": 0 }]] },
    "Get Checkout Abandoners":{ "main": [[{ "node": "Any abandoners?", "type": "main", "index": 0 }]] },
    "Any abandoners?":        { "main": [[{ "node": "Split Candidates", "type": "main", "index": 0 }], []] },
    "Split Candidates":       { "main": [[{ "node": "Has phone?", "type": "main", "index": 0 }]] },
    "Has phone?":             { "main": [[{ "node": "WhatsApp T+15min", "type": "main", "index": 0 }], [{ "node": "Mark Notified", "type": "main", "index": 0 }]] },
    "WhatsApp T+15min":       { "main": [[{ "node": "Mark Notified", "type": "main", "index": 0 }]] },
    "Mark Notified":          { "main": [[{ "node": "Wait 45 min (T+1hr total)", "type": "main", "index": 0 }]] },
    "Wait 45 min (T+1hr total)": { "main": [[{ "node": "WhatsApp Social Proof", "type": "main", "index": 0 }]] },
    "WhatsApp Social Proof":  { "main": [[{ "node": "Wait 5 days", "type": "main", "index": 0 }]] },
    "Wait 5 days":            { "main": [[{ "node": "WhatsApp ₹100 Offer", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "pureleven-retargeting" }]
}
