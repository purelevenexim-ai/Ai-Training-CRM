{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'pl-cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart-rework.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 0;
    padding-bottom: 0;
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign free_delivery_threshold_rupees = settings.basil_cart_free_delivery_threshold | default: 649 | plus: 0
  assign free_gift_threshold_rupees     = settings.basil_cart_gift_threshold          | default: 1449 | plus: 0
  assign free_delivery_threshold = free_delivery_threshold_rupees | times: 100
  assign free_gift_threshold     = free_gift_threshold_rupees     | times: 100
  assign free_delivery_value_rupees = settings.basil_cart_delivery_value | default: 80 | plus: 0
  assign cart_total          = cart.total_price
  assign cart_discount_total = cart.total_discount | default: 0
  assign cart_subtotal       = cart.items_subtotal_price | default: cart.total_price

  assign free_delivery_remaining = free_delivery_threshold | minus: cart_total
  assign free_gift_remaining     = free_gift_threshold     | minus: cart_total

  assign free_delivery_unlocked = false
  assign free_gift_unlocked     = false

  if cart_total >= free_delivery_threshold
    assign free_delivery_unlocked = true
  endif
  if cart_total >= free_gift_threshold
    assign free_gift_unlocked = true
  endif
-%}


<cart-items class="gradient color-{{ section.settings.color_scheme }} isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}">

  {%- if cart != empty -%}

    <div class="pl-cart">
      {% render 'pl-urgency-strip' %}

      <div class="page-width">

        <main class="pl-page">
          <div class="pl-layout">

            <!-- LEFT COLUMN: milestones, proof, items, summary, upsell, reviews -->
            <div class="pl-col-l">
              {% render 'basil-reward-strip' %}

              <p class="pl-col-lbl">Items in your cart</p>

              <form action="{{ routes.cart_url }}"
                    class="cart__contents critical-hidden"
                    method="post"
                    id="cart">
                <div id="main-cart-items" data-id="{{ section.id }}">
                  <ul class="pl-ci-list js-contents" role="list">
                    {%- for item in cart.items -%}
                      {% render 'pl-cart-item', item: item %}
                    {%- endfor -%}
                  </ul>
                </div>
                <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
                <p class="visually-hidden" id="shopping-cart-line-item-status"
                   aria-live="polite" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
              </form>

              <a href="{{ routes.all_products_collection_url }}" class="pl-add-more">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add more items
              </a>

              <div class="pl-mobile-summary">
                {% render 'pl-order-summary' %}
              </div>

              <hr class="pl-section-divider">

              {% render 'pl-cart-boosters' %}

              <div class="pl-mobile-trust">
                {% render 'pl-trust' %}
              </div>

              <!-- Founder's note -->
              <div class="pl-founder-card">
                <div class="pl-founder-avatar" aria-hidden="true">S</div>
                <div class="pl-founder-body">
                  <p class="pl-founder-msg">Hi, I&rsquo;m Sajan. I pack every order personally from our farm in Idukki. If anything feels off, WhatsApp me directly.</p>
                  <a href="https://wa.me/918848265849?text=Hi+Sajan%2C+I+have+a+question+about+my+Pure+Leven+order"
                     target="_blank" rel="noopener noreferrer"
                     class="pl-founder-wa"
                     aria-label="WhatsApp Sajan directly">
                    &#128242; WhatsApp me
                  </a>
                </div>
              </div>

              <!-- Gift message -->
              <div class="pl-gift-card">
                <label class="pl-gift-toggle-row" for="pl-gift-check">
                  <input type="checkbox" id="pl-gift-check" class="pl-gift-check"
                         onchange="plToggleGiftMsg(this)" aria-controls="pl-gift-msg-wrap">
                  <span class="pl-gift-icon" aria-hidden="true">&#127873;</span>
                  <span class="pl-gift-label">Add a gift message (free)</span>
                </label>
                <div id="pl-gift-msg-wrap" class="pl-gift-msg-wrap" hidden>
                  <textarea id="pl-gift-msg"
                            class="pl-gift-textarea"
                            name="note"
                            data-pl-gift-note
                            placeholder="Write your message here — we&rsquo;ll print it on a card inside the package."
                            maxlength="280"
                            rows="3"
                            aria-label="Gift message"></textarea>
                  <span class="pl-gift-char" id="pl-gift-char" aria-live="polite">280 characters remaining</span>
                </div>
              </div>

              {% render 'pl-reviews' %}

              <a href="https://wa.me/?text={{ 'Check+out+my+Pure+Leven+cart+%E2%80%94+farm-fresh+spices+from+Idukki%2C+Kerala%3A+https%3A%2F%2Fpureleven.com%2Fcart' }}"
                 class="pl-wa-share"
                 target="_blank" rel="noopener noreferrer"
                 aria-label="Share cart via WhatsApp">
                &#128242; Share cart via WhatsApp
              </a>
            </div>

            <!-- RIGHT COLUMN: desktop summary + trust -->
            <div class="pl-col-r">
              {%- comment -%} Required stub — cart.js looks for #main-cart-footer {%- endcomment -%}
              <div id="main-cart-footer" data-id="{{ section.id }}" style="display:none;" aria-hidden="true">
                <div class="js-contents"></div>
              </div>

              {% render 'pl-order-summary' %}
              {% render 'pl-trust' %}
            </div>

          </div><!-- /pl-layout -->
        </main>

        {% render 'pl-sticky-bar' %}
      </div><!-- /page-width -->
    </div><!-- /pl-cart -->

  {%- else -%}

    <div class="cart__warnings">
      <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="button">{{ 'general.continue_shopping' | t }}</a>
      {%- if shop.customer_accounts_enabled and customer == null -%}
        <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
        <p class="cart__login-paragraph">{{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}</p>
      {%- endif -%}
      <div id="main-cart-footer" data-id="{{ section.id }}" style="display:none;"><div class="js-contents"></div></div>
    </div>

  {%- endif -%}

</cart-items>

<script src="{{ 'pl-cart.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "cart_promo_code",
      "label": "Cart urgency strip promo code",
      "default": "FRESH10"
    },
    {
      "type": "text",
      "id": "cart_promo_discount",
      "label": "Promo discount label (e.g. 10%)",
      "default": "10%"
    },
    {
      "type": "checkbox",
      "id": "cart_phone_reveal_disabled",
      "label": "Disable phone reveal coupon block",
      "default": false
    },
    {
      "type": "text",
      "id": "basil_cart_topup_collection",
      "label": "Upsell carousel collection handle",
      "default": "cart-upsells"
    },
    {
      "type": "text",
      "id": "basil_cart_review_quote",
      "label": "Featured review quote",
      "default": "The cardamom is absolutely fresh — you can smell Kerala the moment you open the pack. Best spice I have ordered online."
    },
    {
      "type": "text",
      "id": "basil_cart_review_author",
      "label": "Featured review author",
      "default": "Priya M., Kochi"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}