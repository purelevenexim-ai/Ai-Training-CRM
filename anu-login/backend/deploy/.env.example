ANU_LOGIN_DATABASE_PATH=/var/lib/anu-login-backend/anu_login.sqlite3
ANU_LOGIN_ALLOWED_ORIGINS=https://pureleven.com,https://www.pureleven.com
ANU_LOGIN_DEFAULT_COUPON=PURE10
ANU_LOGIN_ADMIN_SECRET=
ANU_LOGIN_SHOPIFY_API_VERSION=2026-07

# ── Shopify Admin API (for webhook registration script) ──────────────────────
SHOPIFY_SHOP_DOMAIN=rwxtic-gz.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=<SHOPIFY_ADMIN_TOKEN>
# Get from Shopify Admin → Settings → Notifications → Webhooks (after first webhook send)
SHOPIFY_WEBHOOK_SECRET=

# ── Delhivery ────────────────────────────────────────────────────────────────
# Token from Delhivery partner portal → Integrations → API
DELHIVERY_API_TOKEN=37ce9815dcdb4a259163ef6ac8bc56beb3e6b252
# Secret from Delhivery → Integrations → Webhooks → Shared Secret
DELHIVERY_WEBHOOK_SECRET=

# ── Wabis WhatsApp API ───────────────────────────────────────────────────────
# From Wabis dashboard → Settings → API Keys
WABIS_API_KEY=
WABIS_BASE_URL=https://api.wabis.io
# Wabis phone number ID (shown in Wabis dashboard → Phone Numbers)
WABIS_PHONE_NUMBER_ID=

# ── Meta Graph API (for template submission script only) ─────────────────────
# Meta Business Suite → System Users → Generate Token (whatsapp_business_management scope)
META_ACCESS_TOKEN=
# Meta Business Suite → WhatsApp → Account → Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Meta Business Suite → WhatsApp → Account → Phone Number ID
META_PHONE_NUMBER_ID=

# ── Public base URL for Shopify/Wabis webhook callbacks ─────────────────────
# Use your localtunnel / production domain (no trailing slash)
PUBLIC_BASE_URL=https://your-tunnel.loca.lt
