{%- comment -%}
  Critical styles snippet - render inline in theme.liquid <head>
  This loads essential above-the-fold styles immediately
  The rest of CSS loads asynchronously below
  
  Usage in layout/theme.liquid:
  <style>
    {% render 'critical-styles' %}
  </style>
{%- endcomment -%}

html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Keep this snippet non-destructive. Dawn's layout, typography, buttons, and media rules live in the theme CSS assets. */
